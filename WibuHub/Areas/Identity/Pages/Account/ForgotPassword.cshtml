@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot your password?";
}

<div class="forgot-modal-overlay">
    <div class="auth-container forgot-modal-card">
        <a asp-page="./Login" class="forgot-modal-close" aria-label="Close forgot password form">&times;</a>
        <h2 class="forgot-modal-title">Forgot Password</h2>
        <p class="forgot-modal-subtitle">Enter your email and we'll send you a reset link.</p>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="error-message" style="display: block; margin-bottom: 15px; text-align: center;" role="alert"></div>
            <div class="form-group">
                <label asp-for="Input.Email">Email</label>
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="admin@wibuhub.com" />
                <span asp-validation-for="Input.Email" style="color: #dc2626; font-size: 0.85rem; margin-top: 5px; display: block;"></span>
            </div>
            <button type="submit" class="btn-auth">
                <i class="fas fa-paper-plane" style="margin-right: 8px;"></i>Send reset link
            </button>
        </form>

        <div class="auth-footer">
            Remembered your password? <a asp-page="./Login">Back to login</a>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .forgot-modal-overlay {
            position: fixed;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(15, 23, 42, 0.6);
            backdrop-filter: blur(4px);
            z-index: 2000;
        }

        .forgot-modal-card {
            position: relative;
            max-width: 620px;
            width: min(90vw, 620px);
            margin: 0;
            padding: 40px;
            border-radius: 28px;
            animation: forgotFadeInUp 0.3s ease;
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.3);
        }

        .forgot-modal-close {
            position: absolute;
            top: 18px;
            right: 24px;
            font-size: 34px;
            color: #94a3b8;
            text-decoration: none;
            line-height: 1;
        }

        .forgot-modal-title {
            font-size: 44px;
            line-height: 1.1;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 8px;
            text-align: left;
        }

        .forgot-modal-subtitle {
            margin-bottom: 26px;
            color: #64748b;
            text-align: left;
            font-size: 18px;
        }

        @@keyframes forgotFadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@media (max-width: 768px) {
            .forgot-modal-card {
                padding: 28px 22px;
            }

            .forgot-modal-title {
                font-size: 34px;
            }

            .forgot-modal-subtitle {
                font-size: 16px;
            }
        }
    </style>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

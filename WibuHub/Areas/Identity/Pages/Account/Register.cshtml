@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="auth-container">
    <div class="auth-header">
        <i class="fas fa-user-plus"></i>
        <h2>Register</h2>
        <p>Create a new administrator account</p>
    </div>

    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">

        @* Hiển thị lỗi tổng quát (nếu có) *@
        <div asp-validation-summary="ModelOnly" class="error-message" style="display: block; margin-bottom: 15px; text-align: center;" role="alert"></div>

        @* Ghi chú: Mặc định Identity không có trường Name (Họ tên). 
           Nếu ApplicationUser của bạn có thêm trường này, hãy mở comment đoạn dưới đây.
        *@
        @* <div class="form-group">
            <label asp-for="Input.Name">Họ tên</label>
            <input asp-for="Input.Name" class="form-control" placeholder="Nguyễn Văn A" />
            <span asp-validation-for="Input.Name" style="color: #dc2626; font-size: 0.85rem; margin-top: 5px; display: block;"></span>
        </div> 
        *@

        <div class="form-group">
            <label asp-for="Input.Email">Email</label>
            <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="admin@wibuhub.com" />
            @* Span hiển thị lỗi validation của ASP.NET *@
            <span asp-validation-for="Input.Email" style="color: #dc2626; font-size: 0.85rem; margin-top: 5px; display: block;"></span>
        </div>

        <div class="form-group">
            <label asp-for="Input.Password">Mật khẩu</label>
            <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="••••••••" id="adminRegisterPassword" />
            <button type="button" class="btn-auth" style="margin-top: 8px; width: auto; padding: 8px 14px;" data-password-target="#adminRegisterPassword">Hiện mật khẩu</button>
            <span asp-validation-for="Input.Password" style="color: #dc2626; font-size: 0.85rem; margin-top: 5px; display: block;"></span>
        </div>

        <div class="form-group">
            <label asp-for="Input.ConfirmPassword">Xác nhận mật khẩu</label>
            <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="••••••••" id="adminRegisterConfirmPassword" />
            <button type="button" class="btn-auth" style="margin-top: 8px; width: auto; padding: 8px 14px;" data-password-target="#adminRegisterConfirmPassword">Hiện mật khẩu</button>
            <span asp-validation-for="Input.ConfirmPassword" style="color: #dc2626; font-size: 0.85rem; margin-top: 5px; display: block;"></span>
        </div>

        <button id="registerSubmit" type="submit" class="btn-auth">
            <i class="fas fa-check-circle" style="margin-right: 8px;"></i>Register
        </button>
    </form>

    <div class="auth-footer">
        Do you already have an account? <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Login</a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelectorAll('[data-password-target]').forEach(function (button) {
            button.addEventListener('click', function () {
                const selector = button.getAttribute('data-password-target');
                const input = selector ? document.querySelector(selector) : null;
                if (!input) {
                    return;
                }

                const isPassword = input.type === 'password';
                input.type = isPassword ? 'text' : 'password';
                button.textContent = isPassword ? 'Ẩn mật khẩu' : 'Hiện mật khẩu';
            });
        });
    </script>
}
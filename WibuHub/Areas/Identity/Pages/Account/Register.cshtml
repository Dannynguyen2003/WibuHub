@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="auth-container">
    <div class="auth-header">
        <i class="fas fa-user-plus"></i>
        <h2>Register</h2>
        <p>Create a new administrator account</p>
    </div>

    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">

        @* Show general summary errors (if any) *@
        <div asp-validation-summary="ModelOnly" class="error-message" style="display: block; margin-bottom: 15px; text-align: center;" role="alert"></div>

        @* Note: By default Identity does not have a Name field. 
           If your ApplicationUser has this field, uncomment the code below.
        *@
        @* <div class="form-group">
            <label asp-for="Input.Name">Full Name</label>
            <input asp-for="Input.Name" class="form-control" placeholder="Nguyen Van A" />
            <span asp-validation-for="Input.Name" style="color: #dc2626; font-size: 0.85rem; margin-top: 5px; display: block;"></span>
        </div> 
        *@

        <div class="form-group">
            <label asp-for="Input.Email">Email</label>
            <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="admin@wibuhub.com" />
            @* Span to display ASP.NET validation error *@
            <span asp-validation-for="Input.Email" style="color: #dc2626; font-size: 0.85rem; margin-top: 5px; display: block;"></span>
        </div>

        <div class="form-group">
            <label asp-for="Input.Password">Password</label>
            <div style="position: relative; display: flex; align-items: center;">
                <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="••••••••" data-password-field="admin-register-password" style="padding-right: 40px;" />
                <button type="button" data-password-toggle="admin-register-password" style="position: absolute; right: 10px; background: transparent; border: none; cursor: pointer; color: #a0aec0; padding: 0; display: flex; align-items: center; justify-content: center;" aria-label="Toggle password visibility">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                </button>
            </div>
            <span asp-validation-for="Input.Password" style="color: #dc2626; font-size: 0.85rem; margin-top: 5px; display: block;"></span>
        </div>

        <div class="form-group">
            <label asp-for="Input.ConfirmPassword">Confirm Password</label>
            <div style="position: relative; display: flex; align-items: center;">
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="••••••••" data-password-field="admin-register-confirm-password" style="padding-right: 40px;" />
                <button type="button" data-password-toggle="admin-register-confirm-password" style="position: absolute; right: 10px; background: transparent; border: none; cursor: pointer; color: #a0aec0; padding: 0; display: flex; align-items: center; justify-content: center;" aria-label="Toggle password visibility">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                </button>
            </div>
            <span asp-validation-for="Input.ConfirmPassword" style="color: #dc2626; font-size: 0.85rem; margin-top: 5px; display: block;"></span>
        </div>

        <button id="registerSubmit" type="submit" class="btn-auth">
            <i class="fas fa-check-circle" style="margin-right: 8px;"></i>Register
        </button>
    </form>

    <div class="auth-footer">
        Do you already have an account? <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Login</a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelectorAll('[data-password-toggle]').forEach(function (button) {
            button.addEventListener('click', function () {
                const fieldName = button.getAttribute('data-password-toggle');
                const passwordInput = document.querySelector('[data-password-field="' + fieldName + '"]');

                if (!passwordInput) {
                    return;
                }

                const isPassword = passwordInput.type === 'password';
                passwordInput.type = isPassword ? 'text' : 'password';

                if (isPassword) {
                    button.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>';
                } else {
                    button.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>';
                }
            });
        });
    </script>
}
@page
@model LoginModel

@{
    ViewData["Title"] = "Login";
}

<div class="auth-container">
    <div class="auth-header">
        <i class="fas fa-book-open"></i>
        <h2>Admin Login</h2>
        <p>Enter information to administer WibuHub</p>
    </div>

    <form id="account" method="post">
        <div asp-validation-summary="ModelOnly" class="error-message" style="display: block;" role="alert"></div>

        <div class="form-group">
            <label asp-for="Input.Email">Email</label>
            <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="admin@wibuhub.com" />
            <span asp-validation-for="Input.Email" class="error-message" style="display: block; color: #dc2626; font-size: 0.9rem; margin-top: 5px;"></span>
        </div>

        <div class="form-group">
            <label asp-for="Input.Password">Password</label>
            <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="••••••••" id="adminLoginPassword" />
            <button type="button" class="btn-auth" style="margin-top: 8px; width: auto; padding: 8px 14px;" data-password-target="#adminLoginPassword">Show password</button>
            <span asp-validation-for="Input.Password" class="error-message" style="display: block; color: #dc2626; font-size: 0.9rem; margin-top: 5px;"></span>
        </div>

        <div class="form-group" style="display: flex; align-items: center; gap: 8px;">
            <input class="form-check-input" asp-for="Input.RememberMe" style="margin: 0;" />
            <label asp-for="Input.RememberMe" style="margin: 0; font-weight: normal; color: #475569;">
                @Html.DisplayNameFor(m => m.Input.RememberMe)
            </label>
        </div>

        <button id="login-submit" type="submit" class="btn-auth">
            <i class="fas fa-sign-in-alt" style="margin-right: 8px;"></i>Login
        </button>
    </form>

    <div class="auth-footer">
        Don't have an account? <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Register Now</a>
        <br />
        <a id="forgot-password" asp-page="./ForgotPassword" style="font-size: 0.9rem; margin-top: 10px; display: inline-block;">Forgot the password</a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelectorAll('[data-password-target]').forEach(function (button) {
            button.addEventListener('click', function () {
                const selector = button.getAttribute('data-password-target');
                const input = selector ? document.querySelector(selector) : null;
                if (!input) {
                    return;
                }

                const isPassword = input.type === 'password';
                input.type = isPassword ? 'text' : 'password';
                button.textContent = isPassword ? 'Hide password' : 'Show password';
            });
        });
    </script>
}
@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = "Xác nhận đăng ký";
}

<div class="auth-container" style="text-align: center;">
    <div class="auth-header">
        <i class="fas fa-envelope-open-text"></i>
        <h2>Xác nhận tài khoản</h2>
        <p>Bước cuối cùng để hoàn tất</p>
    </div>

    @if (Model.DisplayConfirmAccountLink)
    {
        <div style="margin-top: 20px;">
            <p style="color: #64748b; line-height: 1.6; margin-bottom: 25px;">
                (Môi trường Dev) Hệ thống hiện chưa cấu hình dịch vụ gửi email thực tế.
                <br />Để xem hướng dẫn cấu hình, tham khảo <a href="https://aka.ms/aspaccountconf" target="_blank" style="color: #2563eb; text-decoration: none;">tài liệu tại đây</a>.
            </p>

            @* Biến thẻ a thành giao diện nút bấm btn-auth *@
            <a id="confirm-link" href="@Model.EmailConfirmationUrl" class="btn-auth" style="display: block; text-decoration: none;">
                <i class="fas fa-check-circle" style="margin-right: 8px;"></i> Bấm vào đây để xác nhận
            </a>
        </div>
    }
    else
    {
        <div style="margin-top: 20px;">
            <p style="color: #334155; font-size: 1.1rem; line-height: 1.6; padding: 20px; background: #f8fafc; border-radius: 15px; border: 1px dashed #cbd5e1;">
                <i class="fas fa-paper-plane" style="color: #2563eb; margin-right: 8px;"></i>
                Một email xác nhận đã được gửi đến hộp thư của bạn. Vui lòng kiểm tra email và làm theo hướng dẫn.
            </p>
        </div>
    }

    <div class="auth-footer" style="margin-top: 30px;">
        <a asp-page="./Login" style="display: inline-flex; align-items: center; gap: 8px; color: #64748b;">
            <i class="fas fa-arrow-left"></i> Quay lại trang Đăng nhập
        </a>
    </div>
</div>
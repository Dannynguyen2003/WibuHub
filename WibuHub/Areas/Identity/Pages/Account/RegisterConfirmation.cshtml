@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = "Registration confirmation";
}

<div class="auth-container" style="text-align: center;">
    <div class="auth-header">
        <i class="fas fa-envelope-open-text"></i>
        <h2>Confirm your account</h2>
        <p>The last step to complete</p>
    </div>

    @if (Model.DisplayConfirmAccountLink)
    {
        <div style="margin-top: 20px;">
            <p style="color: #64748b; line-height: 1.6; margin-bottom: 25px;">
                (Dev Environment) The system has not configured a real email sender service yet.
                <br />To see configuration guide, refer to <a href="https://aka.ms/aspaccountconf" target="_blank" style="color: #2563eb; text-decoration: none;">the documentation here</a>.
            </p>

            @* Convert anchor tag into btn-auth interface *@
            <a id="confirm-link" href="@Model.EmailConfirmationUrl" class="btn-auth" style="display: block; text-decoration: none;">
                <i class="fas fa-check-circle" style="margin-right: 8px;"></i> Click here to confirm
            </a>
        </div>
    }
    else
    {
        <div style="margin-top: 20px;">
            <p style="color: #334155; font-size: 1.1rem; line-height: 1.6; padding: 20px; background: #f8fafc; border-radius: 15px; border: 1px dashed #cbd5e1;">
                <i class="fas fa-paper-plane" style="color: #2563eb; margin-right: 8px;"></i>
                A confirmation email has been sent to your inbox. Please check your email and follow the instructions.
            </p>
        </div>
    }

    <div class="auth-footer" style="margin-top: 30px;">
        <a asp-page="./Login" style="display: inline-flex; align-items: center; gap: 8px; color: #64748b;">
            <i class="fas fa-arrow-left"></i> Back to Login page
        </a>
    </div>
</div>
@model IEnumerable<WibuHub.ApplicationCore.Entities.Order>

@{
    ViewData["Title"] = "Qu?n l? ūűn hŗng";
    var statuses = ViewBag.StatusOptions as IEnumerable<string> ?? Enumerable.Empty<string>();
    var selectedStatus = ViewBag.SelectedStatus as string;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h1>Qu?n l? ūűn hŗng</h1>
        <div class="d-flex align-items-center" style="gap: 12px;">
            <a asp-action="History" class="btn-secondary btn-sm">L?ch s? giao d?ch</a>
            <form method="get" class="filter-bar filter-bar-inline">
                <label for="status" class="form-label">Tr?ng thŠi thanh toŠn:</label>
                <select id="status" name="status" class="form-control" style="max-width: 220px;">
                    <option value="">T?t c?</option>
                    @foreach (var status in statuses)
                    {
                        <option value="@status" selected="@(status == selectedStatus)">@status</option>
                    }
                </select>
                <button type="submit" class="btn-primary btn-sm">L?c</button>
            </form>
        </div>
    </div>

    <table class="data-table">
        <thead>
            <tr>
                <th style="width: 28%">M? ūűn</th>
                <th style="width: 16%">User</th>
                <th style="width: 14%">Th?i gian</th>
                <th style="width: 14%">T?ng ti?n</th>
                <th style="width: 14%">Phżűng th?c</th>
                <th style="width: 12%">Tr?ng thŠi</th>
                <th style="width: 14%" class="text-center">Thao tŠc</th>
            </tr>
        </thead>
        <tbody>
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td class="text-break">@item.Id</td>
                    <td>@item.UserId</td>
                    <td>@item.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@item.TotalAmount.ToString("N0") Ģ</td>
                    <td>@item.PaymentMethod</td>
                    <td><span class="badge-status">@item.PaymentStatus</span></td>
                    <td class="action-cell">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn-secondary btn-sm">Chi ti?t</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="7" class="text-center">Chża ců ūűn hŗng nŗo.</td>
            </tr>
        }
        </tbody>
    </table>
</div>

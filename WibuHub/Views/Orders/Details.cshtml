@using WibuHub.ApplicationCore.Entities.Identity
@model WibuHub.ApplicationCore.Entities.Order


@{
    ViewData["Title"] = "Order Detail";

    // 1. VIỆT HÓA TRẠNG THÁI
    var statusText = (Model.PaymentStatus ?? string.Empty).ToLowerInvariant() switch
    {
        "completed" => "Hoàn thành",
        "pending" => "Đang chờ thanh toán",
        "cancelled" => "Đã hủy",
        "canceled" => "Đã hủy",
        _ => string.IsNullOrWhiteSpace(Model.PaymentStatus) ? "Chưa cập nhật" : Model.PaymentStatus
    };

    // 2. CSS CLASS
    var statusClass = (Model.PaymentStatus ?? string.Empty).ToLowerInvariant() switch
    {
        "completed" => "order-badge",
        "pending" => "order-badge pending",
        "cancelled" => "order-badge cancelled",
        "canceled" => "order-badge cancelled",
        _ => "order-badge"
    };

    var customer = ViewBag.Customer as StoryUser;
    var customerName = customer?.FullName ?? customer?.UserName ?? (string.IsNullOrWhiteSpace(Model.UserId) ? "Khách hàng" : Model.UserId);
    var customerEmail = customer?.Email ?? Model.Email ?? "Chưa cập nhật";
    var customerPhone = customer?.PhoneNumber ?? Model.Phone ?? "Chưa cập nhật";

    // Đã gỡ bỏ ShippingAddress gây lỗi
    var customerAddress = "Thanh toán trực tuyến (Sản phẩm số)";

    var customerAvatar = string.IsNullOrWhiteSpace(customer?.Avatar)
        ? "https://ui-avatars.com/api/?name=Anonymous&background=E2E8F0&color=475569"
        : customer.Avatar;

    var vipPackagePrices = new Dictionary<string, decimal>(StringComparer.OrdinalIgnoreCase)
    {
        ["VIP 1 Tháng"] = 99000m,
        ["VIP 3 Tháng"] = 249000m,
        ["VIP 12 Tháng"] = 799000m
    };

    var vipItems = new List<(string Name, int Quantity, decimal? Price)>();
    if (!string.IsNullOrWhiteSpace(Model.Note) && Model.Note.StartsWith("Đăng ký VIP:", StringComparison.OrdinalIgnoreCase))
    {
        var rawItems = Model.Note.Substring("Đăng ký VIP:".Length).Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        foreach (var rawItem in rawItems)
        {
            var parts = rawItem.Split('x', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            var name = parts.Length > 0 ? parts[0] : rawItem;
            var quantity = 1;

            int parsedQuantity = 0;
            if (parts.Length > 1 && int.TryParse(parts[1], out parsedQuantity))
            {
                quantity = parsedQuantity;
            }

            decimal price = 0m;
            vipPackagePrices.TryGetValue(name, out price);

            vipItems.Add((name, quantity, price == 0 ? null : price));
        }
    }
}
<link href="~/css/Order.css" rel="stylesheet" />
<div class="order-container">
    <div class="breadcrumb">
        <a asp-action="Index">Đơn hàng</a>
        <i class="fas fa-chevron-right"></i>
        <span>Chi tiết đơn #@Model.Id</span>
    </div>

    <div class="order-header-card">
        <div class="order-info">
            <h1>Đơn hàng #@Model.Id</h1>
            <div class="order-meta">
                <span class="meta-item"><i class="fas fa-user"></i> @customerName</span>
                <span class="meta-item"><i class="fas fa-credit-card"></i> @(string.IsNullOrWhiteSpace(Model.PaymentMethod) ? "Chưa cập nhật" : Model.PaymentMethod)</span>
                <span class="meta-item"><i class="fas fa-hashtag"></i> @(string.IsNullOrWhiteSpace(Model.TransactionId) ? "Chưa cập nhật" : Model.TransactionId)</span>
                <span class="meta-item"><i class="fas fa-clock"></i> @Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
            </div>
        </div>
        <div>
            <span class="@statusClass"><i class="fas fa-check-circle"></i> @statusText</span>
        </div>
        <div class="action-buttons">
            <a class="btn-outline" asp-action="Index"><i class="fas fa-arrow-left"></i> Quay lại</a>
        </div>
    </div>

    <div class="order-grid">
        <div class="card">
            <div class="card-title"><i class="fas fa-box"></i> Sản phẩm trong đơn</div>
            <table class="order-items">
                <thead>
                    <tr><th>Sản phẩm</th><th>Giá</th><th>Số lượng</th><th>Tổng</th></tr>
                </thead>
                <tbody>
                    @if (Model.OrderDetails != null && Model.OrderDetails.Any())
                    {
                        foreach (var detail in Model.OrderDetails)
                        {
                            <tr>
                                <td>@(detail.Story?.StoryName ?? "Chưa cập nhật")</td>
                                <td>@detail.UnitPrice.ToString("N0")đ</td>
                                <td>@detail.Quantity</td>
                                <td>@detail.Amount.ToString("N0")đ</td>
                            </tr>
                        }
                    }
                    @foreach (var vipItem in vipItems)
                    {
                        var vipTotal = vipItem.Price.HasValue ? vipItem.Price.Value * vipItem.Quantity : (decimal?)null;
                        <tr>
                            <td>@vipItem.Name</td>
                            <td>@(vipItem.Price.HasValue? vipItem.Price.Value.ToString("N0") + "đ" : "-")</td>
                            <td>@vipItem.Quantity</td>
                            <td>@(vipTotal.HasValue? vipTotal.Value.ToString("N0") + "đ" : "-")</td>
                        </tr>
                    }
                </tbody>
            </table>
            <div style="margin-top: 20px;">
                <div class="summary-row">
                    <span>Tạm tính</span>
                    <span>@Model.Amount.ToString("N0")đ</span>
                </div>
                <div class="summary-row">
                    <span>Thuế</span>
                    <span>@Model.Tax.ToString("N0")đ</span>
                </div>
                <div class="summary-row total">
                    <span>Tổng cộng</span>
                    <span>@Model.TotalAmount.ToString("N0")đ</span>
                </div>
            </div>
        </div>

        <div>
            <div class="card" style="margin-bottom: 25px;">
                <div class="card-title"><i class="fas fa-user-circle"></i> Khách hàng</div>
                <div class="customer-row">
                    <img src="@customerAvatar" class="customer-avatar" alt="Khách hàng">
                    <div class="customer-details">
                        <h4>@customerName</h4>
                        <p><i class="fas fa-envelope"></i> @customerEmail</p>
                        <p><i class="fas fa-phone-alt"></i> @customerPhone</p>
                    </div>
                </div>
                <ul class="info-list">
                    <li><i class="fas fa-map-marker-alt"></i> @customerAddress</li>
                    <li><i class="fas fa-pen"></i> @(string.IsNullOrWhiteSpace(Model.Note) ? "Không có ghi chú" : Model.Note)</li>
                </ul>
            </div>

            <div class="card">
                <div class="card-title"><i class="fas fa-credit-card"></i> Thanh toán</div>
                <ul class="info-list">
                    <li><i class="fas fa-qrcode"></i> Mã giao dịch: <strong>@(string.IsNullOrWhiteSpace(Model.TransactionId) ? "Chưa cập nhật" : Model.TransactionId)</strong></li>
                    <li><i class="fas fa-credit-card"></i> Phương thức: @(string.IsNullOrWhiteSpace(Model.PaymentMethod) ? "Chưa cập nhật" : Model.PaymentMethod)</li>
                    <li><i class="fas fa-check-circle" style="color:#16a34a;"></i> Trạng thái: @statusText</li>
                </ul>
            </div>
        </div>
    </div>
</div>
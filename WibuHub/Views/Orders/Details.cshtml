@using WibuHub.ApplicationCore.Entities.Identity
@model WibuHub.ApplicationCore.Entities.Order


@{
    ViewData["Title"] = "Order Detail";

    // 1. VIỆT HÓA TRẠNG THÁI
    var statusText = (Model.PaymentStatus ?? string.Empty).ToLowerInvariant() switch
    {
        "completed" => "Completed",
        "pending" => "Pending Payment",
        "cancelled" => "Cancelled",
        "canceled" => "Cancelled",
        _ => string.IsNullOrWhiteSpace(Model.PaymentStatus) ? "Not Updated" : Model.PaymentStatus
    };

    // 2. CSS CLASS
    var statusClass = (Model.PaymentStatus ?? string.Empty).ToLowerInvariant() switch
    {
        "completed" => "order-badge",
        "pending" => "order-badge pending",
        "cancelled" => "order-badge cancelled",
        "canceled" => "order-badge cancelled",
        _ => "order-badge"
    };

    var customer = ViewBag.Customer as StoryUser;
    var customerName = customer?.FullName ?? customer?.UserName ?? (string.IsNullOrWhiteSpace(Model.UserId) ? "Customer" : Model.UserId);
    var customerEmail = customer?.Email ?? Model.Email ?? "Not Updated";
    var customerPhone = customer?.PhoneNumber ?? Model.Phone ?? "Not Updated";

    // Đã gỡ bỏ ShippingAddress gây lỗi
    var customerAddress = "Online Payment (Digital Product)";

    var customerAvatar = string.IsNullOrWhiteSpace(customer?.Avatar)
        ? "https://ui-avatars.com/api/?name=Anonymous&background=E2E8F0&color=475569"
        : customer.Avatar;

}
<link href="~/css/Order.css" rel="stylesheet" />
<div class="order-container">
    <div class="breadcrumb">
        <a asp-action="Index">Orders</a>
        <i class="fas fa-chevron-right"></i>
        <span>Order Detail #@Model.Id</span>
    </div>

    <div class="order-header-card">
        <div class="order-info">
            <h1>Order #@Model.Id</h1>
            <div class="order-meta">
                <span class="meta-item"><i class="fas fa-user"></i> @customerName</span>
                <span class="meta-item"><i class="fas fa-credit-card"></i> @(string.IsNullOrWhiteSpace(Model.PaymentMethod) ? "Not Updated" : Model.PaymentMethod)</span>
                <span class="meta-item"><i class="fas fa-hashtag"></i> @(string.IsNullOrWhiteSpace(Model.TransactionId) ? "Not Updated" : Model.TransactionId)</span>
                <span class="meta-item"><i class="fas fa-clock"></i> @Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
            </div>
        </div>
        <div>
            <span class="@statusClass"><i class="fas fa-check-circle"></i> @statusText</span>
        </div>
        <div class="action-buttons">
            <a class="btn-outline" asp-action="Index"><i class="fas fa-arrow-left"></i> Back</a>
        </div>
    </div>

    <div class="order-grid">
        <div class="card">
            <div class="card-title"><i class="fas fa-box"></i> Order Items</div>
            <table class="order-items">
                <thead>
                    <tr><th>Product</th><th>Price</th><th>Quantity</th><th>Total</th></tr>
                </thead>
                <tbody>
                    @if (Model.OrderDetails != null && Model.OrderDetails.Any())
                    {
                        foreach (var detail in Model.OrderDetails)
                        {
                            <tr>
                                <td>@(detail.ItemName ?? detail.Story?.StoryName ?? "Not Updated")</td>
                                <td>@detail.UnitPrice.ToString("N0")đ</td>
                                <td>@detail.Quantity</td>
                                <td>@detail.Amount.ToString("N0")đ</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
            <div style="margin-top: 20px;">
                <div class="summary-row">
                    <span>Subtotal</span>
                    <span>@Model.Amount.ToString("N0")đ</span>
                </div>
                <div class="summary-row">
                    <span>Tax</span>
                    <span>@Model.Tax.ToString("N0")đ</span>
                </div>
                <div class="summary-row total">
                    <span>Grand Total</span>
                    <span>@Model.TotalAmount.ToString("N0")đ</span>
                </div>
            </div>
        </div>

        <div>
            <div class="card" style="margin-bottom: 25px;">
                <div class="card-title"><i class="fas fa-user-circle"></i> Customer</div>
                <div class="customer-row">
                    <img src="@customerAvatar" class="customer-avatar" alt="Customer">
                    <div class="customer-details">
                        <h4>@customerName</h4>
                        <p><i class="fas fa-envelope"></i> @customerEmail</p>
                        <p><i class="fas fa-phone-alt"></i> @customerPhone</p>
                    </div>
                </div>
                <ul class="info-list">
                    <li><i class="fas fa-map-marker-alt"></i> @customerAddress</li>
                    <li><i class="fas fa-pen"></i> @(string.IsNullOrWhiteSpace(Model.Note) ? "No notes" : Model.Note)</li>
                </ul>
            </div>

            <div class="card">
                <div class="card-title"><i class="fas fa-credit-card"></i> Payment</div>
                <ul class="info-list">
                    <li><i class="fas fa-qrcode"></i> Transaction ID: <strong>@(string.IsNullOrWhiteSpace(Model.TransactionId) ? "Not Updated" : Model.TransactionId)</strong></li>
                    <li><i class="fas fa-credit-card"></i> Method: @(string.IsNullOrWhiteSpace(Model.PaymentMethod) ? "Not Updated" : Model.PaymentMethod)</li>
                    <li><i class="fas fa-check-circle" style="color:#16a34a;"></i> Status: @statusText</li>
                </ul>
            </div>
        </div>
    </div>
</div>
@model IEnumerable<WibuHub.ApplicationCore.Entities.Order>

@{
    ViewData["Title"] = "L?ch s? giao d?ch";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h1>L?ch s? giao d?ch</h1>
        <a asp-action="Index" class="btn-secondary btn-sm">Đőn hŕng đang x? l?</a>
    </div>

    <table class="data-table">
        <thead>
            <tr>
                <th style="width: 28%">M? đőn</th>
                <th style="width: 16%">User</th>
                <th style="width: 14%">Th?i gian</th>
                <th style="width: 14%">T?ng ti?n</th>
                <th style="width: 14%">Phýőng th?c</th>
                <th style="width: 12%">Tr?ng thái</th>
                <th style="width: 14%" class="text-center">Thao tác</th>
            </tr>
        </thead>
        <tbody>
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td class="text-break">@item.Id</td>
                    <td>@item.UserId</td>
                    <td>@item.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@item.TotalAmount.ToString("N0") ţ</td>
                    <td>@item.PaymentMethod</td>
                    <td><span class="badge-status">@item.PaymentStatus</span></td>
                    <td class="action-cell">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn-secondary btn-sm">Chi ti?t</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="7" class="text-center">Chýa có giao d?ch nŕo.</td>
            </tr>
        }
        </tbody>
    </table>
</div>

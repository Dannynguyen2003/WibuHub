@model IEnumerable<WibuHub.ApplicationCore.Entities.Order>

@{
    ViewData["Title"] = "Transaction History";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h1>Transaction History</h1>
        <a asp-action="Index" class="btn-secondary btn-sm">Pending Orders</a>
    </div>

    <table class="data-table">
        <thead>
            <tr>
                <th style="width: 28%">Order ID</th>
                <th style="width: 16%">User</th>
                <th style="width: 14%">Time</th>
                <th style="width: 14%">Total</th>
                <th style="width: 14%">Method</th>
                <th style="width: 12%">Status</th>
                <th style="width: 14%" class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td class="text-break">@item.Id</td>
                    <td>@item.UserId</td>
                    <td>@item.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@item.TotalAmount.ToString("N0") ₫</td>
                    <td>@item.PaymentMethod</td>
                    <td><span class="badge-status">@item.PaymentStatus</span></td>
                    <td class="action-cell">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn-secondary btn-sm">Detail</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="7" class="text-center">No transactions yet.</td>
            </tr>
        }
        </tbody>
    </table>
</div>

@model WibuHub.MVC.ViewModels.RoleVM

@{
    ViewData["Title"] = "Xóa Role";
}

<div class="container">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1 class="text-danger">@ViewData["Title"]</h1>
            <hr />

            <div class="alert alert-danger">
                <h4><i class="bi bi-exclamation-triangle"></i> Cảnh báo!</h4>
                <p>Bạn có chắc chắn muốn xóa role này không?</p>
            </div>

            <div class="card">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0">Thông Tin Role Sẽ Bị Xóa</h5>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-4">Tên Role:</dt>
                        <dd class="col-sm-8"><strong>@Model.Name</strong></dd>

                        <dt class="col-sm-4">Mô tả:</dt>
                        <dd class="col-sm-8">@(Model.Description ?? "Không có mô tả")</dd>

                        <dt class="col-sm-4">Số người dùng:</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-primary">@Model.UserCount người dùng</span>
                        </dd>
                    </dl>

                    @if (Model.UserCount > 0)
                    {
                        <div class="alert alert-warning mt-3">
                            <i class="bi bi-exclamation-circle"></i> 
                            <strong>Lưu ý:</strong> Không thể xóa role vì có @Model.UserCount người dùng đang sử dụng role này.
                        </div>
                    }
                </div>
            </div>

            <form asp-action="Delete" method="post" class="mt-3">
                <input type="hidden" asp-for="Id" />
                <div class="d-grid gap-2">
                    @if (Model.UserCount == 0)
                    {
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash"></i> Xác Nhận Xóa
                        </button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-danger" disabled>
                            <i class="bi bi-trash"></i> Không Thể Xóa (Có người dùng đang sử dụng)
                        </button>
                    }
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-x-circle"></i> Hủy
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

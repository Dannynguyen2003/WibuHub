@* @model WibuHub.ApplicationCore.Entities.Author *@
@model WibuHub.MVC.ViewModels.AuthorVM

@{
    ViewData["Title"] = "Add New Author";
    bool isCreate = Model == null || Model.Id == Guid.Empty;
    string actionString = isCreate ? "Create" : "Edit";
    string buttonString = isCreate ? "Create" : "Update";
    bool isDelete = ViewData["IsDelete"] != null && (bool)ViewData["IsDelete"];
}

<div class="container mt-4">
    <h1>Add New Author</h1>
    <hr />

    <div class="row">
        <div class="col-md-4">
            <form asp-action="@actionString">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                @if (!isCreate)
                {
                    <input asp-for="Id" type="hidden" />
                }
                <div class="form-group mb-3">
                    <label asp-for="Name" class="control-label fw-bold">Author Name</label>
                    <input asp-for="Name" class="form-control" placeholder="Example: Nguyen Nhat Anh..." autofocus />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Slug" class="control-label fw-bold">Slug URL</label>
                    <input asp-for="Slug" class="form-control" placeholder="auto-generated-from-title" id="txtSlug" />
                    <small class="form-text text-muted">This is the path on the URL (no accents, hyphenated).</small>
                    <span asp-validation-for="Slug" class="text-danger"></span>
                </div>
                <div class="form-group" style="text-align: center; margin-top: 10px;">
                    <input type="submit" value="@buttonString" class="btn btn-primary" />
                </div>
            </form>
        </div>
        <div id="divAuthorList" class="col-md-8">
            @await Component.InvokeAsync("AuthorList")
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // Automatically generate slug from Name
        document.getElementById("Name").addEventListener("keyup", function () {
            let name = this.value;
            let slug = generateSlug(name);
            document.getElementById("txtSlug").value = slug;
        });

        function generateSlug(text) {
            return text.toString().toLowerCase()
                .replace(/á|à|ả|ạ|ã|ă|ắ|ằ|ẳ|ặ|ẵ|â|ấ|ầ|ẩ|ậ|ẫ/g, 'a')
                .replace(/é|è|ẻ|ẹ|ẽ|ê|ế|ề|ể|ệ|ễ/g, 'e')
                .replace(/i|í|ì|ỉ|ị|ĩ/g, 'i')
                .replace(/ó|ò|ỏ|ọ|õ|ô|ố|ồ|ổ|ộ|ỗ|ơ|ớ|ờ|ở|ợ|ỡ/g, 'o')
                .replace(/ú|ù|ủ|ụ|ũ|ư|ứ|ừ|ử|ự|ữ/g, 'u')
                .replace(/ý|ỳ|ỷ|ỵ|ỹ/g, 'y')
                .replace(/đ/g, 'd')
                .replace(/\s+/g, '-')
                .replace(/[^\w\-]+/g, '')
                .replace(/\-\-+/g, '-')
                .replace(/^-+/, '')
                .replace(/-+$/, '');
        }
    </script>
    <script>
        function openModalDeleteAuthor(idAuthor) {
            if (!confirm("Are you sure you want to delete this author?")) {
                return;
            }
            deleteAuthor(idAuthor);
        }
        function deleteAuthor(idAuthor) {
            let inputToken = document.querySelector("input[name='__RequestVerificationToken']");
            if (!inputToken) {
                console.error("Security token not found!");
                return;
            }
            $.ajax({
                url: '/Authors/Delete',
                type: 'POST',
                data: {
                    id: idAuthor,
                    __RequestVerificationToken: inputToken.value
                },
                success: function (response) {
                    if (response.isOK) {
                        refreshAuthorList();
                    } else {
                        alert("Deletion failed!");
                    }
                },
                error: function () {
                    alert("There was an error connecting to the server.");
                }
            });
        }
        function refreshAuthorList(page = 1) {
            $.get('/Authors/Reload', { page: page }, function (data) {
                $('#divAuthorList').html(data);
            });
        }
    </script>
}

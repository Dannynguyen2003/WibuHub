п»ї@* @model WibuHub.ApplicationCore.Entities.Author *@
@model WibuHub.MVC.ViewModels.AuthorVM

@{
    ViewData["Title"] = "Add New Author";
    bool isCreate = Model == null || Model.Id == Guid.Empty;
    string actionString = isCreate ? "Create" : "Edit";
    string buttonString = isCreate ? "Create" : "Update";
    bool isDelete = ViewData["IsDelete"] != null && (bool)ViewData["IsDelete"];
}

<div class="container mt-4">
    <h1>Add New Author</h1>
    <hr />

    <div class="row">
        <div class="col-md-4">
            <form asp-action="@actionString">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                @if (!isCreate)
                {
                    <input asp-for="Id" type="hidden" />
                }
                <div class="form-group mb-3">
                    <label asp-for="Name" class="control-label fw-bold">Author Name</label>
                    <input asp-for="Name" class="form-control" placeholder="e.g. Author Name..." autofocus />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Slug" class="control-label fw-bold">URL Path (Slug)</label>
                    <input asp-for="Slug" class="form-control" placeholder="auto-generated-from-name" id="txtSlug" />
                    <small class="form-text text-muted">This is the URL path (no accents, hyphens).</small>
                    <span asp-validation-for="Slug" class="text-danger"></span>
                </div>
                <div class="form-group" style="text-align: center; margin-top: 10px;">
                    <input type="submit" value="@buttonString" class="btn btn-primary" />
                </div>
            </form>
        </div>
        <div id="divAuthorList" class="col-md-8">
            @await Component.InvokeAsync("AuthorList")
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // Tб»± Д‘б»™ng tбєЎo Slug khi gГµ TГЄn tГЎc giбєЈ
        document.getElementById("Name").addEventListener("keyup", function () {
            let name = this.value;
            let slug = generateSlug(name);
            document.getElementById("txtSlug").value = slug;
        });

        function generateSlug(text) {
            return text.toString().toLowerCase()
                .replace(/ГЎ|Г |бєЈ|бєЎ|ГЈ|Дѓ|бєЇ|бє±|бєі|бє·|бєµ|Гў|бєҐ|бє§|бє©|бє­|бє«/g, 'a')
                .replace(/Г©|ГЁ|бє»|бє№|бєЅ|ГЄ|бєї|б»Ѓ|б»ѓ|б»‡|б»…/g, 'e')
                .replace(/i|Г­|Г¬|б»‰|б»‹|Д©/g, 'i')
                .replace(/Гі|ГІ|б»Џ|б»Ќ|Гµ|Гґ|б»‘|б»“|б»•|б»™|б»—|ЖЎ|б»›|б»ќ|б»џ|б»Ј|б»Ў/g, 'o')
                .replace(/Гє|Г№|б»§|б»Ґ|Е©|Ж°|б»©|б»«|б»­|б»±|б»Ї/g, 'u')
                .replace(/ГЅ|б»і|б»·|б»µ|б»№/g, 'y')
                .replace(/Д‘/g, 'd')
                .replace(/\s+/g, '-')
                .replace(/[^\w\-]+/g, '')
                .replace(/\-\-+/g, '-')
                .replace(/^-+/, '')
                .replace(/-+$/, '');
        }
    </script>
    <script>
        function openModalDeleteAuthor(idAuthor) {
            if (!confirm("Are you sure you want to delete this author?")) {
                return;
            }
            deleteAuthor(idAuthor);
        }
        function deleteAuthor(idAuthor) {
            let inputToken = document.querySelector("input[name='__RequestVerificationToken']");
            if (!inputToken) {
                console.error("Security token not found!");
                return;
            }
            $.ajax({
                url: '/Authors/Delete',
                type: 'POST',
                data: {
                    id: idAuthor,
                    __RequestVerificationToken: inputToken.value
                },
                success: function (response) {
                    if (response.isOK) {
                        refreshAuthorList();
                    } else {
                        alert("Delete failed!");
                    }
                },
                error: function () {
                    alert("An error occurred while connecting to the server.");
                }
            });
        }
        function refreshAuthorList(page = 1) {
            $.get('/Authors/Reload', { page: page }, function (data) {
                $('#divAuthorList').html(data);
            });
        }
    </script>
}

@{
    ViewData["Title"] = "Quản lý Tác giả";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h1>Quản lý Tác giả</h1>
        <p>
            <a asp-action="Create" class="btn btn-success">
                <i class="fas fa-plus"></i> Tạo mới
            </a>
        </p>
    </div>

    <form id="antiForgeryForm" method="post" class="d-none">
        @Html.AntiForgeryToken()
    </form>

    <div id="divAuthorList">
        @await Component.InvokeAsync("AuthorList")
    </div>
</div>

@section Scripts {
    <script>
        function openModalDeleteAuthor(idAuthor) {
            if (!confirm("Bạn có chắc chắn muốn xóa tác giả này không?")) {
                return;
            }
            deleteAuthor(idAuthor);
        }
        function deleteAuthor(idAuthor) {
            let inputToken = document.querySelector("#antiForgeryForm input[name='__RequestVerificationToken']");
            if (!inputToken) {
                console.error("Không tìm thấy Token bảo mật!");
                return;
            }
            $.ajax({
                url: '/Authors/Delete',
                type: 'POST',
                data: {
                    id: idAuthor,
                    __RequestVerificationToken: inputToken.value
                },
                success: function (response) {
                    if (response.isOK) {
                        refreshAuthorList();
                    } else {
                        alert("Xóa thất bại!");
                    }
                },
                error: function () {
                    alert("Có lỗi xảy ra khi kết nối với máy chủ.");
                }
            });
        }
        function refreshAuthorList(page = 1) {
            $.get('/Authors/Reload', { page: page }, function (data) {
                $('#divAuthorList').html(data);
            });
        }
    </script>
}

@{
    ViewData["Title"] = "Stories Management";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h1>Stories Management</h1>
        <p>
            <a asp-action="Create" class="btn btn-success">
                <i class="fas fa-plus"></i> Create New
            </a>
        </p>
    </div>

    <form id="antiForgeryForm" method="post" class="d-none">
        @Html.AntiForgeryToken()
    </form>

    <div id="divStoryList">
        @await Component.InvokeAsync("StoryList")
    </div>
</div>

@section Scripts {
    <script>
        function openModalDeleteStory(idStory) {
            if (!confirm("Are you sure you want to delete this story?")) {
                return;
            }
            deleteStory(idStory);
        }
        function deleteStory(idStory) {
            let inputToken = document.querySelector("#antiForgeryForm input[name='__RequestVerificationToken']");
            if (!inputToken) {
                console.error("Security token not found!");
                return;
            }
            $.ajax({
                url: '/Stories/Delete',
                type: 'POST',
                data: {
                    id: idStory,
                    __RequestVerificationToken: inputToken.value
                },
                success: function (response) {
                    if (response.isOK) {
                        refreshStoryList();
                    } else {
                        alert("Deletion failed!");
                    }
                },
                error: function () {
                    alert("An error occurred while connecting to the server.");
                }
            });
        }
        function refreshStoryList(page = 1) {
            $.get('/Stories/Reload', { page: page }, function (data) {
                $('#divStoryList').html(data);
            });
        }
    </script>
}

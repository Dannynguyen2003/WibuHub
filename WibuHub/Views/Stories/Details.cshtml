@model WibuHub.ApplicationCore.Entities.Story

@{
    ViewData["Title"] = Model.StoryName;
    var coverUrl = string.IsNullOrWhiteSpace(Model.CoverImage)
        ? "https://via.placeholder.com/240x340?text=No+Cover"
        : Model.CoverImage;
    var statusText = Model.Status switch
    {
        1 => "Completed",
        2 => "Paused",
        _ => "In Progress"
    };
    var authorName = !string.IsNullOrWhiteSpace(Model.AuthorName)
        ? Model.AuthorName
        : Model.Author?.Name ?? "Updating";
    var createdDate = Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy");
    var updateDate = Model.UpdateDate.ToLocalTime().ToString("dd/MM/yyyy");
    var chapterCount = Model.Chapters?.Count ?? 0;

    // Đã sửa: Chỉ lấy danh sách thể loại từ bảng trung gian, bỏ logic fallback cũ
    var categories = Model.StoryCategories?
        .Select(sc => sc.Category?.Name)
        .Where(name => !string.IsNullOrWhiteSpace(name))
        .Distinct()
        .ToList() ?? new List<string>();
}

<div class="story-detail-page">
    <div class="story-detail-card">
        <div class="story-detail-cover">
            <img src="@coverUrl" alt="@Model.StoryName" />
        </div>
        <div class="story-detail-info">
            <h1 class="story-detail-title">@Model.StoryName</h1>
            <div class="story-detail-meta">
                <div class="story-detail-meta-item">
                    <i class="fas fa-user"></i>
                    <span class="label">Author</span>
                    <span class="value">@authorName</span>
                </div>
                <div class="story-detail-meta-item">
                    <i class="far fa-calendar-alt"></i>
                    <span class="label">Created</span>
                    <span class="value">@createdDate</span>
                </div>
                <div class="story-detail-meta-item">
                    <i class="fas fa-history"></i>
                    <span class="label">Updated</span>
                    <span class="value">@updateDate</span>
                </div>
                <div class="story-detail-meta-item">
                    <i class="fas fa-list"></i>
                    <span class="label">Total Chapters</span>
                    <span class="value">@chapterCount</span>
                </div>
                <div class="story-detail-meta-item">
                    <i class="fas fa-signal"></i>
                    <span class="label">Status</span>
                    <span class="value">@statusText</span>
                </div>
                <div class="story-detail-meta-item">
                    <i class="fas fa-heart"></i>
                    <span class="label">Followers</span>
                    <span class="value">@Model.FollowCount</span>
                </div>
                <div class="story-detail-meta-item">
                    <i class="far fa-eye"></i>
                    <span class="label">Views</span>
                    <span class="value">@Model.ViewCount</span>
                </div>
                <div class="story-detail-meta-item">
                    <i class="fas fa-star"></i>
                    <span class="label">Rating</span>
                    <span class="value">@Model.RatingScore.ToString("0.0")</span>
                </div>
            </div>
            @if (categories.Any())
            {
                <div class="story-detail-tags">
                    @foreach (var category in categories)
                    {
                        <span class="story-detail-tag">@category</span>
                    }
                </div>
            }
            <div class="story-detail-actions">
                <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
                <a class="btn btn-outline-secondary" asp-action="Index">Back to List</a>
            </div>
        </div>
    </div>

    <div class="story-detail-chapters">
        <h3>Chapter List</h3>
        @if (Model.Chapters != null && Model.Chapters.Any())
        {
            <div class="story-detail-chapter-list">
                @foreach (var chapter in Model.Chapters.OrderByDescending(c => c.ChapterNumber))
                {
                    <div class="story-detail-chapter-item">
                        <div>
                            <div class="chapter-name">@chapter.Name</div>
                            <div class="chapter-meta">Chapter @chapter.ChapterNumber</div>
                        </div>
                        <span class="chapter-date">@chapter.CreatedAt.ToString("dd/MM/yyyy")</span>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="story-detail-empty">No chapters yet.</div>
        }
    </div>
</div>
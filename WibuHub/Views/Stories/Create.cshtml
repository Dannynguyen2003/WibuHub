@* @model WibuHub.ApplicationCore.Entities.Story *@
@model WibuHub.MVC.ViewModels.StoryVM
﻿

@{
    ViewData["Title"] = "Thêm mới Truyện";
    bool isCreate = Model == null || Model.Id == Guid.Empty;
    string actionString = isCreate ? "Create" : "Edit";
    string buttonString = isCreate ? "Tạo mới" : "Cập nhật";
    }

    <div class="container mt-4">
        <h1>Add New Stories</h1>
        <hr />
        <div class="row">
            <div class="col-md-4">
                <form asp-action="@actionString" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    @if (!isCreate)
                    {
                        <input asp-for="Id" type="hidden" />
                    }
                    <div class="form-group mb-3">
                        <label asp-for="Title" class="control-label fw-bold">Tiêu đề truyện</label>
                        <input asp-for="Title" class="form-control" placeholder="Nhập tiêu đề truyện..." autofocus />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>
                    <div class="form-group mb-3">
                        <label asp-for="AlternativeName" class="control-label fw-bold">Tên khác</label>
                        <input asp-for="AlternativeName" class="form-control" placeholder="Tên tiếng Anh, tên gốc..." />
                        <span asp-validation-for="AlternativeName" class="text-danger"></span>
                    </div>
                <div class="form-group mb-3">
                    <label asp-for="Description" class="control-label fw-bold">Mô tả</label>
                    <textarea asp-for="Description" class="form-control" rows="3" placeholder="Mô tả ngắn về truyện..."></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Slug" class="control-label fw-bold">Đường dẫn (Slug)</label>
                    <input asp-for="Slug" class="form-control" placeholder="tu-dong-sinh-ra-tu-tieu-de" id="txtSlug" />
                    <small class="form-text text-muted">Đây là đường dẫn trên URL (không dấu, gạch ngang).</small>
                    <span asp-validation-for="Slug" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Price" class="control-label fw-bold">Giá bán</label>
                    <input asp-for="Price" asp-format="{0:0.####}" class="form-control" type="number" step="0.0001" min="0" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Discount" class="control-label fw-bold">Giảm giá</label>
                    <input asp-for="Discount" asp-format="{0:0.####}" class="form-control" type="number" step="0.0001" min="0" />
                    <span asp-validation-for="Discount" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="CoverImageFile" class="control-label fw-bold">Ảnh bìa</label>
                    <input asp-for="CoverImageFile" class="form-control" type="file" accept="image/*" />
                    <span asp-validation-for="CoverImageFile" class="text-danger"></span>
                    @if (!string.IsNullOrWhiteSpace(Model?.CoverImage))
                    {
                        <div class="mt-2">
                            <img src="@Model.CoverImage" alt="cover" class="img-thumbnail" style="max-width: 200px;" />
                        </div>
                    }
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Status" class="control-label fw-bold">Trạng thái</label>
                    <select asp-for="Status" class="form-control">
                        <option value="0">Đang tiến hành</option>
                        <option value="1">Hoàn thành</option>
                        <option value="2">Tạm ngưng</option>
                    </select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="AuthorId" class="control-label fw-bold">Tác giả</label>
                    <select asp-for="AuthorId" class="form-control" asp-items="ViewBag.AuthorId"></select>
                    <span asp-validation-for="AuthorId" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="CategoryIds" class="control-label fw-bold">Danh mục</label>
                    <select asp-for="CategoryIds" class="form-control" asp-items="ViewBag.CategoryId" multiple size="6"></select>
                    <span asp-validation-for="CategoryIds" class="text-danger"></span>
                </div>
                <div class="form-group" style="text-align: center; margin-top: 10px;">
                    <input type="submit" value="@buttonString" class="btn btn-primary" />
                </div>
            </form>
        </div>
        <div id="divStoryList" class="col-md-8">
            @await Component.InvokeAsync("StoryList")
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // Tự động tạo Slug khi gõ Tiêu đề
        document.getElementById("Title").addEventListener("keyup", function () {
            let name = this.value;
            let slug = generateSlug(name);
            document.getElementById("txtSlug").value = slug;
        });
            function generateSlug(text) {
                return text.toString().toLowerCase()
                    .replace(/á|à|ả|ạ|ã|ă|ắ|ằ|ẳ|ặ|ẵ|â|ấ|ầ|ẩ|ậ|ẫ/g, 'a')
                    .replace(/é|è|ẻ|ẹ|ẽ|ê|ế|ề|ể|ệ|ễ/g, 'e')
                    .replace(/i|í|ì|ỉ|ị|ĩ/g, 'i')
                    .replace(/ó|ò|ỏ|ọ|õ|ô|ố|ồ|ổ|ộ|ỗ|ơ|ớ|ờ|ở|ợ|ỡ/g, 'o')
                    .replace(/ú|ù|ủ|ụ|ũ|ư|ứ|ừ|ử|ự|ữ/g, 'u')
                    .replace(/ý|ỳ|ỷ|ỵ|ỹ/g, 'y')
                    .replace(/đ/g, 'd')
                    .replace(/\s+/g, '-')
                    .replace(/[^\w\-]+/g, '')
                    .replace(/\-\-+/g, '-')
                    .replace(/^-+/, '')
                    .replace(/-+$/, '');
            }
        </script>
        <script>
            function openModalDeleteStory(idStory) {
                if (!confirm("Bạn có chắc chắn muốn xóa truyện này không?")) {
                    return;
                }
                deleteStory(idStory);
            }
            function deleteStory(idStory) {
                let inputToken = document.querySelector("input[name='__RequestVerificationToken']");
                if (!inputToken) {
                    console.error("Không tìm thấy Token bảo mật!");
                    return;
                }
                $.ajax({
                    url: '/Stories/Delete',
                    type: 'POST',
                    data: {
                        id: idStory,
                        __RequestVerificationToken: inputToken.value
                    },
                    success: function (response) {
                        if (response.isOK) {
                            refreshStoryList();
                        } else {
                            alert("Xóa thất bại!");
                        }
                    },
                    error: function () {
                        alert("Có lỗi xảy ra khi kết nối với máy chủ.");
                    }
                });
            }
            function refreshStoryList(page = 1) {
                $.get('/Stories/Reload', { page: page }, function (data) {
                    $('#divStoryList').html(data);
                });
            }
        </script>
}
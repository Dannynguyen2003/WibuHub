@model WibuHub.ApplicationCore.Entities.Chapter

@{
    ViewData["Title"] = "Details";
}

<div class="container py-4">
    <div class="card shadow-sm">
        <div class="card-header bg-white d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2">
            <div>
                <h1 class="h4 mb-1">@Model?.Name</h1>
                <div class="text-muted">@Model?.Story?.StoryName</div>
            </div>
            <span class="badge bg-primary">Chapter @Model?.ChapterNumber</span>
        </div>
        <div class="card-body">
            <dl class="row mb-0 gy-2">
                <dt class="col-sm-3 text-muted">@Html.DisplayNameFor(model => model.Story)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Story.StoryName)</dd>

                <dt class="col-sm-3 text-muted">@Html.DisplayNameFor(model => model.Name)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Name)</dd>

                <dt class="col-sm-3 text-muted">@Html.DisplayNameFor(model => model.ChapterNumber)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.ChapterNumber)</dd>

                <dt class="col-sm-3 text-muted">@Html.DisplayNameFor(model => model.Slug)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Slug)</dd>

                <dt class="col-sm-3 text-muted">@Html.DisplayNameFor(model => model.ViewCount)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.ViewCount)</dd>

                <dt class="col-sm-3 text-muted">Danh sách ảnh</dt>
                <dd class="col-sm-9">
                    @if (Model.Images != null && Model.Images.Any())
                    {
                        <ul class="list-group list-group-flush border rounded">
                            @foreach (var image in Model.Images.OrderBy(i => i.OrderIndex))
                            {
                                <li class="list-group-item d-flex align-items-center justify-content-between">
                                    <a href="@image.ImageUrl" target="_blank" rel="noopener noreferrer">@image.ImageUrl</a>
                                    <span class="badge bg-light text-muted">#@image.OrderIndex</span>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <span class="text-muted">Chưa có ảnh.</span>
                    }
                </dd>

                <dt class="col-sm-3 text-muted">@Html.DisplayNameFor(model => model.ServerId)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.ServerId)</dd>

                <dt class="col-sm-3 text-muted">@Html.DisplayNameFor(model => model.CreatedAt)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.CreatedAt)</dd>

            </dl>
        </div>
        <div class="card-footer bg-white d-flex gap-2">
            <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model?.Id">Edit</a>
            <a class="btn btn-outline-secondary" asp-action="Index">Back to List</a>
        </div>
    </div>
</div>

@model WibuHub.ApplicationCore.Entities.Chapter

@{
    ViewData["Title"] = "Details";
}

<h1>Chi tiết Chương</h1>

<div>
    <h4>Chapter</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Story)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Story.StoryName)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ChapterNumber)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ChapterNumber)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Slug)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Slug)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ViewCount)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ViewCount)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Content)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Content)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ServerId)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ServerId)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.CreatedAt)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.CreatedAt)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Price)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Price)
        </dd>
    </dl>
</div>

@if (Model.Images != null && Model.Images.Any())
{
    <div class="mt-4">
        <h4>Ảnh Chương</h4>
        <hr />
        <div class="row">
            @foreach (var image in Model.Images.OrderBy(i => i.OrderIndex))
            {
                <div class="col-md-12 mb-3">
                    <div class="card">
                        <img src="@image.ImageUrl" class="card-img-top" alt="@Model.Name - Page @image.OrderIndex" style="max-width: 100%; height: auto;" />
                        <div class="card-body text-center">
                            <p class="card-text">Trang @image.OrderIndex</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}
else
{
    <div class="mt-4">
        <p class="text-muted">Chương này chưa có ảnh nào.</p>
    </div>
}

<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>

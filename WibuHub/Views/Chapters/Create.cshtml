@* @model WibuHub.ApplicationCore.Entities.Chapter *@
@model WibuHub.MVC.ViewModels.ChapterVM


@{
    ViewData["Title"] = "Add New Chapter";
    bool isCreate = Model == null || Model.Id == Guid.Empty;
    string actionString = isCreate ? "Create" : "Edit";
    string buttonString = isCreate ? "Create" : "Update";
}

<div class="container mt-4">
    <h1>Add New Chapter</h1>
    <hr />


    <div class="row">
        <div class="col-md-4">
            <form asp-action="@actionString" enctype="multipart/form-data" data-unsaved-guard="true">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                @if (!isCreate)
                {
                    <input asp-for="Id" type="hidden" />
                }
                <div class="form-group mb-3">
                    <label asp-for="StoryId" class="control-label fw-bold">Story</label>
                    <select asp-for="StoryId" class="form-control" asp-items="ViewBag.StoryId">
                        <option value="">-- Please select a story --</option>
                    </select>
                    <span asp-validation-for="StoryId" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Name" class="control-label fw-bold">Chapter Name</label>
                    <input asp-for="Name" class="form-control" placeholder="Example: Chapter 1..." autofocus />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="ChapterNumber" class="control-label fw-bold">Chapter Number</label>
                    <input asp-for="ChapterNumber" class="form-control" type="number" step="0.5" placeholder="1, 1.5, 2..." />
                    <span asp-validation-for="ChapterNumber" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Slug" class="control-label fw-bold">Slug URL</label>
                    <input asp-for="Slug" class="form-control" placeholder="auto-generated-from-name" id="txtSlug" />
                    <small class="form-text text-muted">This is the path on the URL (no accents, hyphenated).</small>
                    <span asp-validation-for="Slug" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label class="control-label fw-bold">Image List (URL or upload from device)</label>
                    <div class="mb-2">
                        <input asp-for="UploadImages" class="form-control" type="file" multiple accept="image/*" />
                        <small class="text-muted">Uploaded images will be added to the list with URLs when saved.</small>
                    </div>
                    <div id="uploadPreviewList" class="d-flex flex-column gap-2"></div>
                    <div id="chapterImageList" class="d-flex flex-column gap-2">
                        @if (Model?.ImageUrls != null && Model.ImageUrls.Count > 0)
                        {
                            foreach (var imageUrl in Model.ImageUrls)
                            {
                                <div class="input-group chapter-image-item" draggable="true">
                                    <span class="input-group-text">↕</span>
                                    <input type="text" name="ImageUrls" class="form-control" value="@imageUrl" placeholder="https://..." />
                                    <button type="button" class="btn btn-outline-danger btn-remove-image">Delete</button>
                                </div>
                            }
                        }
                    </div>
                    <button type="button" class="btn btn-outline-secondary mt-2" id="btnAddImage">+ Add Image</button>
                </div>
                @* <div class="form-group mb-3">
                    <label asp-for="UploadImages" class="control-label fw-bold">Upload images from device</label>
                    <input asp-for="UploadImages" class="form-control" type="file" multiple accept="image/*" />
                    <small class="text-muted">Uploaded images will be added after the URL list.</small>
                </div> *@
                <div class="form-group mb-3">
                    <label asp-for="ServerId" class="control-label fw-bold">Server ID</label>
                    <input asp-for="ServerId" class="form-control" type="number" />
                    <span asp-validation-for="ServerId" class="text-danger"></span>
                </div>
                <div class="form-group" style="text-align: center; margin-top: 10px;">
                    <input type="submit" value="@buttonString" class="btn btn-primary" />
                </div>
            </form>
        </div>
        @if (isCreate)
        {
            <div id="divChapterList" class="col-md-8">
                @await Component.InvokeAsync("ChapterList", new { storyId = Model?.StoryId })
            </div>
        }
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        const uploadInput = document.getElementById("UploadImages");
        const uploadPreviewList = document.getElementById("uploadPreviewList");
        let uploadFiles = [];

        function getFileKey(file) {
            return `${file.name}-${file.size}-${file.lastModified}`;
        }

        function updateUploadInputFiles() {
            const dataTransfer = new DataTransfer();
            uploadFiles.forEach(item => dataTransfer.items.add(item.file));
            uploadInput.files = dataTransfer.files;
        }

        function buildUploadFilesFromInput(files) {
            const existingMap = new Map(uploadFiles.map(item => [item.key, item]));
            files.forEach(file => {
                const key = getFileKey(file);
                if (!existingMap.has(key)) {
                    existingMap.set(key, {
                        key,
                        file
                    });
                }
            });
            uploadFiles = Array.from(existingMap.values());
            updateUploadInputFiles();
        }

        function syncUploadFilesFromDom() {
            const orderKeys = Array.from(uploadPreviewList.querySelectorAll(".upload-preview-item"))
                .map(item => item.dataset.key);
            const fileMap = new Map(uploadFiles.map(item => [item.key, item]));
            uploadFiles = orderKeys.map(key => fileMap.get(key)).filter(Boolean);
            updateUploadInputFiles();
        }

        function bindUploadRowEvents(row) {
            row.addEventListener("dragstart", function () {
                row.classList.add("dragging");
            });
            row.addEventListener("dragend", function () {
                row.classList.remove("dragging");
                syncUploadFilesFromDom();
            });
            row.querySelector(".btn-remove-upload").addEventListener("click", function () {
                const key = row.dataset.key;
                uploadFiles = uploadFiles.filter(item => item.key !== key);
                row.remove();
                updateUploadInputFiles();
            });
        }

        function renderUploadPreview() {
            uploadPreviewList.innerHTML = "";
            uploadFiles.forEach(item => {
                const row = document.createElement("div");
                row.className = "input-group upload-preview-item";
                row.setAttribute("draggable", "true");
                row.dataset.key = item.key;
                row.innerHTML = `
                    <span class="input-group-text">↕</span>
                    <span class="input-group-text p-0" style="width: 64px; justify-content: center;">
                        <img alt="preview" style="max-width: 60px; max-height: 60px; object-fit: cover;" />
                    </span>
                    <input type="text" class="form-control" value="${item.file.name}" readonly />
                    <button type="button" class="btn btn-outline-danger btn-remove-upload">Delete</button>
                `;
                const img = row.querySelector("img");
                img.src = URL.createObjectURL(item.file);
                img.onload = function () {
                    URL.revokeObjectURL(img.src);
                };
                bindUploadRowEvents(row);
                uploadPreviewList.appendChild(row);
            });
        }

        uploadPreviewList.addEventListener("dragover", function (e) {
            e.preventDefault();
            const dragging = uploadPreviewList.querySelector(".dragging");
            if (!dragging) return;
            const rows = [...uploadPreviewList.querySelectorAll(".upload-preview-item:not(.dragging)")];
            const nextRow = rows.find(r => e.clientY <= r.getBoundingClientRect().top + r.offsetHeight / 2);
            if (nextRow) {
                uploadPreviewList.insertBefore(dragging, nextRow);
            } else {
                uploadPreviewList.appendChild(dragging);
            }
        });

        uploadInput.addEventListener("change", function () {
            buildUploadFilesFromInput(Array.from(uploadInput.files));
            renderUploadPreview();
        });
    </script>
    <script>
        const chapterImageList = document.getElementById("chapterImageList");
        function createImageRow(value = "") {
            const row = document.createElement("div");
            row.className = "input-group chapter-image-item";
            row.setAttribute("draggable", "true");
            row.innerHTML = `
                <span class="input-group-text">↕</span>
                <input type="text" name="ImageUrls" class="form-control" placeholder="https://..." />
                <button type="button" class="btn btn-outline-danger btn-remove-image">Delete</button>
            `;
            row.querySelector("input").value = value;
            bindImageRowEvents(row);
            chapterImageList.appendChild(row);
        }
        function bindImageRowEvents(row) {
            row.querySelector(".btn-remove-image").addEventListener("click", function () {
                row.remove();
                if (!chapterImageList.querySelector(".chapter-image-item")) {
                    createImageRow();
                }
            });
            row.addEventListener("dragstart", function () {
                row.classList.add("dragging");
            });
            row.addEventListener("dragend", function () {
                row.classList.remove("dragging");
            });
        }
        chapterImageList.addEventListener("dragover", function (e) {
            e.preventDefault();
            const dragging = chapterImageList.querySelector(".dragging");
            if (!dragging) return;
            const rows = [...chapterImageList.querySelectorAll(".chapter-image-item:not(.dragging)")];
            const nextRow = rows.find(r => e.clientY <= r.getBoundingClientRect().top + r.offsetHeight / 2);
            if (nextRow) {
                chapterImageList.insertBefore(dragging, nextRow);
            } else {
                chapterImageList.appendChild(dragging);
            }
        });
        [...chapterImageList.querySelectorAll(".chapter-image-item")].forEach(bindImageRowEvents);
        if (!chapterImageList.querySelector(".chapter-image-item")) {
            createImageRow();
        }
        document.getElementById("btnAddImage").addEventListener("click", function () {
            createImageRow();
        });
    </script>
    <script>
        // Automatically generate Slug when typing Chapter Name
        document.getElementById("Name").addEventListener("keyup", function () {
            let name = this.value;
            let slug = generateSlug(name);
            document.getElementById("txtSlug").value = slug;
        });
        function generateSlug(text) {
            return text.toString().toLowerCase()
                .replace(/á|à|ả|ạ|ã|ă|ắ|ằ|ẳ|ặ|ẵ|â|ấ|ầ|ẩ|ậ|ẫ/g, 'a')
                .replace(/é|è|ẻ|ẹ|ẽ|ê|ế|ề|ể|ệ|ễ/g, 'e')
                .replace(/i|í|ì|ỉ|ị|ĩ/g, 'i')
                .replace(/ó|ò|ỏ|ọ|õ|ô|ố|ồ|ổ|ộ|ỗ|ơ|ớ|ờ|ở|ợ|ỡ/g, 'o')
                .replace(/ú|ù|ủ|ụ|ũ|ư|ứ|ừ|ử|ự|ữ/g, 'u')
                .replace(/ý|ỳ|ỷ|ỵ|ỹ/g, 'y')
                .replace(/đ/g, 'd')
                .replace(/\s+/g, '-')
                .replace(/[^\w\-]+/g, '')
                .replace(/\-\-+/g, '-')
                .replace(/^-+/, '')
                .replace(/-+$/, '');
        }
    </script>
    <script>
        function openModalDeleteChapter(idChapter) {
            if (!confirm("Are you sure you want to delete this chapter?")) {
                return;
            }
            deleteChapter(idChapter);
        }
        function deleteChapter(idChapter) {
            let inputToken = document.querySelector("input[name='__RequestVerificationToken']");
            if (!inputToken) {
                console.error("Security token not found!");
                return;
            }
            $.ajax({
                url: '/Chapters/Delete',
                type: 'POST',
                data: {
                    id: idChapter,
                    __RequestVerificationToken: inputToken.value
                },
                success: function (response) {
                    if (response.isOK) {
                        refreshChapterList();
                    } else {
                        alert("Deletion failed!");
                    }
                },
                error: function () {
                    alert("An error occurred while connecting to the server.");
                }
            });
        }
        function refreshChapterList(page = 1) {
            const storyId = document.getElementById("StoryId").value;
            $.get('/Chapters/Reload', { page: page, storyId: storyId || null }, function (data) {
                $('#divChapterList').html(data);
            });
        }
    </script>
    <script>
        const storySelect = document.getElementById("StoryId");
        if (storySelect) {
            storySelect.addEventListener("change", function () {
                refreshChapterList();
            });
        }
    </script>
    }

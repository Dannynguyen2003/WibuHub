@* @model WibuHub.ApplicationCore.Entities.Chapter *@
@model WibuHub.MVC.ViewModels.ChapterVM


@{
    ViewData["Title"] = "Thêm mới Chương";
    bool isCreate = Model == null || Model.Id == Guid.Empty;
    string actionString = isCreate ? "Create" : "Edit";
    string buttonString = isCreate ? "Tạo mới" : "Cập nhật";
}

<div class="container mt-4">
    <h1>Thêm mới Chương</h1>
    <hr />


    <div class="row">
        <div class="col-md-4">
            <form asp-action="@actionString">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                @if (!isCreate)
                {
                    <input asp-for="Id" type="hidden" />
                }
                <div class="form-group mb-3">
                    <label asp-for="StoryId" class="control-label fw-bold">Truyện</label>
                    <select asp-for="StoryId" class="form-control" asp-items="ViewBag.StoryId">
                        <option value="">-- Vui lòng chọn truyện --</option>
                    </select>
                    <span asp-validation-for="StoryId" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Name" class="control-label fw-bold">Tên chương</label>
                    <input asp-for="Name" class="form-control" placeholder="Ví dụ: Chương 1..." autofocus />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="ChapterNumber" class="control-label fw-bold">Số chương</label>
                    <input asp-for="ChapterNumber" class="form-control" type="number" step="0.5" placeholder="1, 1.5, 2..." />
                    <span asp-validation-for="ChapterNumber" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Slug" class="control-label fw-bold">Đường dẫn (Slug)</label>
                    <input asp-for="Slug" class="form-control" placeholder="tu-dong-sinh-ra-tu-ten" id="txtSlug" />
                    <small class="form-text text-muted">Đây là đường dẫn trên URL (không dấu, gạch ngang).</small>
                    <span asp-validation-for="Slug" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label class="control-label fw-bold">Danh sách ảnh (nội dung chapter)</label>
                    <div id="chapterImageList" class="d-flex flex-column gap-2">
                        @if (Model?.ImageUrls != null && Model.ImageUrls.Count > 0)
                        {
                            foreach (var imageUrl in Model.ImageUrls)
                            {
                                <div class="input-group chapter-image-item" draggable="true">
                                    <span class="input-group-text">↕</span>
                                    <input type="text" name="ImageUrls" class="form-control" value="@imageUrl" placeholder="https://..." />
                                    <button type="button" class="btn btn-outline-secondary btn-move-up">↑</button>
                                    <button type="button" class="btn btn-outline-secondary btn-move-down">↓</button>
                                    <button type="button" class="btn btn-outline-danger btn-remove-image">Xóa</button>
                                </div>
                            }
                        }
                    </div>
                    <small class="text-muted">Kéo-thả hoặc bấm ↑ ↓ để đổi thứ tự ảnh.</small>
                    <button type="button" class="btn btn-outline-secondary mt-2" id="btnAddImage">+ Thêm ảnh</button>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="ServerId" class="control-label fw-bold">Server ID</label>
                    <input asp-for="ServerId" class="form-control" type="number" />
                    <span asp-validation-for="ServerId" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Price" class="control-label fw-bold">Giá</label>
                    <input asp-for="Price" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Discount" class="control-label fw-bold">Giảm giá</label>
                    <input asp-for="Discount" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="Discount" class="text-danger"></span>
                </div>
                <div class="form-group" style="text-align: center; margin-top: 10px;">
                    <input type="submit" value="@buttonString" class="btn btn-primary" />
                </div>
            </form>
        </div>
        <div id="divChapterList" class="col-md-8">
            @await Component.InvokeAsync("ChapterList")
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // Tự động tạo Slug khi gõ Tên chương
        document.getElementById("Name").addEventListener("keyup", function () {
            let name = this.value;
            let slug = generateSlug(name);
            document.getElementById("txtSlug").value = slug;
        });
        function generateSlug(text) {
            return text.toString().toLowerCase()
                .replace(/á|à|ả|ạ|ã|ă|ắ|ằ|ẳ|ặ|ẵ|â|ấ|ầ|ẩ|ậ|ẫ/g, 'a')
                .replace(/é|è|ẻ|ẹ|ẽ|ê|ế|ề|ể|ệ|ễ/g, 'e')
                .replace(/i|í|ì|ỉ|ị|ĩ/g, 'i')
                .replace(/ó|ò|ỏ|ọ|õ|ô|ố|ồ|ổ|ộ|ỗ|ơ|ớ|ờ|ở|ợ|ỡ/g, 'o')
                .replace(/ú|ù|ủ|ụ|ũ|ư|ứ|ừ|ử|ự|ữ/g, 'u')
                .replace(/ý|ỳ|ỷ|ỵ|ỹ/g, 'y')
                .replace(/đ/g, 'd')
                .replace(/\s+/g, '-')
                .replace(/[^\w\-]+/g, '')
                .replace(/\-\-+/g, '-')
                .replace(/^-+/, '')
                .replace(/-+$/, '');
        }
    </script>
    <script>
        const chapterImageList = document.getElementById("chapterImageList");
        function createImageRow(value = "") {
            const row = document.createElement("div");
            row.className = "input-group chapter-image-item";
            row.setAttribute("draggable", "true");
            row.innerHTML = `
                <span class="input-group-text">↕</span>
                <input type="text" name="ImageUrls" class="form-control" placeholder="https://..." />
                <button type="button" class="btn btn-outline-secondary btn-move-up">↑</button>
                <button type="button" class="btn btn-outline-secondary btn-move-down">↓</button>
                <button type="button" class="btn btn-outline-danger btn-remove-image">Xóa</button>
            `;
            row.querySelector("input").value = value;
            bindImageRowEvents(row);
            chapterImageList.appendChild(row);
        }
        function bindImageRowEvents(row) {
            row.querySelector(".btn-remove-image").addEventListener("click", function () {
                row.remove();
                if (!chapterImageList.querySelector(".chapter-image-item")) {
                    createImageRow();
                }
            });
            row.querySelector(".btn-move-up").addEventListener("click", function () {
                const prev = row.previousElementSibling;
                if (prev) {
                    chapterImageList.insertBefore(row, prev);
                }
            });
            row.querySelector(".btn-move-down").addEventListener("click", function () {
                const next = row.nextElementSibling;
                if (next) {
                    chapterImageList.insertBefore(next, row);
                }
            });
            row.addEventListener("dragstart", function () {
                row.classList.add("dragging");
            });
            row.addEventListener("dragend", function () {
                row.classList.remove("dragging");
            });
        }
        chapterImageList.addEventListener("dragover", function (e) {
            e.preventDefault();
            const dragging = chapterImageList.querySelector(".dragging");
            if (!dragging) return;
            const rows = [...chapterImageList.querySelectorAll(".chapter-image-item:not(.dragging)")];
            const nextRow = rows.find(r => e.clientY <= r.getBoundingClientRect().top + r.offsetHeight / 2);
            if (nextRow) {
                chapterImageList.insertBefore(dragging, nextRow);
            } else {
                chapterImageList.appendChild(dragging);
            }
        });
        [...chapterImageList.querySelectorAll(".chapter-image-item")].forEach(bindImageRowEvents);
        if (!chapterImageList.querySelector(".chapter-image-item")) {
            createImageRow();
        }
        document.getElementById("btnAddImage").addEventListener("click", function () {
            createImageRow();
        });
    </script>
    <script>
        function openModalDeleteChapter(idChapter) {
            let inputToken = document.querySelector("input[name='__RequestVerificationToken']");
            $.ajax({
                url: '/Chapters/Delete',
                type: 'GET',
                data: { id: idChapter },
                beforeSend: function () {
                    console.log("Sending...");
                },
                success: function (responseHTML) {
                    openModal("Xóa Chương", responseHTML, "modal-lg");
                },
                error: function (xhr, status, error) {
                    console.error("Error:", status, error);
                },
                complete: function () {
                    console.log("Request completed");
                },
                timeout: 10000
            });
        }
        function deleteChapter(idChapter) {
            let inputToken = document.querySelector("input[name='__RequestVerificationToken']");
            if (!inputToken) {
                console.error("Không tìm thấy Token bảo mật!");
                return;
            }
            $.ajax({
                url: '/Chapters/Delete',
                type: 'POST',
                data: {
                    id: idChapter,
                    __RequestVerificationToken: inputToken.value
                },
                success: function (response) {
                    if (response.isOK) {
                        closeModal();
                        refreshChapterList();
                    } else {
                        alert("Xóa thất bại!");
                    }
                },
                error: function () {
                    alert("Có lỗi xảy ra khi kết nối với máy chủ.");
                }
            });
        }
        function refreshChapterList() {
            $.get('/Chapters/Reload', function (data) {
                $('#divChapterList').html(data);
            });
        }
    </script>
    }

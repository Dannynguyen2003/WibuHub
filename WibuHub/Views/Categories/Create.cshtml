@* @model WibuHub.ApplicationCore.Entities.Category *@
@model WibuHub.MVC.ViewModels.CategoryVM

@{
    ViewData["Title"] = "Add New Category";
    bool isCreate = Model == null || Model.Id == Guid.Empty;
    string actionString = isCreate ? "Create" : "Edit";
    string buttonString = isCreate ? "Create" : "Update";
}

<div class="container mt-4">
    <h1>Add New Category</h1>
    <hr />

    <div class="row">
        <div class="col-md-6">
            <form asp-action="@actionString">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                @if (!isCreate)
                {
                    <input asp-for="Id" type="hidden" />
                    <input asp-for="Position" type="hidden" />
                }

                @* 1. Tên danh mục *@
                <div class="form-group mb-3">
                    <label asp-for="Name" class="control-label fw-bold">Category Name</label>
                    <input asp-for="Name" class="form-control" placeholder="e.g. Action, Romance..." autofocus />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                @* 2. Mô tả*@
                <div class="form-group mb-3">
                    <label asp-for="Description" class="control-label fw-bold">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="3" placeholder="Brief description of this category..."></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                @* 3. Slug (Đường dẫn) *@
                <div class="form-group mb-3">
                    <label asp-for="Slug" class="control-label fw-bold">URL Path (Slug)</label>
                    <input asp-for="Slug" class="form-control" placeholder="auto-generated-from-name" id="txtSlug" />
                    <small class="form-text text-muted">This is the URL path (no accents, hyphens).</small>
                    <span asp-validation-for="Slug" class="text-danger"></span>
                </div>

                @* 4. Vị trí sắp xếp (Position)
                <div class="form-group mb-3">
                    <label asp-for="Position" class="control-label fw-bold">Display Position</label>
                    <input asp-for="Position" class="form-control" type="number" min="0" value="0" />
                    <small class="form-text text-muted">Lower numbers display first.</small>
                    <span asp-validation-for="Position" class="text-danger"></span>
                </div> *@

                @* Buttons *@
                <div class="form-group" style="text-align: center; margin-top: 10px;">
                    <input type="submit" value="@buttonString" class="btn btn-primary" />
                </div>
            </form>
        </div>
        <div id="divCategoryList" class="col-md-8">
            @await Component.InvokeAsync("CategoryList")
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function deleteCategory(idCategory) {
            let inputToken = document.querySelector("input[name='__RequestVerificationToken']");
            if (!inputToken) {
                console.error("Security token not found!");
                return;
            }

            $.ajax({
                url: '/Categories/Delete',
                type: 'POST',
                data: {
                    id: idCategory,
                    __RequestVerificationToken: inputToken.value
                },
                success: function (response) {
                    if(response.isOK){
                        closeModal();
                        refreshCategoryList();
                    } else {
                        alert("Delete failed!");
                    }
                },
                error: function() {
                    alert("An error occurred while connecting to the server.");
                }
            });
        }

        // Đừng quên hàm này để cập nhật lại danh sách sau khi xóa thành công
        function refreshCategoryList(page = 1) {
            $.get('/Categories/Reload', { page: page }, function(data) {
                $('#divCategoryList').html(data);
            });
        }
    </script>
    <script>
        // Tự động tạo Slug khi gõ Tên danh mục
        document.getElementById("Name").addEventListener("keyup", function () {
            let name = this.value;
            let slug = generateSlug(name);
            document.getElementById("txtSlug").value = slug;
        });

        function generateSlug(text) {
            return text.toString().toLowerCase()
                .replace(/á|à|ả|ạ|ã|ă|ắ|ằ|ẳ|ặ|ẵ|â|ấ|ầ|ẩ|ậ|ẫ/g, 'a')
                .replace(/é|è|ẻ|ẹ|ẽ|ê|ế|ề|ể|ệ|ễ/g, 'e')
                .replace(/i|í|ì|ỉ|ị|ĩ/g, 'i')
                .replace(/ó|ò|ỏ|ọ|õ|ô|ố|ồ|ổ|ộ|ỗ|ơ|ớ|ờ|ở|ợ|ỡ/g, 'o')
                .replace(/ú|ù|ủ|ụ|ũ|ư|ứ|ừ|ử|ự|ữ/g, 'u')
                .replace(/ý|ỳ|ỷ|ỵ|ỹ/g, 'y')
                .replace(/đ/g, 'd')
                .replace(/\s+/g, '-')           // Thay khoảng trắng bằng -
                .replace(/[^\w\-]+/g, '')       // Loại bỏ ký tự đặc biệt
                .replace(/\-\-+/g, '-')         // Thay nhiều -- bằng 1 -
                .replace(/^-+/, '')              // Cắt - ở đầu
                .replace(/-+$/, '');             // Cắt - ở cuối
        }
    </script>

    <script>
        // openModal();
        function openModalDeleteCategory(idCategory){
            if (!confirm("Are you sure you want to delete this category?")) {
                return;
            }
            deleteCategory(idCategory);
        }

        function deleteCategory(idCategory){
            let inputToken = document.querySelector("input[name='__RequestVerificationToken']");
            $.ajax({
                url: '/Categories/Delete',
                type: 'POST',
                data: { id: idCategory, __RequestVerificationToken: inputToken.value },
                beforeSend: function () {
                    console.log("Sending...");
                },
                success: function (response) {
                    console.log("Success:", {response});
                    if(response.isOK){
                        //=== Load lại danh sách Category mới ===//
                        refreshCategoryList();
                    }

                },
                error: function (xhr, status, error) {
                    console.error("Error:", status, error);
                },
                complete: function () {
                    console.log("Request completed");
                },
                timeout: 10000  // Giới hạn thời gian (ms)
            });
        }

        function refreshCategoryList(page = 1){
            $.ajax({
                url: '/Categories/Reload',
                type: 'GET',
                data: { page: page },
                beforeSend: function () {
                    console.log("Sending...");
                },
                success: function (response) {
                    let divCategoryList = document.getElementById("divCategoryList");
                    if(divCategoryList){
                        divCategoryList.innerHTML = response;
                    }

                },
                error: function (xhr, status, error) {
                    console.error("Error:", status, error);
                },
                complete: function () {
                    console.log("Request completed");
                },
                timeout: 10000  // Giới hạn thời gian (ms)
            });
        }
    </script>
}

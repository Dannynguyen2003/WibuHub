@{
    ViewData["Title"] = "Category Management";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h1>Category Management</h1>
        <p>
            <a asp-action="Create" class="btn btn-success">
                <i class="fas fa-plus"></i> Create New
            </a>
        </p>
    </div>

    <form id="antiForgeryForm" method="post" class="d-none">
        @Html.AntiForgeryToken()
    </form>

    <div id="divCategoryList">
        @await Component.InvokeAsync("CategoryList")
    </div>
</div>

@section Scripts {
    <script>
        function openModalDeleteCategory(idCategory) {
            if (!confirm("Are you sure you want to delete this category?")) {
                return;
            }
            deleteCategory(idCategory);
        }
        function deleteCategory(idCategory) {
            let inputToken = document.querySelector("#antiForgeryForm input[name='__RequestVerificationToken']");
            if (!inputToken) {
                console.error("Security token not found!");
                return;
            }
            $.ajax({
                url: '/Categories/Delete',
                type: 'POST',
                data: {
                    id: idCategory,
                    __RequestVerificationToken: inputToken.value
                },
                success: function (response) {
                    if (response.isOK) {
                        refreshCategoryList();
                    }
                },
                error: function () {
                    alert("An error occurred while connecting to the server.");
                }
            });
        }
        function refreshCategoryList(page = 1) {
            $.ajax({
                url: '/Categories/Reload',
                type: 'GET',
                data: { page: page },
                success: function (response) {
                    let divCategoryList = document.getElementById("divCategoryList");
                    if (divCategoryList) {
                        divCategoryList.innerHTML = response;
                    }
                },
                error: function (xhr, status, error) {
                    console.error("Error:", status, error);
                }
            });
        }
    </script>
}

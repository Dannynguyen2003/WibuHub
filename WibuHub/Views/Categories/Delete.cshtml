@model WibuHub.ApplicationCore.Entities.Category

<div class="p-3">
    <div class="alert alert-warning">
        <i class="fas fa-exclamation-triangle"></i>
        <strong>Confirm:</strong> Are you sure you want to delete this category? This will hide the category from the system.
    </div>

    <div>
        <dl class="row">
            <dt class="col-sm-4">
                @Html.DisplayNameFor(model => model.Name)
            </dt>
            <dd class="col-sm-8 fw-bold">
                @Html.DisplayFor(model => model.Name)
            </dd>

            <dt class="col-sm-4">
                Slug (URL)
            </dt>
            <dd class="col-sm-8 text-danger">
                @Model.Slug
            </dd>

            <dt class="col-sm-4">
                @Html.DisplayNameFor(model => model.Description)
            </dt>
            <dd class="col-sm-8">
                @(string.IsNullOrEmpty(Model.Description) ? "No description" : Model.Description)
            </dd>

            <dt class="col-sm-4">
                @Html.DisplayNameFor(model => model.Position)
            </dt>
            <dd class="col-sm-8">
                <span class="badge bg-secondary">@Model.Position</span>
            </dd>
        </dl>

        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" onclick="closeModal()">Cancel</button>
            <form id="deleteForm">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                @* Call deleteCategory from AJAX script *@
                <button type="button" onclick="deleteCategory('@Model.Id')" class="btn btn-danger">
                    Confirm Delete
                </button>
            </form>
        </div>
    </div>
</div>
@model WibuHub.ApplicationCore.DTOs.Shared.PagedResult<WibuHub.MVC.ViewModels.StoryVM>
<table class="data-table">
<thead>
    <tr>
        <th style="width: 5%">Position</th>
        <th style="width: 8%">Cover</th>
        <th style="width: 14%">Title</th>
        <th style="width: 10%">Author</th>
        <th style="width: 10%">Categories</th>
        <th style="width: 10%">Status</th>
        <th style="width: 8%">Chapters</th>
        <th style="width: 7%">Views</th>
        <th style="width: 7%">Followers</th>
        <th style="width: 7%">Price</th>
        <th style="width: 7%">Discount</th>
        <th style="width: 8%">Created Date</th>
        <th style="width: 12%" class="text-center">Actions</th>
    </tr>
</thead>
    <tbody>
        @if (Model?.Items != null && Model.Items.Any())
        {
            var position = 1;
            @foreach (var item in Model.Items)
            {
                var coverUrl = string.IsNullOrWhiteSpace(item.CoverImage)
                ? "https://via.placeholder.com/60x80?text=No+Cover"
                : item.CoverImage;
                <tr>
                    <td>
                        <span class="badge-status">@((Model.PageIndex - 1) * Model.PageSize + position)</span>
                    </td>
                    <td>
                        <img class="story-cover-thumb" src="@coverUrl" alt="@item.Title" />
                    </td>
                    <td><strong>@item.Title</strong></td>
                    <td>@(item.Author?.Name ?? "N/A")</td>
                    <td>@(string.IsNullOrWhiteSpace(item.CategoryDisplay) ? "N/A" : item.CategoryDisplay)</td>
                    <td>
                        @switch (item.Status)
                        {
                            case 0:
                                <span class="badge-status pending">Ongoing</span>
                                break;
                            case 1:
                                <span class="badge-status">Completed</span>
                                break;
                            case 2:
                                <span class="badge-status pending">Paused</span>
                                break;
                            default:
                                <span class="badge-status">Unknown</span>
                                break;
                        }
                    </td>

                    <td><span class="badge-status" style="background-color: #e0f2fe; color: #2563eb;">@item.TotalChapters</span></td>

                    <td>@item.ViewCount</td>
                    <td>@item.FollowCount</td>
                    <td>@item.Price.ToString("N0")</td>
                    <td>@item.Discount.ToString("N0")</td>
                    <td>@item.CreatedAt.ToString("dd/MM/yyyy")</td>
                    <td class="action-cell">
                        <a asp-action="Edit" asp-route-id="@item.Id"
                           class="btn-primary btn-sm">Edit</a>
                        <a asp-action="Details" asp-route-id="@item.Id"
                           class="btn-secondary btn-sm">Details</a>
                        <button type="button" onclick="openModalDeleteStory('@item.Id')"
                                class="btn-danger btn-sm">
                            Delete
                        </button>
                    </td>
                </tr>
                position++;
            }
        }
        else
        {
            <tr>
                <td colspan="13" class="text-center">No stories created yet.</td>
            </tr>
        }
    </tbody>
</table>

@if (Model != null && Model.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                <a class="page-link" href="javascript:void(0)" onclick="refreshStoryList(1)">&laquo;&laquo;</a>
            </li>
            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                <a class="page-link" href="javascript:void(0)" onclick="refreshStoryList(@(Model.PageIndex - 1))">&laquo;</a>
            </li>
            @for (var i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                    <a class="page-link" href="javascript:void(0)" onclick="refreshStoryList(@i)">@i</a>
                </li>
            }
            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                <a class="page-link" href="javascript:void(0)" onclick="refreshStoryList(@(Model.PageIndex + 1))">&raquo;</a>
            </li>
            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                <a class="page-link" href="javascript:void(0)" onclick="refreshStoryList(@Model.TotalPages)">&raquo;&raquo;</a>
            </li>
        </ul>
    </nav>
}
@model WibuHub.ApplicationCore.DTOs.Shared.PagedResult<WibuHub.MVC.ViewModels.StoryVM>
<table class="data-table">
    <thead>
        <tr>
            <th style="width: 8%">Position</th>
            <th style="width: 15%">Tiêu đề</th>
            <th style="width: 10%">Tác giả</th>
            <th style="width: 10%">Danh mục</th>
            <th style="width: 12%">Trạng thái</th>
            <th style="width: 10%">Lượt xem</th>
            <th style="width: 10%">Theo dõi</th>
            <th style="width: 15%">Ngày tạo</th>
            <th style="width: 20%" class="text-center">Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @if (Model?.Items != null && Model.Items.Any())
        {
            var position = 1;
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>
                        <span class="badge-status">@((Model.PageIndex - 1) * Model.PageSize + position)</span>
                    </td>
                    <td><strong>@item.Title</strong></td>
                    <td>@(item.Author?.Name ?? "N/A")</td>
                    <td>@(item.CategoryName ?? "N/A")</td>
                    <td>
                        @switch (item.Status)
                        {
                            case 0:
                                <span class="badge-status pending">Đang tiến hành</span>
                                break;
                            case 1:
                                <span class="badge-status">Hoàn thành</span>
                                break;
                            case 2:
                                <span class="badge-status pending">Tạm ngưng</span>
                                break;
                            default:
                                <span class="badge-status">Không xác định</span>
                                break;
                        }
                    </td>
                    <td>@item.ViewCount</td>
                    <td>@item.FollowCount</td>
                    <td>@item.CreatedAt.ToString("dd/MM/yyyy")</td>
                    <td class="action-cell">
                        <a asp-action="Edit" asp-route-id="@item.Id"
                           class="btn-primary btn-sm">Sửa</a>
                        <a asp-action="Details" asp-route-id="@item.Id"
                           class="btn-secondary btn-sm">Chi tiết</a>
                        <button type="button" onclick="openModalDeleteStory('@item.Id')"
                                class="btn-danger btn-sm">
                            Xóa
                        </button>
                    </td>
                </tr>
                position++;
            }
        }
        else
        {
            <tr>
                <td colspan="9" class="text-center">Chưa có truyện nào được tạo.</td>
            </tr>
        }
    </tbody>
</table>
@if (Model != null && Model.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-end">
            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                <a class="page-link" href="javascript:void(0)" onclick="refreshStoryList(@(Model.PageIndex - 1))">&laquo;</a>
            </li>
            @for (var i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                    <a class="page-link" href="javascript:void(0)" onclick="refreshStoryList(@i)">@i</a>
                </li>
            }
            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                <a class="page-link" href="javascript:void(0)" onclick="refreshStoryList(@(Model.PageIndex + 1))">&raquo;</a>
            </li>
        </ul>
    </nav>
}

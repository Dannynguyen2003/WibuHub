@model WibuHub.ApplicationCore.DTOs.Shared.PagedResult<WibuHub.MVC.ViewModels.CategoryVM>

<table class="data-table">
    <thead>
        <tr>
            <th style="width: 10%">Position</th>
            <th style="width: 20%">Name</th>
            <th style="width: 20%">Slug URL</th>
            <th style="width: 30%">Description</th>
            <th style="width: 20%" class="text-center">Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model?.Items != null && Model.Items.Any())
        {
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>
                        <span class="badge-status">@item.Position</span>
                    </td>
                    <td><strong>@item.Name</strong></td>
                    <td>
                        <span class="text-danger fw-bold">@item.Slug</span>
                    </td>
                    <td>
                        <small class="text-muted">@(item.Description ?? "No description")</small>
                    </td>
                    <td class="action-cell">
                        <a asp-action="Edit" asp-route-id="@item.Id"
                           class="btn-primary btn-sm">Edit</a>

                        <a asp-action="Details" asp-route-id="@item.Id"
                           class="btn-secondary btn-sm">Details</a>

                        @* Button Delete calling JS confirm modal *@
                        <button type="button" onclick="openModalDeleteCategory('@item.Id')"
                                class="btn-danger btn-sm">
                            Delete
                        </button>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5" class="text-center">No categories created yet.</td>
            </tr>
        }
    </tbody>
</table>
@if (Model != null && Model.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                <a class="page-link" href="javascript:void(0)" onclick="refreshCategoryList(@(Model.PageIndex - 1))">&laquo;</a>
            </li>
            @for (var i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                    <a class="page-link" href="javascript:void(0)" onclick="refreshCategoryList(@i)">@i</a>
                </li>
            }
            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                <a class="page-link" href="javascript:void(0)" onclick="refreshCategoryList(@(Model.PageIndex + 1))">&raquo;</a>
            </li>
        </ul>
    </nav>
}

@model WibuHub.ApplicationCore.DTOs.Shared.PagedResult<WibuHub.MVC.ViewModels.AuthorVM>
<table class="data-table">
    <thead>
        <tr>
            <th style="width: 10%">Position</th>
            <th style="width: 35%">Tên tác giả</th>
            <th style="width: 35%">Slug</th>
            <th style="width: 20%" class="text-center">Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @if (Model?.Items != null && Model.Items.Any())
        {
            var position = 1;
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>
                        <span class="badge-status">@((Model.PageIndex - 1) * Model.PageSize + position)</span>
                    </td>
                    <td><strong>@item.Name</strong></td>
                    <td>@item.Slug</td>
                    <td class="action-cell">
                        <a asp-action="Edit" asp-route-id="@item.Id"
                           class="btn-primary btn-sm">Sửa</a>
                        <a asp-action="Details" asp-route-id="@item.Id"
                           class="btn-secondary btn-sm">Chi tiết</a>
                        <button type="button" onclick="openModalDeleteAuthor('@item.Id')"
                                class="btn-danger btn-sm">
                            Xóa
                        </button>
                    </td>
                </tr>
                position++;
            }
        }
        else
        {
            <tr>
                <td colspan="4" class="text-center">Chưa có tác giả nào được tạo.</td>
            </tr>
        }
    </tbody>
</table>
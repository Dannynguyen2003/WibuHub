@model WibuHub.ApplicationCore.DTOs.Shared.PagedResult<WibuHub.MVC.ViewModels.AuthorVM>
<table class="data-table">
    <thead>
        <tr>
            <th style="width: 10%">Position</th>
            <th style="width: 35%">Author Name</th>
            <th style="width: 35%">Slug</th>
            <th style="width: 20%" class="text-center">Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model?.Items != null && Model.Items.Any())
        {
            var position = 1;
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>
                        <span class="badge-status">@((Model.PageIndex - 1) * Model.PageSize + position)</span>
                    </td>
                    <td><strong>@item.Name</strong></td>
                    <td>@item.Slug</td>
                    <td class="action-cell">
                        <a asp-action="Edit" asp-route-id="@item.Id"
                           class="btn-primary btn-sm">Edit</a>
                        <button type="button" onclick="openModalDeleteAuthor('@item.Id')"
                                class="btn-danger btn-sm">
                            Delete
                        </button>
                    </td>
                </tr>
                position++;
            }
        }
        else
        {
            <tr>
                <td colspan="4" class="text-center">No authors have been created yet.</td>
            </tr>
        }
    </tbody>
</table>
@if (Model != null && Model.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                <a class="page-link" href="javascript:void(0)" onclick="refreshAuthorList(@(Model.PageIndex - 1))">&laquo;</a>
            </li>
            @for (var i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                    <a class="page-link" href="javascript:void(0)" onclick="refreshAuthorList(@i)">@i</a>
                </li>
            }
            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                <a class="page-link" href="javascript:void(0)" onclick="refreshAuthorList(@(Model.PageIndex + 1))">&raquo;</a>
            </li>
        </ul>
    </nav>
}

@model WibuHub.ApplicationCore.DTOs.Shared.PagedResult<WibuHub.MVC.ViewModels.ChapterVM>
<table class="data-table">
    <thead>
        <tr>
            <th style="width: 8%">Position</th>
            <th style="width: 8%">Số chương</th>
            <th style="width: 15%">Tên chương</th>
            <th style="width: 15%">Truyện</th>
            <th style="width: 8%">Số ảnh</th>
            <th style="width: 12%">Slug</th>
            <th style="width: 8%">Lượt xem</th>
            <th style="width: 8%">Giá</th>
            <th style="width: 12%">Ngày tạo</th>
            <th style="width: 12%" class="text-center">Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Items != null && Model.Items.Any())
        {
            var position = 1;
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>
                        <span class="badge-status">@position</span>
                    </td>
                    <td>
                        <span class="badge-status">@item.ChapterNumber</span>
                    </td>
                    <td><strong>@item.Name</strong></td>
                    <td>@item.StoryName</td>
                    <td>@item.ImageCount</td>
                    <td>
                        <span class="text-danger fw-bold">@item.Slug</span>
                    </td>
                    <td>@item.ViewCount</td>
                    <td>@item.Price.ToString("#,##0") ₫</td>
                    <td>@item.CreatedAt.ToString("dd/MM/yyyy")</td>
                    <td class="action-cell">
                        <a asp-action="Edit" asp-route-id="@item.Id"
                           class="btn-primary btn-sm">Sửa</a>
                        <a asp-action="Details" asp-route-id="@item.Id"
                           class="btn-secondary btn-sm">Chi tiết</a>
                        <button type="button" onclick="openModalDeleteChapter('@item.Id')"
                                class="btn-danger btn-sm">
                            Xóa
                        </button>
                    </td>
                </tr>
                position++;
            }
        }
        else
        {
            <tr>
                <td colspan="10" class="text-center">Chưa có chương nào được tạo.</td>
            </tr>
        }
    </tbody>
</table>
@if (Model != null && Model.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-end">
            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                <a class="page-link" href="javascript:void(0)" onclick="refreshChapterList(@(Model.PageIndex - 1))">&laquo;</a>
            </li>
            @for (var i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                    <a class="page-link" href="javascript:void(0)" onclick="refreshChapterList(@i)">@i</a>
                </li>
            }
            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                <a class="page-link" href="javascript:void(0)" onclick="refreshChapterList(@(Model.PageIndex + 1))">&raquo;</a>
            </li>
        </ul>
    </nav>
}

@{
    Layout = null;
    var isIdentityArea = string.Equals(ViewContext.RouteData.Values["area"]?.ToString(), "Identity", StringComparison.OrdinalIgnoreCase);
}
@using Microsoft.AspNetCore.Identity
@using WibuHub.ApplicationCore.Entities.Identity
@inject SignInManager<StoryUser> SignInManager
@inject UserManager<StoryUser> UserManager
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WibuHub Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    @* <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" /> *@
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    @* <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" /> *@
    @* @if (Context.Request.Path.StartsWithSegments("/Identity")) *@
    @if (isIdentityArea)
    {
        <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    }
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
</head>
    <body>
        @if (isIdentityArea)
        {
            <div class="container py-4">
                <main role="main">
                    @RenderBody()
                </main>
            </div>
        }
        else
        {

    <!-- DASHBOARD WRAPPER (ẩn ban đầu) -->
    <div id="dashboard-wrapper" style="display: flex;">
        <div class="dashboard-container">
            <!-- SIDEBAR -->
            <div class="sidebar">
                <div class="sidebar-header">
                    <i class="fas fa-book-open"></i>
                    <div>
                        <h2>ReadStory</h2>
                        <span>Admin Panel</span>
                    </div>
                </div>
                <div class="sidebar-menu">
                    <ul>
                        <li class="active" data-page="dashboard"><i class="fas fa-chart-pie"></i> <span>Dashboard</span></li>
                        <li data-page="stories"><i class="fas fa-book"></i> <span>Quản lý Truyện</span></li>
                        <li data-page="categories"><i class="fas fa-list"></i> <span>Thể loại</span></li>
                        <li data-page="authors"><i class="fas fa-feather"></i> <span>Tác giả</span></li>
                        <li data-page="users"><i class="fas fa-users"></i> <span>Người dùng</span></li>
                        <li data-page="comments"><i class="fas fa-comments"></i> <span>Bình luận</span></li>
                        <li data-page="statistics"><i class="fas fa-chart-line"></i> <span>Thống kê</span></li>
                        <li data-page="settings"><i class="fas fa-cog"></i> <span>Cài đặt</span></li>
                        <li data-page="profile"><i class="fas fa-id-card"></i> <span>Hồ sơ</span></li>
                    </ul>
                </div>
                <div class="sidebar-footer" id="logout-btn">
                    <i class="fas fa-sign-out-alt"></i>
                    <span>Đăng xuất</span>
                </div>
            </div>

            <!-- MAIN CONTENT -->
            <div class="main-content">
                <!-- HEADER -->
                <div class="header">
                    <div class="header-left">
                        <h3><i class="fas fa-crown" style="color: #fbbf24;"></i> Xin chào, Admin</h3>
                        <div class="search-box">
                            <i class="fas fa-search"></i>
                            <input type="text" placeholder="Tìm kiếm truyện, người dùng...">
                        </div>
                    </div>
                    <div class="header-right">
                        <div class="icon" onclick="alert('Thông báo')">
                            <i class="far fa-bell"></i>
                            <span class="badge">4</span>
                        </div>
                        <div class="icon" onclick="alert('Tin nhắn')">
                            <i class="far fa-envelope"></i>
                            <span class="badge">2</span>
                        </div>
                        <div class="admin-profile" onclick="navigateTo('profile')">
                            <img src="https://randomuser.me/api/portraits/men/32.jpg" alt="Admin">
                            <div class="admin-info">
                                <div class="name">Nguyễn Văn A</div>
                                <div class="role">Quản trị viên</div>
                            </div>
                        </div>
                    </div>
                </div>

    <div class="container-fluid">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2024 - WibuHub Admin - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
            </div>
        </div>
    </div>
        }
        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
        @if (!isIdentityArea)
        {
            <script src="~/js/app.js" asp-append-version="true"></script>
        }
        @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

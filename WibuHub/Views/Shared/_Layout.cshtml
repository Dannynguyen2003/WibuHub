    @using Microsoft.AspNetCore.Identity
@using WibuHub.ApplicationCore.Entities.Identity
@inject SignInManager<StoryUser> SignInManager
@inject UserManager<StoryUser> UserManager
@{
    var isIdentityArea = string.Equals(ViewContext.RouteData.Values["area"]?.ToString(), "Identity", StringComparison.OrdinalIgnoreCase);
    var avatarUrl = "https://randomuser.me/api/portraits/men/32.jpg";

    if (SignInManager.IsSignedIn(User))
    {
        var currentUser = await UserManager.GetUserAsync(User);
        if (!string.IsNullOrWhiteSpace(currentUser?.Avatar))
        {
            avatarUrl = currentUser.Avatar;
        }
    }
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WIBUHUB Admin</title>

    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

    @if (!SignInManager.IsSignedIn(User))
    {
        <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    }
    else
    {
        <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    }
</head>
<body>

    @if (SignInManager.IsSignedIn(User))
    {
        <div id="dashboard-wrapper" style="display: block;">
            <div class="dashboard-container">

                <div class="sidebar">
                    <div class="sidebar-header">
                        <button class="sidebar-toggle" type="button" aria-label="Toggle sidebar">
                            <i class="fas fa-book-open"></i>
                        </button>
                        <div>
                            <h2>WIBUHUB</h2><span>Admin Panel</span>
                        </div>
                    </div>
                    <div class="sidebar-menu">
                        <ul>
                            <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")">
                                <a asp-controller="Home" asp-action="Index" style="text-decoration:none; color:inherit; display:flex; gap:14px; width:100%">
                                    <i class="fas fa-chart-pie"></i> <span>Dashboard</span>
                                </a>
                            </li>
                            @if (User.IsInRole("SuperAdmin"))
                            {
                                <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "RoleManagement" ? "active" : "")">
                                    <a asp-controller="RoleManagement" asp-action="Index" style="text-decoration:none; color:inherit; display:flex; gap:14px; width:100%">
                                        <i class="fas fa-user-shield"></i> <span>Role Management</span>
                                    </a>
                                </li>
                            }
                            <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "AdminProfile" ? "active" : "")">
                                <a asp-controller="AdminProfile" asp-action="Index" style="text-decoration:none; color:inherit; display:flex; gap:14px; width:100%">
                                    <i class="fas fa-user-circle"></i> <span>Admin Profile</span>
                                </a>
                            </li>
                            <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Categories" ? "active" : "")">
                                <a asp-controller="Categories" asp-action="Create" style="text-decoration:none; color:inherit; display:flex; gap:14px; width:100%">
                                    <i class="fas fa-tags"></i> <span>Categories Management</span>
                                </a>
                            </li>
                            <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Authors" ? "active" : "")">
                                <a asp-controller="Authors" asp-action="Create" style="text-decoration:none; color:inherit; display:flex; gap:14px; width:100%">
                                    <i class="fas fa-user-pen"></i> <span>Authors Management</span>
                                </a>
                            </li>
                            <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Stories" ? "active" : "")">
                                <a asp-controller="Stories" asp-action="Create" style="text-decoration:none; color:inherit; display:flex; gap:14px; width:100%">
                                    <i class="fas fa-book-open"></i> <span>Stories Management</span>
                                </a>
                            </li>
                            <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Chapters" ? "active" : "")">
                                <a asp-controller="Chapters" asp-action="Create" style="text-decoration:none; color:inherit; display:flex; gap:14px; width:100%">
                                    <i class="fas fa-list-ol"></i> <span>Chapters Management</span>
                                </a>
                            </li>
                            <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Orders" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                                <a asp-controller="Orders" asp-action="Index" style="text-decoration:none; color:inherit; display:flex; gap:14px; width:100%">
                                    <i class="fas fa-receipt"></i> <span>Orders Management</span>
                                </a>
                            </li>
                            <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Orders" && ViewContext.RouteData.Values["Action"]?.ToString() == "History" ? "active" : "")">
                                <a asp-controller="Orders" asp-action="History" style="text-decoration:none; color:inherit; display:flex; gap:14px; width:100%">
                                    <i class="fas fa-clock-rotate-left"></i> <span>Transaction History</span>
                                </a>
                            </li>

                        </ul>
                    </div>
                    <div class="sidebar-footer">
                        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post" style="width: 100%;">
                            <button type="submit" style="background:none; border:none; color:inherit; cursor:pointer; display:flex; gap:12px; align-items:center;">
                                <i class="fas fa-sign-out-alt"></i> <span>Đăng xuất</span>
                            </button>
                        </form>
                    </div>
                </div>

                <div class="main-content">
                    <div class="header">
                        <div class="header-left">
                            <h3><i class="fas fa-crown" style="color: #fbbf24;"></i> Xin chào, Admin</h3>
                        </div>
                        <div class="header-right">
                            <a asp-controller="AdminProfile" asp-action="Index" style="text-decoration: none; color: inherit;">
                                <div class="admin-profile">
                                    <img src="@avatarUrl" alt="Admin">
                                    <div class="admin-info">
                                        <div class="name">@User.Identity?.Name</div>
                                        <div class="role">Quản trị viên</div>
                                    </div>
                                </div>
                            </a>
                        </div>
                    </div>

                    <div class="pages-container">
                        @RenderBody()
                    </div>

                </div>
            </div>
        </div>
    }
    else
    {
        @RenderBody()
    }

    <script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/unsaved-guard.js" asp-append-version="true"></script>
    <script>
        const sidebar = document.querySelector('.sidebar');
        const toggleButton = document.querySelector('.sidebar-toggle');
        const storageKey = 'wibuhub.sidebar.collapsed';

        if (sidebar && toggleButton) {
            const isCollapsed = localStorage.getItem(storageKey) === 'true';
            if (isCollapsed) {
                sidebar.classList.add('collapsed');
            }

            toggleButton.addEventListener('click', () => {
                sidebar.classList.toggle('collapsed');
                localStorage.setItem(storageKey, sidebar.classList.contains('collapsed'));
            });
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
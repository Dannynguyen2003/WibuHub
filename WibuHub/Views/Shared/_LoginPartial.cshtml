@using Microsoft.AspNetCore.Identity
@using WibuHub.ApplicationCore.Entities.Identity

@inject SignInManager<StoryUser> SignInManager
@inject UserManager<StoryUser> UserManager

<div class="header-right">
    @if (SignInManager.IsSignedIn(User))
    {
        <div class="icon" onclick="alert('Notifications')">
            <i class="far fa-bell"></i>
            <span class="badge">4</span>
        </div>
        <div class="icon" onclick="alert('Messages')">
            <i class="far fa-envelope"></i>
            <span class="badge">2</span>
        </div>

        <a asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage Profile" style="text-decoration: none; color: inherit;">
            <div class="admin-profile">
                <img src="https://randomuser.me/api/portraits/men/32.jpg" alt="Avatar">
                <div class="admin-info">
                    <div class="name">@UserManager.GetUserName(User)</div>
                    <div class="role">Admin</div>
                </div>
            </div>
        </a>
    }
    else
    {
        <a id="login" asp-area="Identity" asp-page="/Account/Login" class="btn-primary" style="text-decoration: none; margin-bottom: 0; padding: 8px 20px;">
            <i class="fas fa-sign-in-alt"></i> Login
        </a>
        <a id="register" asp-area="Identity" asp-page="/Account/Register" class="btn-outline" style="text-decoration: none; margin-left: 10px; padding: 8px 20px;">
            Register
        </a>
    }
</div>
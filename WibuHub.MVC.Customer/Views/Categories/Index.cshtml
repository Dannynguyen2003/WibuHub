@using System.Globalization
@model WibuHub.MVC.Customer.ViewModels.CategoryStoriesViewModel

@{
    ViewData["Title"] = $"Th? lo?i - {Model.CategoryName}";
}

<div class="category-page">
    <div class="category-page-header">
        <h2>@Model.CategoryName</h2>
        <span>@Model.Stories.Count stories</span>
    </div>

    @if (Model.Stories.Count == 0)
    {
        <div class="category-empty">No stories in this category yet.</div>
    }
    else
    {
        <div class="category-grid">
            @foreach (var story in Model.Stories)
            {
                var coverImage = string.IsNullOrWhiteSpace(story.CoverImage)
                    ? string.Empty
                    : (story.CoverImage.StartsWith("http", StringComparison.OrdinalIgnoreCase)
                        ? story.CoverImage
                        : Url.Content($"~/{story.CoverImage.TrimStart('/') }"));
                var createdAt = story.CreatedAt.ToLocalTime();
                var timeSpan = DateTime.Now - createdAt;
                var timeLabel = timeSpan.TotalHours < 24
                    ? $"{Math.Max(1, (int)Math.Round(timeSpan.TotalHours))} Hours Ago"
                    : $"{Math.Max(1, (int)Math.Round(timeSpan.TotalDays))} Days Ago";
                var latestChapter = story.Chapters?
                    .OrderByDescending(c => c.ChapterNumber)
                    .FirstOrDefault();
                var chapterLabel = latestChapter != null ? $"Chapter {latestChapter.ChapterNumber}" : "No chapters yet";
                var storySlug = string.IsNullOrWhiteSpace(story.Slug) ? story.StoryName : story.Slug;
                var storyUrl = Url.Action("Details", "Stories", new { id = story.Id }) ?? "#";
                var isHot = story.ViewCount >= 10000;
                <div class="category-card">
                    <a class="category-cover" href="@storyUrl" style="@(string.IsNullOrWhiteSpace(coverImage) ? string.Empty : $"background-image:url('{coverImage}')")">
                        <div class="category-badges">
                            <span class="category-badge">@timeLabel</span>
                            @if (isHot)
                            {
                                <span class="category-badge hot">Hot</span>
                            }
                        </div>
                    </a>
                    <div class="category-info">
                        <a class="category-title" href="@storyUrl">@story.StoryName</a>
                        <div class="category-chapter">@chapterLabel</div>
                    </div>
                </div>
            }
        </div>
    }
</div>

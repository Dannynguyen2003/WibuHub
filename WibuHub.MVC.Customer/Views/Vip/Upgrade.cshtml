@{
    ViewData["Title"] = "Upgrade VIP Privileges";
}

@section Styles {
    <link rel="stylesheet" href="~/css/vip.css" asp-append-version="true" />
}

<div class="vip-container">
    <div class="vip-header">
        <h1>Unlimited Experience</h1>
        <p>Remove ads, read new chapters early, and get exclusive badges.</p>
    </div>

    <div class="pricing-grid">
        <div class="pricing-card">
            <div class="plan-name">VIP 1 Month</div>
            <div class="plan-price">99,000 <span>VND</span></div>
            <p style="color: #6b7280; font-size: 0.9rem;">Equivalent to 30 days</p>
            <ul class="plan-features">
                <li><i class="fas fa-check-circle"></i> No Ads</li>
                <li><i class="fas fa-check-circle"></i> Read chapters early</li>
                <li style="color: #9ca3af;"><i class="fas fa-times-circle" style="color: #9ca3af;"></i> VIP comment badge</li>
            </ul>
            <button class="btn-buy standard" onclick="addVipToCart('VIP_MONTH')">Add to cart</button>
        </div>

        <div class="pricing-card popular">
            <div class="popular-badge">MOST POPULAR</div>
            <div class="plan-name" style="color: #d97706;">VIP 3 Months</div>
            <div class="plan-price">249,000 <span>VND</span></div>
            <p style="color: #6b7280; font-size: 0.9rem;">Save more with 90 days plan</p>
            <ul class="plan-features">
                <li><i class="fas fa-check-circle"></i> No Ads</li>
                <li><i class="fas fa-check-circle"></i> Read chapters early</li>
                <li><i class="fas fa-check-circle"></i> Gold avatar border & VIP badge</li>
            </ul>
            <button class="btn-buy premium" onclick="addVipToCart('VIP_QUARTER')">Add to cart</button>
        </div>

        <div class="pricing-card">
            <div class="plan-name">VIP 12 Months</div>
            <div class="plan-price">799,000 <span>VND</span></div>
            <p style="color: #6b7280; font-size: 0.9rem;">Best value plan for story fans</p>
            <ul class="plan-features">
                <li><i class="fas fa-check-circle"></i> All Standard Privileges</li>
                <li><i class="fas fa-check-circle"></i> Read Extra Chapters</li>
                <li><i class="fas fa-check-circle"></i> Red name on rankings</li>
            </ul>
            <button class="btn-buy standard" onclick="addVipToCart('VIP_YEAR')">Add to cart</button>
        </div>
    </div>
</div>

<form id="addVipForm" action="/ShoppingCart/AddVipPackage" method="post" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" id="vipCodeInput" name="code" value="" />
</form>

@section Scripts {
    <script>
        function addVipToCart(code) {
            // Assign VIP package code to hidden input
            document.getElementById('vipCodeInput').value = code;
            // Submit form
            document.getElementById('addVipForm').submit();
        }
    </script>
}
@{
    ViewData["Title"] = "Nâng cấp đặc quyền VIP";
}

@section Styles {
    <link rel="stylesheet" href="~/css/vip.css" asp-append-version="true" />
}

<div class="vip-container">
    <div class="vip-header">
        <h1>Trải Nghiệm Không Giới Hạn</h1>
        <p>Loại bỏ quảng cáo, đọc trước chương mới và sở hữu huy hiệu độc quyền.</p>
    </div>

    <div class="pricing-grid">
        <div class="pricing-card">
            <div class="plan-name">VIP 1 Tháng</div>
            <div class="plan-price">99,000 <span>VNĐ</span></div>
            <p style="color: #6b7280; font-size: 0.9rem;">Tương đương 30 ngày</p>
            <ul class="plan-features">
                <li><i class="fas fa-check-circle"></i> Không quảng cáo</li>
                <li><i class="fas fa-check-circle"></i> Đọc trước chương mới</li>
                <li style="color: #9ca3af;"><i class="fas fa-times-circle" style="color: #9ca3af;"></i> Huy hiệu bình luận VIP</li>
            </ul>
            <button class="btn-buy standard" onclick="addVipToCart('VIP_MONTH')">Thêm vào giỏ</button>
        </div>

        <div class="pricing-card popular">
            <div class="popular-badge">ĐƯỢC ƯU CHUỘNG NHẤT</div>
            <div class="plan-name" style="color: #d97706;">VIP 3 Tháng</div>
            <div class="plan-price">249,000 <span>VNĐ</span></div>
            <p style="color: #6b7280; font-size: 0.9rem;">Tiết kiệm hơn khi đăng ký 90 ngày</p>
            <ul class="plan-features">
                <li><i class="fas fa-check-circle"></i> Không quảng cáo</li>
                <li><i class="fas fa-check-circle"></i> Đọc trước chương mới</li>
                <li><i class="fas fa-check-circle"></i> Avatar viền vàng & Huy hiệu VIP</li>
            </ul>
            <button class="btn-buy premium" onclick="addVipToCart('VIP_QUARTER')">Thêm vào giỏ</button>
        </div>

        <div class="pricing-card">
            <div class="plan-name">VIP 12 Tháng</div>
            <div class="plan-price">799,000 <span>VNĐ</span></div>
            <p style="color: #6b7280; font-size: 0.9rem;">Gói tiết kiệm nhất cho fan truyện</p>
            <ul class="plan-features">
                <li><i class="fas fa-check-circle"></i> Tất cả đặc quyền Tiêu chuẩn</li>
                <li><i class="fas fa-check-circle"></i> Đọc chương Extra Ngoại truyện</li>
                <li><i class="fas fa-check-circle"></i> Tên màu đỏ trên BXH</li>
            </ul>
            <button class="btn-buy standard" onclick="addVipToCart('VIP_YEAR')">Thêm vào giỏ</button>
        </div>
    </div>
</div>

<form id="addVipForm" action="/ShoppingCart/AddVipPackage" method="post" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" id="vipCodeInput" name="code" value="" />
</form>

@section Scripts {
    <script>
        function addVipToCart(code) {
            // Gán mã code của gói VIP vào input ẩn
            document.getElementById('vipCodeInput').value = code;
            // Submit form
            document.getElementById('addVipForm').submit();
        }
    </script>
}
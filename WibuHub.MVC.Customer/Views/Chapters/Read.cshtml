@using System.Globalization
@model WibuHub.MVC.Customer.ViewModels.ChapterReadViewModel

@{
    var chapter = Model.Chapter;
    var storyName = chapter.Story?.StoryName ?? chapter.StoryName;
    var storySlug = string.IsNullOrWhiteSpace(chapter.Story?.Slug)
        ? chapter.StoryName
        : chapter.Story!.Slug;
    var chapterTitle = $"{storyName} - Chapter {chapter.ChapterNumber}";
    var updatedAt = chapter.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss");
    var orderedChapters = Model.Chapters.OrderByDescending(c => c.ChapterNumber).ToList();
    var activeServer = string.Equals(Model.ActiveServer, "vip", StringComparison.OrdinalIgnoreCase) ? "vip" : "normal";

    string BuildChapterUrl(WibuHub.ApplicationCore.Entities.Chapter item)
    {
        return Url.RouteUrl("ChapterReadSeo", new
        {
            storySlug,
            chapterNumber = item.ChapterNumber.ToString(CultureInfo.InvariantCulture),
            sv = activeServer
        }) ?? "#";
    }

    string ResolveImageUrl(string rawUrl)
    {
        if (rawUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase))
        {
            return rawUrl;
        }

        var relativePath = rawUrl.TrimStart('/');
        var baseUrl = activeServer == "vip" ? Model.VipServerBaseUrl : Model.NormalServerBaseUrl;

        if (!string.IsNullOrWhiteSpace(baseUrl))
        {
            return $"{baseUrl.TrimEnd('/')}/{relativePath}";
        }

        return Url.Content($"~/{relativePath}");
    }
    var previousChapter = Model.PreviousChapterId.HasValue
        ? Model.Chapters.FirstOrDefault(c => c.Id == Model.PreviousChapterId.Value)
        : null;
    var nextChapter = Model.NextChapterId.HasValue
        ? Model.Chapters.FirstOrDefault(c => c.Id == Model.NextChapterId.Value)
        : null;
}

<div style="padding: 15px 20px 20px 20px; max-width: 1200px; margin: 0 auto;">
    <ul style="display: flex; flex-wrap: wrap; list-style: none; padding: 0; margin: 0; font-size: 0.95rem; color: #6b7280; align-items: center; gap: 8px;">
        <li>
            <a href="/" style="color: #3b82f6; text-decoration: none; display: flex; align-items: center; gap: 4px;">
                <i class="fas fa-home"></i> Home
            </a>
        </li>
        <li><span style="margin: 0 2px;">/</span></li>
        <li>
            <a href="/Stories/Details/@chapter.StoryId" style="color: #3b82f6; text-decoration: none;">
                @storyName
            </a>
        </li>
        <li><span style="margin: 0 2px;">/</span></li>
        <li>
            <span style="color: #1f2937; font-weight: 500;">Chapter @chapter.ChapterNumber</span>
        </li>
    </ul>
</div>

<div class="chapter-read-page">
    <div class="chapter-read-header">
        <h2>@chapterTitle</h2>
        <div class="chapter-updated">[Updated at: @updatedAt]</div>
    </div>

    <div class="chapter-warning">
        <i class="fas fa-exclamation-triangle"></i>
        If you cannot view the story, please change the "IMAGE SERVER" below
    </div>

    <div class="chapter-toolbar">
        <div class="chapter-servers">
            <a class="chapter-server @(activeServer == "normal" ? "active" : "")" href="@Url.RouteUrl("ChapterReadSeo", new { storySlug, chapterNumber = chapter.ChapterNumber.ToString(CultureInfo.InvariantCulture), sv = 1 })">Normal Server</a>
            @if (Model.IsVipUser)
            {
                <a class="chapter-server @(activeServer == "vip" ? "active" : "")" href="@Url.RouteUrl("ChapterReadSeo", new { storySlug, chapterNumber = chapter.ChapterNumber.ToString(CultureInfo.InvariantCulture), sv = 2 })">VIP Server</a>
            }
        </div>
        <button class="chapter-report" type="button"><i class="fas fa-flag"></i> Report</button>
    </div>

    <div class="chapter-nav">
        <a class="chapter-nav-btn @(previousChapter == null ? "disabled" : "")" href="@(previousChapter == null ? "#" : BuildChapterUrl(previousChapter))">
            <i class="fas fa-chevron-left"></i>
        </a>
        <select class="chapter-select" onchange="if (this.value) window.location.href = this.value;">
            @foreach (var item in orderedChapters)
            {
                var url = BuildChapterUrl(item);
                <option value="@url" selected="@(item.Id == chapter.Id)">Chapter @item.ChapterNumber</option>
            }
        </select>
        <a class="chapter-nav-btn @(nextChapter == null ? "disabled" : "")" href="@(nextChapter == null ? "#" : BuildChapterUrl(nextChapter))">
            <i class="fas fa-chevron-right"></i>
        </a>
        <div class="chapter-nav-hint">Use left (←) or right (→) arrow keys to navigate chapters</div>
    </div>

    <div class="chapter-content">
        @if (chapter.Images != null && chapter.Images.Any())
        {
            foreach (var image in chapter.Images.OrderBy(i => i.OrderIndex))
            {
                var imageUrl = ResolveImageUrl(image.ImageUrl);
                <img src="@imageUrl" alt="@chapterTitle" />
            }
        }
        else if (!string.IsNullOrWhiteSpace(chapter.Content))
        {
            <div class="chapter-text">@Html.Raw(chapter.Content)</div>
        }
        else
        {
            <div class="chapter-placeholder">Page 1 - Story content will be displayed here</div>
        }
    </div>
    <div class="chapter-bottom-bar">
        <div class="chapter-bottom-bar-inner">
            <a class="chapter-bar-btn" asp-controller="Home" asp-action="Index"><i class="fas fa-home"></i></a>
            <a class="chapter-bar-btn" asp-controller="Stories" asp-action="Details" asp-route-id="@chapter.StoryId"><i class="fas fa-undo"></i></a>
            <a class="chapter-bar-btn @(previousChapter == null ? "disabled" : "")" href="@(previousChapter == null ? "#" : BuildChapterUrl(previousChapter))">
                <i class="fas fa-chevron-left"></i>
            </a>
            <select class="chapter-bar-select" onchange="if (this.value) window.location.href = this.value;">
                @foreach (var item in orderedChapters)
                {
                    var url = BuildChapterUrl(item);
                    <option value="@url" selected="@(item.Id == chapter.Id)">Chapter @item.ChapterNumber</option>
                }
            </select>
            <a class="chapter-bar-btn @(nextChapter == null ? "disabled" : "")" href="@(nextChapter == null ? "#" : BuildChapterUrl(nextChapter))">
                <i class="fas fa-chevron-right"></i>
            </a>
            @if (User?.Identity?.IsAuthenticated ?? false)
            {
                <form class="chapter-bar-follow-form" asp-controller="Follows" asp-action="Toggle" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="storyId" value="@chapter.StoryId" />
                    <input type="hidden" name="returnUrl" value="@($"{Context.Request.Path}{Context.Request.QueryString}")" />
                    <button class="chapter-bar-follow" type="submit">
                        <i class="@(Model.IsFollowed ? "fas fa-heart" : "far fa-heart")"></i>
                        @(Model.IsFollowed ? "Following" : "Follow")
                    </button>
                </form>
            }
            else
            {
                <button class="chapter-bar-follow" type="button" data-open-login="true">
                    <i class="far fa-heart"></i>
                    Follow
                </button>
            }
        </div>
    </div>
</div>
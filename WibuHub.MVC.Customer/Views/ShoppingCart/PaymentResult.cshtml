@{
    ViewData["Title"] = "Kết quả thanh toán";
}
<link rel="stylesheet" href="~/css/PaymentResult.css" asp-append-version="true" />

<div class="result-wrapper">
    <div class="result-container">
        <div class="icon-wrapper">
            <div class="fake-3d-icon">
                <i class="fas fa-check"></i>
            </div>
        </div>

        <h1 class="result-title text-primary-blue">Thanh toán thành công!</h1>

        <div class="vip-badge">
            <i class="fas fa-crown"></i> VIP CỦA BẠN ĐÃ ĐƯỢC KÍCH HOẠT!
        </div>

        <div class="result-message">
            <p>Hệ thống đã xác nhận thanh toán.</p>
            <p>Quá trình nâng cấp đang được hoàn tất...</p>
            <p>Cảm ơn bạn vì đã ủng hộ WibuHub.</p>
            <p>Hãy tận hưởng các đặc quyền mới nhé!</p>
            <p class="transaction-id">
                <i class="fas fa-link"></i> Mã giao dịch: [Gốc MOMO...]
            </p>
        </div>

        <a href="/" class="btn-action btn-block">Về trang chủ</a>
    </div>
</div>
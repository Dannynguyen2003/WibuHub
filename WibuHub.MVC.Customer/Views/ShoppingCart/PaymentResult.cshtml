@{
    ViewData["Title"] = "Kết quả thanh toán";
}
<link rel="stylesheet" href="~/css/PaymentResult.css" asp-append-version="true" />

<div class="container mt-5 mb-5" style="max-width: 800px;">
    <div class="card shadow-sm">
        <div class="card-header bg-white">
            <h2 class="mb-0">Kết quả thanh toán</h2>
        </div>
        <div class="card-body text-center p-5">
            @if (Context.Request.Query["resultCode"] == "0")
            {
                <i class="fas fa-check-circle text-success" style="font-size: 4rem; margin-bottom: 20px;"></i>
                <h3 class="text-success">Thanh toán thành công!</h3>
                <p class="text-muted" style="font-size: 1.1rem;">@ViewBag.Message</p>
                <p>Cảm ơn bạn đã nâng cấp VIP. Hãy tận hưởng các đặc quyền mới nhé!</p>
            }
            else
            {
                <i class="fas fa-times-circle text-danger" style="font-size: 4rem; margin-bottom: 20px;"></i>
                <h3 class="text-danger">Giao dịch thất bại</h3>
                <p class="text-muted">@ViewBag.Message</p>
            }

            <div class="mt-4">
                <a href="/" class="btn btn-primary px-4 py-2" style="border-radius: 20px;">Về trang chủ</a>
            </div>
        </div>
    </div>
</div>
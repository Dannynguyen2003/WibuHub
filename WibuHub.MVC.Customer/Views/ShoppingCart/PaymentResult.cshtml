@{
    ViewData["Title"] = "Payment Result";
}
<link rel="stylesheet" href="~/css/PaymentResult.css" asp-append-version="true" />

<div class="result-wrapper">
    <div class="result-container">
        <div class="icon-wrapper">
            <div class="fake-3d-icon">
                <i class="fas fa-check"></i>
            </div>
        </div>

        <h1 class="result-title text-primary-blue">Payment Successful!</h1>

        <div class="vip-badge">
            <i class="fas fa-crown"></i> YOUR VIP HAS BEEN ACTIVATED!
        </div>

        <div class="result-message">
            <p>The system has confirmed your payment.</p>
            <p>The upgrade process is being completed...</p>
            <p>Thank you for supporting WibuHub.</p>
            <p>Enjoy your new privileges!</p>
            <p class="transaction-id">
                <i class="fas fa-link"></i> Transaction ID: [From MOMO...]
            </p>
        </div>

        <a href="/" class="btn-action btn-block">Back to Home</a>
    </div>
</div>
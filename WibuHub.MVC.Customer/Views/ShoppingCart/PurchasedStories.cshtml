@model IReadOnlyList<WibuHub.MVC.Customer.ViewModels.ShoppingCart.PurchasedStoryItemViewModel>
@{
    ViewData["Title"] = "Purchased Stories";
    var currentPage = ViewBag.CurrentPage is int cp ? cp : 1;
    var totalPages = ViewBag.TotalPages is int tp ? tp : 1;
    var totalItems = ViewBag.TotalItems is int ti ? ti : (Model?.Count ?? 0);
}

@if (TempData["DownloadError"] != null)
{
    <div style="max-width: 1100px; margin: 0 auto 16px; padding: 10px 14px; border-radius: 8px; background: #fef2f2; color: #991b1b; border: 1px solid #fecaca;">
        @TempData["DownloadError"]
    </div>
}

<div style="max-width: 1100px; margin: 24px auto; padding: 0 16px;">
    <div style="display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;margin-bottom:16px;">
        <h1 style="margin:0;font-size:1.8rem;color:#0f172a;">Purchased Stories</h1>
        <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
            <span style="color:#64748b;font-size:0.95rem;">Total: @totalItems story(s)</span>
            <a asp-controller="ShoppingCart" asp-action="Orders" style="text-decoration:none;background:#2563eb;color:#fff;padding:8px 14px;border-radius:8px;">View Orders</a>
        </div>
    </div>

    @if (Model == null || Model.Count == 0)
    {
        <div style="background:#fff;border:1px solid #e5e7eb;border-radius:12px;padding:20px;color:#64748b;">
            You have not purchased any stories yet.
        </div>
    }
    else
    {
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:14px;">
            @foreach (var item in Model)
            {
                <div style="background:#fff;border:1px solid #e5e7eb;border-radius:12px;overflow:hidden;display:flex;flex-direction:column;">
                    <a asp-controller="Stories" asp-action="Details" asp-route-id="@item.StoryId" style="display:block;background:#f8fafc;aspect-ratio:16/10;overflow:hidden;">
                        @if (!string.IsNullOrWhiteSpace(item.CoverImage))
                        {
                            <img src="@item.CoverImage" alt="@item.StoryTitle" style="width:100%;height:100%;object-fit:cover;display:block;" />
                        }
                        else
                        {
                            <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:#94a3b8;">No image</div>
                        }
                    </a>
                    <div style="padding:12px;display:grid;gap:8px;">
                        <a asp-controller="Stories" asp-action="Details" asp-route-id="@item.StoryId" style="text-decoration:none;color:#0f172a;font-weight:700;line-height:1.4;">@item.StoryTitle</a>
                        <div style="font-size:0.9rem;color:#64748b;">Last purchased: @item.LastPurchasedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                        <div style="display:flex;justify-content:space-between;gap:8px;font-size:0.92rem;">
                            <span style="color:#64748b;">Quantity:</span>
                            <strong style="color:#0f172a;">@item.TotalPurchasedQuantity</strong>
                        </div>
                        <div style="display:flex;justify-content:space-between;gap:8px;font-size:0.92rem;">
                            <span style="color:#64748b;">Spent:</span>
                            <strong style="color:#0f172a;">@item.TotalSpent.ToString("N0") ţ</strong>
                        </div>
                        <a asp-controller="ShoppingCart"
                           asp-action="DownloadStory"
                           asp-route-storyId="@item.StoryId"
                           style="text-decoration:none;background:#16a34a;color:#fff;padding:8px 12px;border-radius:8px;text-align:center;">
                            Download
                        </a>
                    </div>
                </div>
            }
        </div>

        @if (totalPages > 1)
        {
            <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;justify-content:center;margin-top:18px;">
                @if (currentPage > 1)
                {
                    <a asp-action="PurchasedStories"
                       asp-route-page="1"
                       aria-label="First page"
                       style="text-decoration:none;padding:7px 12px;border-radius:8px;border:1px solid #d1d5db;background:#fff;color:#1f2937;">
                        <i class="fas fa-angles-left"></i>
                    </a>
                }
                else
                {
                    <span style="padding:7px 12px;border-radius:8px;border:1px solid #e5e7eb;background:#f8fafc;color:#94a3b8;cursor:not-allowed;">
                        <i class="fas fa-angles-left"></i>
                    </span>
                }

                @if (currentPage > 1)
                {
                    <a asp-action="PurchasedStories"
                       asp-route-page="@(currentPage - 1)"
                       aria-label="Previous page"
                       style="text-decoration:none;padding:7px 12px;border-radius:8px;border:1px solid #d1d5db;background:#fff;color:#1f2937;">
                        <i class="fas fa-chevron-left"></i>
                    </a>
                }
                else
                {
                    <span style="padding:7px 12px;border-radius:8px;border:1px solid #e5e7eb;background:#f8fafc;color:#94a3b8;cursor:not-allowed;">
                        <i class="fas fa-chevron-left"></i>
                    </span>
                }

                @for (int p = 1; p <= totalPages; p++)
                {
                    <a asp-action="PurchasedStories"
                       asp-route-page="@p"
                       style="text-decoration:none;padding:7px 12px;border-radius:8px;border:1px solid #d1d5db;@(p == currentPage ? "background:#2563eb;color:#fff;border-color:#2563eb;" : "background:#fff;color:#1f2937;")">
                        @p
                    </a>
                }

                @if (currentPage < totalPages)
                {
                    <a asp-action="PurchasedStories"
                       asp-route-page="@(currentPage + 1)"
                       aria-label="Next page"
                       style="text-decoration:none;padding:7px 12px;border-radius:8px;border:1px solid #d1d5db;background:#fff;color:#1f2937;">
                        <i class="fas fa-chevron-right"></i>
                    </a>
                }
                else
                {
                    <span style="padding:7px 12px;border-radius:8px;border:1px solid #e5e7eb;background:#f8fafc;color:#94a3b8;cursor:not-allowed;">
                        <i class="fas fa-chevron-right"></i>
                    </span>
                }

                @if (currentPage < totalPages)
                {
                    <a asp-action="PurchasedStories"
                       asp-route-page="@totalPages"
                       aria-label="Last page"
                       style="text-decoration:none;padding:7px 12px;border-radius:8px;border:1px solid #d1d5db;background:#fff;color:#1f2937;">
                        <i class="fas fa-angles-right"></i>
                    </a>
                }
                else
                {
                    <span style="padding:7px 12px;border-radius:8px;border:1px solid #e5e7eb;background:#f8fafc;color:#94a3b8;cursor:not-allowed;">
                        <i class="fas fa-angles-right"></i>
                    </span>
                }
            </div>
        }
    }
</div>

@model IReadOnlyList<WibuHub.ApplicationCore.Entities.Order>
@{
    ViewData["Title"] = "My Orders";
    var currentPage = ViewBag.CurrentPage is int cp ? cp : 1;
    var totalPages = ViewBag.TotalPages is int tp ? tp : 1;
    var totalOrders = ViewBag.TotalOrders is int to ? to : (Model?.Count ?? 0);
}

<div style="max-width: 1100px; margin: 24px auto; padding: 0 16px;">
    <div style="display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;margin-bottom:16px;">
        <h1 style="margin:0;font-size:1.8rem;color:#0f172a;">My Purchased Orders</h1>
        <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
            <span style="color:#64748b;font-size:0.95rem;">Total: @totalOrders order(s)</span>
            <a asp-controller="ShoppingCart" asp-action="PurchasedStories" style="text-decoration:none;background:#0ea5e9;color:#fff;padding:8px 14px;border-radius:8px;">Purchased Stories</a>
            <a asp-controller="ShoppingCart" asp-action="Index" style="text-decoration:none;background:#2563eb;color:#fff;padding:8px 14px;border-radius:8px;">Back to Shop</a>
        </div>
    </div>

    @if (Model == null || Model.Count == 0)
    {
        <div style="background:#fff;border:1px solid #e5e7eb;border-radius:12px;padding:20px;color:#64748b;">
            You have no orders yet.
        </div>
    }
    else
    {
        foreach (var order in Model)
        {
            var status = order.PaymentStatus ?? "Unknown";
            var statusColor = status.Equals("Completed", StringComparison.OrdinalIgnoreCase) ? "#16a34a"
                : status.Equals("Pending", StringComparison.OrdinalIgnoreCase) ? "#f59e0b"
                : status.Equals("Cancelled", StringComparison.OrdinalIgnoreCase) ? "#ef4444"
                : "#64748b";

            <div style="background:#fff;border:1px solid #e5e7eb;border-radius:12px;padding:16px;margin-bottom:14px;">
                <div style="display:flex;justify-content:space-between;gap:10px;flex-wrap:wrap;margin-bottom:10px;">
                    <div>
                        <div style="font-size:0.9rem;color:#64748b;">Order ID</div>
                        <div style="font-weight:600;color:#0f172a;word-break:break-all;">@order.Id</div>
                    </div>
                    <div>
                        <div style="font-size:0.9rem;color:#64748b;">Created At</div>
                        <div style="font-weight:600;color:#0f172a;">@order.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                    </div>
                    <div>
                        <div style="font-size:0.9rem;color:#64748b;">Status</div>
                        <div style="font-weight:700;color:@statusColor;">@status</div>
                    </div>
                    <div>
                        <div style="font-size:0.9rem;color:#64748b;">Total</div>
                        <div style="font-weight:700;color:#0f172a;">@order.TotalAmount.ToString("N0") ţ</div>
                    </div>
                </div>

                @if (order.OrderDetails != null && order.OrderDetails.Any())
                {
                    <div style="border-top:1px dashed #e5e7eb;padding-top:10px;display:grid;gap:8px;">
                        @foreach (var detail in order.OrderDetails)
                        {
                            <div style="display:flex;justify-content:space-between;gap:10px;flex-wrap:wrap;">
                                <div style="color:#1f2937;font-weight:500;">
                                    @if (detail.StoryId.HasValue && detail.StoryId.Value != Guid.Empty)
                                    {
                                        <a asp-controller="Stories" asp-action="Details" asp-route-id="@detail.StoryId" style="text-decoration:none;color:#2563eb;">@(detail.ItemName ?? "Story")</a>
                                        @if (status.Equals("Completed", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <a asp-controller="ShoppingCart"
                                               asp-action="DownloadStory"
                                               asp-route-storyId="@detail.StoryId"
                                               style="margin-left:10px;text-decoration:none;background:#16a34a;color:#fff;padding:4px 10px;border-radius:6px;font-size:0.82rem;display:inline-block;">
                                                Download
                                            </a>
                                        }
                                    }
                                    else
                                    {
                                        @(detail.ItemName ?? "Item")
                                    }
                                </div>
                                <div style="color:#64748b;">Qty: @detail.Quantity</div>
                                <div style="font-weight:600;color:#0f172a;">@detail.Amount.ToString("N0") ţ</div>
                            </div>
                        }
                    </div>
                }
            </div>
        }

        @if (totalPages > 1)
        {
            <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;justify-content:center;margin-top:18px;">
                @for (int p = 1; p <= totalPages; p++)
                {
                    <a asp-action="Orders"
                       asp-route-page="@p"
                       style="text-decoration:none;padding:7px 12px;border-radius:8px;border:1px solid #d1d5db;@(p == currentPage ? "background:#2563eb;color:#fff;border-color:#2563eb;" : "background:#fff;color:#1f2937;")">
                        @p
                    </a>
                }
            </div>
        }
    }
</div>

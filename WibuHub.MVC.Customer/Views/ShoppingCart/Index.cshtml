@model WibuHub.MVC.Customer.Models.ShoppingCart.Cart

@{
    ViewData["Title"] = "Giỏ hàng";
}

<h1>Giỏ hàng</h1>

<div class="mb-3">
    <form asp-action="AddToCart" method="post" class="d-inline">
        @Html.AntiForgeryToken()
        <input type="hidden" name="storyId" value="11111111-1111-1111-1111-111111111111" />
        <input type="hidden" name="storyTitle" value="One Piece" />
        <button type="submit" class="btn btn-sm btn-primary">Thêm One Piece</button>
    </form>
    <form asp-action="AddToCart" method="post" class="d-inline">
        @Html.AntiForgeryToken()
        <input type="hidden" name="storyId" value="22222222-2222-2222-2222-222222222222" />
        <input type="hidden" name="storyTitle" value="Naruto" />
        <button type="submit" class="btn btn-sm btn-primary">Thêm Naruto</button>
    </form>
</div>

@if (!Model.Items.Any())
{
    <p>Giỏ hàng đang trống.</p>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Tên truyện</th>
                <th>Số lượng</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.StoryTitle</td>
                <td>@item.Quantity</td>
                <td>
                    <form asp-action="Remove" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="storyId" value="@item.StoryId" />
                        <button type="submit" class="btn btn-sm btn-danger">Xóa</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
}

<a asp-controller="Cart" asp-action="Index" class="btn btn-outline-primary">Tiếp tục mua</a>

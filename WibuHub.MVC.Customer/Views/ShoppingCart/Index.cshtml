@model WibuHub.MVC.Customer.ViewModels.ShoppingCart.ShoppingCartViewModel
@{
    ViewData["Title"] = "Cart";
    var total = Model.Cart.Items.Sum(i => i.Total);
    var currentPage = ViewBag.CurrentPage is int cp ? cp : 1;
    var totalPages = ViewBag.TotalPages is int tp ? tp : 1;
    var totalStories = ViewBag.TotalStories is int ts ? ts : (Model.Stories?.Count ?? 0);
}

<div class="cart-page">
    <div class="cart-header">
        <h1>Shopping Cart</h1>
        <a class="cart-checkout-link" asp-action="Cart">View Cart</a>
    </div>

    <div class="cart-grid">
        <section class="cart-section">
            <h2>Select story to buy</h2>
            <div style="margin-bottom:10px;color:#64748b;font-size:0.95rem;">Total stories: @totalStories</div>
            <div class="cart-list">
                @if (Model.Stories.Count == 0)
                {
                    <p class="cart-empty">No stories available.</p>
                }
                else
                {
                    foreach (var story in Model.Stories)
                    {
                        <div class="cart-card">
                            <div class="cart-card-info">
                                <div class="cart-card-title">@story.StoryTitle</div>
                            </div>
                            <div class="cart-card-actions">
                                <span class="cart-price">@story.Price.ToString("N0") ₫</span>
                                <form asp-action="AddStory" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="idStory" value="@story.Id" />
                                    <input type="hidden" name="quantity" value="1" />
                                    <button type="submit" class="cart-btn">Add to cart</button>
                                </form>
                            </div>
                        </div>
                    }
                }
            </div>

            @if (totalPages > 1)
            {
                <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;justify-content:center;margin-top:14px;">
                    @for (int p = 1; p <= totalPages; p++)
                    {
                        <a asp-action="Index"
                           asp-route-page="@p"
                           style="text-decoration:none;padding:7px 12px;border-radius:8px;border:1px solid #d1d5db;@(p == currentPage ? "background:#2563eb;color:#fff;border-color:#2563eb;" : "background:#fff;color:#1f2937;")">
                            @p
                        </a>
                    }
                </div>
            }
        </section>

        <section class="cart-section">
            <h2>VIP Package</h2>
            <div class="cart-list">
                @foreach (var package in Model.VipPackages)
                {
                    <div class="cart-card">
                        <div class="cart-card-info">
                            <div class="cart-card-title">@package.Name</div>
                            <div class="cart-card-sub">@package.Description</div>
                        </div>
                        <div class="cart-card-actions">
                            <span class="cart-price">@package.Price.ToString("N0") ₫</span>
                            <form asp-action="AddVipPackage" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="code" value="@package.Code" />
                                <button type="submit" class="cart-btn">Subscribe</button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        </section>

    </div>
</div>

@using System.Globalization
@using WibuHub.ApplicationCore.Entities
@using WibuHub.MVC.Customer.ViewModels
@model WibuHub.ApplicationCore.Entities.Story

@{
    ViewData["Title"] = Model.StoryName;
    var coverUrl = string.IsNullOrWhiteSpace(Model.CoverImage)
        ? "https://ui-avatars.com/api/?name=Anonymous&background=E2E8F0&color=475569"
        : (Model.CoverImage.StartsWith("http", StringComparison.OrdinalIgnoreCase)
            ? Model.CoverImage
            : Url.Content($"~/{Model.CoverImage.TrimStart('/')}"));

    var storySlug = string.IsNullOrWhiteSpace(Model.Slug)
        ? Model.StoryName
        : Model.Slug;

    var statusText = Model.Status switch
    {
        1 => "Completed",
        2 => "Paused",
        _ => "Ongoing"
    };

    var authorName = !string.IsNullOrWhiteSpace(Model.AuthorName)
        ? Model.AuthorName
        : Model.Author?.Name ?? "Updating";

    var createdDate = Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy");

    var orderedChapters = (Model.Chapters ?? Array.Empty<Chapter>())
        .OrderBy(c => c.ChapterNumber)
        .ToList();

    var firstChapter = orderedChapters.FirstOrDefault();
    var latestChapter = orderedChapters.LastOrDefault();

    var continueChapterNumber = ViewData["ContinueChapterNumber"] is double number
        ? number
        : (double?)null;

    var firstChapterUrl = firstChapter == null
        ? "#"
        : Url.RouteUrl("ChapterReadSeo", new
        {
            storySlug,
            chapterNumber = firstChapter.ChapterNumber.ToString(CultureInfo.InvariantCulture)
        }) ?? "#";

    var latestChapterUrl = latestChapter == null
        ? "#"
        : Url.RouteUrl("ChapterReadSeo", new
        {
            storySlug,
            chapterNumber = latestChapter.ChapterNumber.ToString(CultureInfo.InvariantCulture)
        }) ?? "#";

    var continueChapterUrl = continueChapterNumber.HasValue
        ? Url.RouteUrl("ChapterReadSeo", new
        {
            storySlug,
            chapterNumber = continueChapterNumber.Value.ToString(CultureInfo.InvariantCulture)
        }) ?? "#"
        : "#";

    // Fixed: Remove old fallback Model.Category check and use StoryCategories directly
    var storyCategories = Model.StoryCategories?
        .Where(sc => sc.Category != null)
        .Select(sc => sc.Category!)
        .ToList() ?? new List<Category>();

    var categoryDisplay = storyCategories.Any()
        ? string.Join(", ", storyCategories.Select(c => c.Name))
        : "Updating";

    var ratingValue = Math.Clamp((int)Math.Round(Model.RatingScore), 0, 5);
    var isFollowed = (ViewData["IsFollowed"] as bool?) ?? false;
    var myRating = (ViewData["MyRating"] as int?) ?? 0;
    var ratingCount = (ViewData["RatingCount"] as int?) ?? 0;
    var storyComments = ViewData["StoryComments"] as List<StoryCommentItemViewModel> ?? new List<StoryCommentItemViewModel>();
}

<div style="padding: 15px 20px 20px 20px; max-width: 1200px; margin: 0 auto;">
    <ul style="display: flex; flex-wrap: wrap; list-style: none; padding: 0; margin: 0; font-size: 0.95rem; color: #6b7280; align-items: center; gap: 8px;">
        <li>
            <a href="/" style="color: #3b82f6; text-decoration: none;">
                Trang chủ
            </a>
        </li>
        <li><span style="margin: 0 2px;">/</span></li>
        <li>
            @if (storyCategories.Any())
            {
                var firstCat = storyCategories.First();
                <a href="/Categories?id=@firstCat.Id" style="color: #3b82f6; text-decoration: none;">
                    @firstCat.Name
                </a>
            }
            else
            {
                <span>Category</span>
            }
        </li>
        <li><span style="margin: 0 2px;">/</span></li>
        <li>
            <span style="color: #1f2937; font-weight: 500;">@Model.StoryName</span>
        </li>
    </ul>
</div>

<div class="story-detail-shell">
    <div class="story-detail-header">
        <div class="story-detail-cover">
            <img src="@coverUrl" alt="@Model.StoryName" />
        </div>
        <div class="story-detail-content">
            <h1 class="story-detail-title">@Model.StoryName</h1>
            <div class="story-detail-stats">
                <div class="story-detail-stat">
                    <span class="stat-label">Author</span>
                    <span class="stat-value">@authorName</span>
                </div>
                <div class="story-detail-stat">
                    <span class="stat-label">Status</span>
                    <span class="stat-value">@statusText</span>
                </div>
                <div class="story-detail-stat">
                    <span class="stat-label">Category</span>
                    <span class="stat-value">
                        @if (storyCategories.Any())
                        {
                            @for (int i = 0; i < storyCategories.Count; i++)
                            {
                                <a href="/Categories?id=@storyCategories[i].Id"
                                   style="color: #3b82f6; text-decoration: none; font-weight: 500;">
                                    @storyCategories[i].Name
                                </a>
                                @(i < storyCategories.Count - 1 ? ", " : "")
                            }
                        }
                        else
                        {
                            @("Updating")
                        }
                    </span>
                </div>
                <div class="story-detail-stat">
                    <span class="stat-label">Views</span>
                    <span class="stat-value">@Model.ViewCount</span>
                </div>
            </div>
            <div class="story-detail-rating">
                <div class="rating-stars">
                    @for (var i = 1; i <= 5; i++)
                    {
                        <i class="@(i <= ratingValue ? "fas fa-star" : "far fa-star")"></i>
                    }
                </div>
                <span class="rating-text">@Model.RatingScore.ToString("0.0")/5</span>
                <span class="rating-divider">-</span>
                <span class="rating-meta">@ratingCount reviews</span>
            </div>
            @if (TempData["RatingMessage"] != null)
            {
                <div style="margin-top: 8px; color: #2563eb; font-size: 0.9rem;">@TempData["RatingMessage"]</div>
            }

            <div style="margin-top: 12px;">
                @if (User?.Identity?.IsAuthenticated ?? false)
                {
                    <form asp-action="Rate" method="post" id="storyRatingForm" style="display: flex; align-items: center; gap: 10px; flex-wrap: wrap;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="storyId" value="@Model.Id" />
                        <input type="hidden" name="returnUrl" value="@ViewContext.HttpContext.Request.Path" />
                        <input type="hidden" name="score" id="ratingScoreInput" value="@myRating" />

                        <div id="ratingStarsInput" style="display: inline-flex; gap: 6px;">
                            @for (var i = 1; i <= 5; i++)
                            {
                                <button type="button" class="rating-star-btn" data-score="@i" style="border: none; background: transparent; font-size: 22px; color: #f59e0b; cursor: pointer; padding: 0;">
                                    <i class="@(i <= myRating ? "fas fa-star" : "far fa-star")"></i>
                                </button>
                            }
                        </div>

                        <button type="submit" class="story-follow-btn" style="padding: 8px 14px; font-size: 0.9rem;">Submit Rating</button>
                    </form>
                }
                else
                {
                    <button type="button" id="ratingLoginBtn" class="story-follow-btn" style="padding: 8px 14px; font-size: 0.9rem;">Login to rate</button>
                }
            </div>

            <div class="story-detail-follow">
                @if (User?.Identity?.IsAuthenticated ?? false)
                {
                    <form class="story-follow-form" asp-controller="Follows" asp-action="Toggle" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="storyId" value="@Model.Id" />
                        <input type="hidden" name="returnUrl" value="@ViewContext.HttpContext.Request.Path" />
                        <button type="submit" class="story-follow-btn @(isFollowed ? "active" : "")">
                            @(isFollowed ? "Following" : "Follow")
                        </button>
                    </form>
                }
                else
                {
                    <button type="button" id="followLoginBtn" class="story-follow-btn" data-open-login="true">Follow</button>
                }
                <span>@Model.FollowCount.ToString("N0") Followers</span>
            </div>
            <div class="story-detail-actions">
                <a class="story-action primary" href="@firstChapterUrl">Read from start</a>
                <a class="story-action primary" href="@latestChapterUrl">Read latest</a>
                @if (User?.Identity?.IsAuthenticated == true && continueChapterNumber.HasValue)
                {
                    <a class="story-action outline" href="@continueChapterUrl">Continue Reading &gt;</a>
                }
            </div>

        </div>

@section Scripts {
    <script>
        const followLoginBtn = document.getElementById('followLoginBtn');
        const ratingLoginBtn = document.getElementById('ratingLoginBtn');
        const commentLoginBtn = document.getElementById('commentLoginBtn');
        const ratingStarsInput = document.getElementById('ratingStarsInput');
        const ratingScoreInput = document.getElementById('ratingScoreInput');

        const openLoginModal = () => {
            const loginBtn = document.getElementById('loginBtn');
            if (loginBtn) {
                loginBtn.click();
                return;
            }
            document.getElementById('authModal')?.classList.add('active');
        };

        if (followLoginBtn) {
            followLoginBtn.addEventListener('click', (e) => {
                e.preventDefault();
                alert('You must sign in to follow the story.');
                openLoginModal();
            });
        }

        if (ratingLoginBtn) {
            ratingLoginBtn.addEventListener('click', (e) => {
                e.preventDefault();
                alert('You must sign in to rate the story.');
                openLoginModal();
            });
        }

        if (commentLoginBtn) {
            commentLoginBtn.addEventListener('click', (e) => {
                e.preventDefault();
                alert('You must sign in to comment.');
                openLoginModal();
            });
        }

        if (ratingStarsInput && ratingScoreInput) {
            const updateRatingStars = (score) => {
                ratingStarsInput.querySelectorAll('.rating-star-btn').forEach((btn) => {
                    const starScore = parseInt(btn.getAttribute('data-score'));
                    const icon = btn.querySelector('i');
                    if (!icon) return;
                    icon.className = starScore <= score ? 'fas fa-star' : 'far fa-star';
                });
            };

            ratingStarsInput.querySelectorAll('.rating-star-btn').forEach((btn) => {
                btn.addEventListener('click', () => {
                    const score = parseInt(btn.getAttribute('data-score'));
                    if (!Number.isNaN(score)) {
                        ratingScoreInput.value = score;
                        updateRatingStars(score);
                    }
                });
            });

            updateRatingStars(parseInt(ratingScoreInput.value || '0'));
        }
    </script>
}
    </div>
    <div class="story-detail-description">
        <h3>STORY CONTENT</h3>
        <p>@(string.IsNullOrWhiteSpace(Model.Description) ? "No description yet." : Model.Description)</p>
    </div>
    <div class="story-chapters">
        <div class="story-chapters-header">Chapter List</div>
        @if (orderedChapters.Any())
        {
            <div class="story-chapters-list">
                @foreach (var chapter in orderedChapters.OrderByDescending(c => c.ChapterNumber))
                {
                    var chapterUrl = Url.RouteUrl("ChapterReadSeo", new
                    {
                        storySlug,
                        chapterNumber = chapter.ChapterNumber.ToString(CultureInfo.InvariantCulture)
                    });
                    chapterUrl ??= "#";
                    <a class="story-chapter-item" href="@chapterUrl">
                        <span>Chapter @chapter.ChapterNumber</span>
                        <span class="chapter-date">@chapter.CreatedAt.ToString("dd/MM/yyyy")</span>
                    </a>
                }
            </div>
        }
        else
        {
            <div class="story-chapters-empty">No chapters yet.</div>
        }
    </div>

    <div class="story-detail-description" style="margin-top: 18px;">
        <h3>COMMENTS (@storyComments.Count)</h3>

        @if (TempData["CommentMessage"] != null)
        {
            <p style="margin: 10px 0; color: #2563eb;">@TempData["CommentMessage"]</p>
        }

        @if (User?.Identity?.IsAuthenticated ?? false)
        {
            <form asp-action="AddComment" method="post" style="margin-bottom: 16px;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="storyId" value="@Model.Id" />
                <input type="hidden" name="returnUrl" value="@ViewContext.HttpContext.Request.Path" />
                <textarea name="content" rows="3" maxlength="1000" placeholder="Write your comment..." style="width: 100%; border: 1px solid #d1d5db; border-radius: 10px; padding: 10px; resize: vertical;"></textarea>
                <div style="margin-top: 8px;">
                    <button type="submit" class="story-follow-btn" style="padding: 8px 14px;">Submit</button>
                </div>
            </form>
        }
        else
        {
            <button type="button" id="commentLoginBtn" class="story-follow-btn" style="padding: 8px 14px; margin-bottom: 12px;">Login to comment</button>
        }

        @if (storyComments.Any())
        {
            <div style="display: grid; gap: 10px;">
                @foreach (var comment in storyComments)
                {
                    var avatarUrl = string.IsNullOrWhiteSpace(comment.Avatar)
                        ? "https://ui-avatars.com/api/?name=" + Uri.EscapeDataString(comment.UserName)
                        : comment.Avatar;

                    <div style="border: 1px solid #e5e7eb; border-radius: 12px; padding: 10px;">
                        <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 6px;">
                            <img src="@avatarUrl" alt="@comment.UserName" style="width: 32px; height: 32px; border-radius: 50%; object-fit: cover;" />
                            <strong style="font-size: 0.95rem;">@comment.UserName</strong>
                            <span style="font-size: 0.8rem; color: #6b7280;">@comment.CreateDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                        </div>
                        <p style="margin: 0; color: #1f2937; white-space: pre-wrap;">@comment.Content</p>
                    </div>
                }
            </div>
        }
        else
        {
            <p style="color: #6b7280; margin: 0;">No comments yet.</p>
        }
    </div>
</div>
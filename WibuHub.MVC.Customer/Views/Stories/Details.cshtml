@using System.Globalization
@using WibuHub.ApplicationCore.Entities
@model WibuHub.ApplicationCore.Entities.Story

@{
    ViewData["Title"] = Model.StoryName;
    var coverUrl = string.IsNullOrWhiteSpace(Model.CoverImage)
        ? "https://ui-avatars.com/api/?name=Anonymous&background=E2E8F0&color=475569"
        : (Model.CoverImage.StartsWith("http", StringComparison.OrdinalIgnoreCase)
            ? Model.CoverImage
            : Url.Content($"~/{Model.CoverImage.TrimStart('/')}"));

    var storySlug = string.IsNullOrWhiteSpace(Model.Slug)
        ? Model.StoryName
        : Model.Slug;

    var statusText = Model.Status switch
    {
        1 => "Hoàn thành",
        2 => "Tạm ngưng",
        _ => "Đang tiến hành"
    };

    var authorName = !string.IsNullOrWhiteSpace(Model.AuthorName)
        ? Model.AuthorName
        : Model.Author?.Name ?? "Đang cập nhật";

    var createdDate = Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy");

    var orderedChapters = (Model.Chapters ?? Array.Empty<Chapter>())
        .OrderBy(c => c.ChapterNumber)
        .ToList();

    var chapterCount = orderedChapters.Count;
    var firstChapter = orderedChapters.FirstOrDefault();
    var latestChapter = orderedChapters.LastOrDefault();

    var continueChapterNumber = ViewData["ContinueChapterNumber"] is double number
        ? number
        : (double?)null;

    var firstChapterUrl = firstChapter == null
        ? "#"
        : Url.RouteUrl("ChapterReadSeo", new
        {
            storySlug,
            chapterNumber = firstChapter.ChapterNumber.ToString(CultureInfo.InvariantCulture)
        }) ?? "#";

    var latestChapterUrl = latestChapter == null
        ? "#"
        : Url.RouteUrl("ChapterReadSeo", new
        {
            storySlug,
            chapterNumber = latestChapter.ChapterNumber.ToString(CultureInfo.InvariantCulture)
        }) ?? "#";

    var continueChapterUrl = continueChapterNumber.HasValue
        ? Url.RouteUrl("ChapterReadSeo", new
        {
            storySlug,
            chapterNumber = continueChapterNumber.Value.ToString(CultureInfo.InvariantCulture)
        }) ?? "#"
        : "#";

    // Đã sửa: Xóa logic check fallback Model.Category cũ và dùng thẳng StoryCategories an toàn
    var storyCategories = Model.StoryCategories?
        .Where(sc => sc.Category != null)
        .Select(sc => sc.Category!)
        .ToList() ?? new List<Category>();

    var categoryDisplay = storyCategories.Any()
        ? string.Join(", ", storyCategories.Select(c => c.Name))
        : "Đang cập nhật";

    var ratingValue = Math.Clamp((int)Math.Round(Model.RatingScore), 0, 5);
    var isFollowed = (ViewData["IsFollowed"] as bool?) ?? false;
}

<div style="padding: 15px 20px 20px 20px; max-width: 1200px; margin: 0 auto;">
    <ul style="display: flex; flex-wrap: wrap; list-style: none; padding: 0; margin: 0; font-size: 0.95rem; color: #6b7280; align-items: center; gap: 8px;">
        <li>
            <a href="/Categories?id=@(storyCategories.FirstOrDefault()?.Id)" style="color: #3b82f6; text-decoration: none;">
                @(storyCategories.FirstOrDefault()?.Name ?? "Thể loại")
            </a>
        </li>
        <li><span style="margin: 0 2px;">/</span></li>
        <li>
            @if (storyCategories.Any())
            {
                var firstCat = storyCategories.First();
                <a href="/Categories?id=@firstCat.Id" style="color: #3b82f6; text-decoration: none;">
                    @firstCat.Name
                </a>
            }
            else
            {
                <span>Thể loại</span>
            }
        </li>
        <li><span style="margin: 0 2px;">/</span></li>
        <li>
            <span style="color: #1f2937; font-weight: 500;">@Model.StoryName</span>
        </li>
    </ul>
</div>

<div class="story-detail-shell">
    <div class="story-detail-header">
        <div class="story-detail-cover">
            <img src="@coverUrl" alt="@Model.StoryName" />
        </div>
        <div class="story-detail-content">
            <h1 class="story-detail-title">@Model.StoryName</h1>
            <div class="story-detail-stats">
                <div class="story-detail-stat">
                    <span class="stat-label">Tác giả</span>
                    <span class="stat-value">@authorName</span>
                </div>
                <div class="story-detail-stat">
                    <span class="stat-label">Tình trạng</span>
                    <span class="stat-value">@statusText</span>
                </div>
                <div class="story-detail-stat">
                    <span class="stat-label">Thể loại</span>
                    <span class="stat-value">
                        @if (storyCategories.Any())
                        {
                            @for (int i = 0; i < storyCategories.Count; i++)
                            {
                                <a href="/Categories?id=@storyCategories[i].Id"
                                   style="color: #3b82f6; text-decoration: none; font-weight: 500;">
                                    @storyCategories[i].Name
                                </a>
                                @(i < storyCategories.Count - 1 ? ", " : "")
                            }
                        }
                        else
                        {
                            @("Đang cập nhật")
                        }
                    </span>
                </div>
                <div class="story-detail-stat">
                    <span class="stat-label">Lượt xem</span>
                    <span class="stat-value">@Model.ViewCount</span>
                </div>
            </div>
            <div class="story-detail-rating">
                <div class="rating-stars">
                    @for (var i = 1; i <= 5; i++)
                    {
                        <i class="@(i <= ratingValue ? "fas fa-star" : "far fa-star")"></i>
                    }
                </div>
                <span class="rating-text">@Model.RatingScore.ToString("0.0")/5</span>
                <span class="rating-divider">-</span>
                <span class="rating-meta">@chapterCount Chap</span>
            </div>
            <div class="story-detail-follow">
                @if (User?.Identity?.IsAuthenticated ?? false)
                {
                    <form class="story-follow-form" asp-controller="Follows" asp-action="Toggle" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="storyId" value="@Model.Id" />
                        <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                        <button type="submit" class="story-follow-btn @(isFollowed ? "active" : "")">
                            @(isFollowed ? "Đã theo dõi" : "Theo dõi")
                        </button>
                    </form>
                }
                else
                {
                    <button type="button" class="story-follow-btn" data-open-login="true">Theo dõi</button>
                }
                <span>@Model.FollowCount.ToString("N0") Người đã theo dõi</span>
            </div>
            <div class="story-detail-actions">
                <a class="story-action primary" href="@firstChapterUrl">Đọc từ đầu</a>
                <a class="story-action primary" href="@latestChapterUrl">Đọc mới nhất</a>
                @if (User?.Identity?.IsAuthenticated == true && continueChapterNumber.HasValue)
                {
                    <a class="story-action outline" href="@continueChapterUrl">Đọc tiếp &gt;</a>
                }
            </div>
        </div>
    </div>
    <div class="story-detail-description">
        <h3>NỘI DUNG TRUYỆN</h3>
        <p>@(string.IsNullOrWhiteSpace(Model.Description) ? "Chưa có mô tả." : Model.Description)</p>
    </div>
    <div class="story-chapters">
        <div class="story-chapters-header">Danh sách chương</div>
        @if (orderedChapters.Any())
        {
            <div class="story-chapters-list">
                @foreach (var chapter in orderedChapters.OrderByDescending(c => c.ChapterNumber))
                {
                    var chapterUrl = Url.RouteUrl("ChapterReadSeo", new
                    {
                        storySlug,
                        chapterNumber = chapter.ChapterNumber.ToString(CultureInfo.InvariantCulture)
                    });
                    chapterUrl ??= "#";
                    <a class="story-chapter-item" href="@chapterUrl">
                        <span>Chương @chapter.ChapterNumber</span>
                        <span class="chapter-date">@chapter.CreatedAt.ToString("dd/MM/yyyy")</span>
                    </a>
                }
            </div>
        }
        else
        {
            <div class="story-chapters-empty">Chưa có chương.</div>
        }
    </div>
</div>
@using System.Globalization
@model WibuHub.MVC.Customer.ViewModels.RankingStoriesViewModel

@{
    ViewData["Title"] = $"BXH - {Model.Title}";
}

<div class="category-page">
    <div class="category-page-header">
        <h2>@Model.Title</h2>
        <span>@Model.Stories.Count truy?n</span>
    </div>

    @if (Model.Stories.Count == 0)
    {
        <div class="category-empty">Ch²a c¾ truy?n trong b?ng x?p h?ng nÓy.</div>
    }
    else
    {
        <div class="category-grid">
            @foreach (var story in Model.Stories)
            {
                var coverImage = string.IsNullOrWhiteSpace(story.CoverImage)
                    ? string.Empty
                    : (story.CoverImage.StartsWith("http", StringComparison.OrdinalIgnoreCase)
                        ? story.CoverImage
                        : Url.Content($"~/{story.CoverImage.TrimStart('/') }"));
                var updatedAt = story.UpdateDate.ToLocalTime();
                var timeSpan = DateTime.Now - updatedAt;
                var timeLabel = timeSpan.TotalHours < 24
                    ? $"{Math.Max(1, (int)Math.Round(timeSpan.TotalHours))} Gi? Tr²?c"
                    : $"{Math.Max(1, (int)Math.Round(timeSpan.TotalDays))} NgÓy Tr²?c";
                var latestChapter = story.Chapters?
                    .OrderByDescending(c => c.ChapterNumber)
                    .FirstOrDefault();
                var chapterLabel = latestChapter != null ? $"Ch²§ng {latestChapter.ChapterNumber}" : "Ch²a c¾ ch²§ng";
                var storySlug = string.IsNullOrWhiteSpace(story.Slug) ? story.StoryName : story.Slug;
                var chapterUrl = latestChapter == null
                    ? "#"
                    : Url.RouteUrl("ChapterReadSeo", new
                    {
                        storySlug,
                        chapterNumber = latestChapter.ChapterNumber.ToString(CultureInfo.InvariantCulture)
                    }) ?? "#";
                var isHot = story.ViewCount >= 10000;
                <div class="category-card">
                    <a class="category-cover" href="@chapterUrl" style="@(string.IsNullOrWhiteSpace(coverImage) ? string.Empty : $"background-image:url('{coverImage}')")">
                        <div class="category-badges">
                            <span class="category-badge">@timeLabel</span>
                            @if (isHot)
                            {
                                <span class="category-badge hot">Hot</span>
                            }
                        </div>
                    </a>
                    <div class="category-info">
                        <a class="category-title" href="@chapterUrl">@story.StoryName</a>
                        <div class="category-chapter">@chapterLabel</div>
                    </div>
                </div>
            }
        </div>
    }
</div>

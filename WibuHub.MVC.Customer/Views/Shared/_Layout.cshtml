                <a href="#" class="mobile-menu-item" id="mobileHot"><i class="fas fa-fire"></i> Hot nhất</a>
                <a asp-controller="Categories" asp-action="Index" asp-route-id="" class="mobile-menu-item" id="mobileGenre"><i class="fas fa-tags"></i> Thể loại</a>
                <a href="#" class="mobile-menu-item" id="mobileRank"><i class="fas fa-crown"></i> BXH</a>
                <a href="#" class="mobile-menu-item" id="mobileCompleted"><i class="fas fa-check-circle"></i> Hoàn thành</a>
                <a href="#" class="mobile-menu-item" id="mobileGroups"><i class="fas fa-users"></i> Nhóm dịch</a>
                <a href="#" class="mobile-menu-item" id="mobileProfilePage"><i class="fas fa-user"></i> Cá nhân</a>
            </div>
        }
        <!-- Navigation tabs (desktop) -->
        <nav class="nav-tabs">
            <a class="nav-item" id="tabHome" asp-controller="Home" asp-action="Index">Trang chủ</a>
            <a class="nav-item" id="tabNew" asp-controller="Home" asp-action="Index">Mới cập nhật</a>
            <a class="nav-item" id="tabHot" asp-controller="Home" asp-action="Index">Hot nhất</a>
            <div class="nav-dropdown">
                <span class="nav-item nav-item-static" id="tabGenre">Thể loại <i class="fas fa-chevron-down"></i></span>
                <div class="genre-dropdown">
                    <div class="genre-column">
                        <a class="genre-link genre-link-all" asp-controller="Categories" asp-action="Index" asp-route-id="">Tất cả</a>
                        @foreach (var category in categories.Take(categoriesPerColumn))
                        {
                            <a class="genre-link" asp-controller="Categories" asp-action="Index" asp-route-id="@category.Id">@category.Name</a>
                        }
                    </div>
                    @for (var columnIndex = 1; columnIndex < categoryColumnCount; columnIndex++)
                    {
                        var columnCategories = categories
                            .Skip(columnIndex * categoriesPerColumn)
                            .Take(categoriesPerColumn)
                            .ToList();

                        <div class="genre-column">
                            @foreach (var category in columnCategories)
                            {
                                <a class="genre-link" asp-controller="Categories" asp-action="Index" asp-route-id="@category.Id">@category.Name</a>
                            }
                        </div>
                    }
                </div>
            </div>
            <div class="nav-dropdown nav-dropdown-rank">
                <span class="nav-item nav-item-static" id="tabRank">BXH <i class="fas fa-chevron-down"></i></span>
                <div class="rank-dropdown">
                    <a class="rank-link" asp-controller="Rankings" asp-action="Index" asp-route-type="top-day">Top Ngày</a>
                    <a class="rank-link" asp-controller="Rankings" asp-action="Index" asp-route-type="top-week">Top Tuần</a>
                    <a class="rank-link" asp-controller="Rankings" asp-action="Index" asp-route-type="top-month">Top Tháng</a>
                    <a class="rank-link" asp-controller="Rankings" asp-action="Index" asp-route-type="favorites">Yêu Thích</a>
                    <a class="rank-link" asp-controller="Rankings" asp-action="Index" asp-route-type="latest">Mới Cập Nhật</a>
                    <a class="rank-link" asp-controller="Rankings" asp-action="Index" asp-route-type="new">Truyện Mới</a>
                    <a class="rank-link" asp-controller="Rankings" asp-action="Index" asp-route-type="full">Truyện Full</a>
                    <a class="rank-link" asp-controller="Rankings" asp-action="Index" asp-route-type="random">Truyện Ngẫu Nhiên</a>
                </div>
            </div>
            <a class="nav-item" id="tabCompleted" asp-controller="Home" asp-action="Index">Hoàn thành</a>
            <a class="nav-item" id="tabGroups" asp-controller="Home" asp-action="Index">Nhóm dịch</a>
            <a class="nav-item" id="tabProfilePage" asp-controller="Home" asp-action="Index">Cá nhân</a>
        </nav>



                        <div class="hot-item"><span class="hot-rank">1</span><div class="hot-info"><h4>One Piece</h4><p>Chapter 1090 • 980K</p></div></div>
                        <div class="hot-item"><span class="hot-rank">2</span><div class="hot-info"><h4>Dớp Dâng</h4><p>Chapter 567 • 854K</p></div></div>
                        <div class="hot-item"><span class="hot-rank">3</span><div class="hot-info"><h4>Thiên mệnh đế chủ</h4><p>Chapter 420 • 620K</p></div></div>
                    </div>
                    <div class="rank-content" id="rankMonth">
                        <div class="hot-item"><span class="hot-rank">1</span><div class="hot-info"><h4>Solo Leveling</h4><p>Chapter 200 • 1.2M</p></div></div>
                        <div class="hot-item"><span class="hot-rank">2</span><div class="hot-info"><h4>One Piece</h4><p>Chapter 1090 • 980K</p></div></div>
                        <div class="hot-item"><span class="hot-rank">3</span><div class="hot-info"><h4>Dớp Dâng</h4><p>Chapter 567 • 854K</p></div></div>

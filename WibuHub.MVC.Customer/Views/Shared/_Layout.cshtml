                        const desc = story.description || story.Description || 'Updating...';
                        const cover = story.coverImage || story.CoverImage || 'https://via.placeholder.com/200x300';
                        const rating = story.rating || story.Rating || '5.0';
                        const views = Utils.formatViews(story.viewCount || story.ViewCount || 0);

                        list.insertAdjacentHTML('beforeend', `
                            <li class="suggest-slide" style="flex: 0 0 100%; width: 100%; box-sizing: border-box;">
                                <div class="featured-box" style="display:flex; align-items:center; justify-content:space-between; padding:40px; gap:30px; width:100%;">
                                    <div class="featured-info" style="flex:1; color:white;">
                                        <p class="tag-hot" style="color:#fbbf24; font-weight:bold; margin-bottom:10px;">FEATURED</p>
                                        <h2 style="font-size:2.5rem; margin:0 0 15px 0; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">${title}</h2>
                                        <p class="desc" style="color:#9ca3af; margin-bottom:20px; display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; overflow:hidden;">${desc}</p>
                                        <div class="stats" style="margin-bottom:25px;">
                                            <span style="margin-right:15px; color:#fbbf24;"><i class="fas fa-star"></i> ${rating}</span>
                                            <span style="color:#9ca3af;"><i class="fas fa-eye"></i> ${views} views</span>
                                        </div>
                                        <a href="/Stories/Details/${id}" class="btn-read" style="display:inline-block; background-color:#3b82f6; color:white; padding:12px 32px; border-radius:20px; font-weight:bold; text-decoration:none;">Read Now</a>
                                    </div>
                                    <div class="featured-cover" style="width:200px; height:300px; border-radius:12px; overflow:hidden; flex-shrink:0; background:#333; box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.5);">
                                        <img src="${cover}" alt="${title}" style="width:100%; height:100%; object-fit:cover;">
                                    </div>
                                </div>
                            </li>
                        `);
                    });

                    this.initSliderLogic();
                } catch (err) {
                    list.innerHTML = '<li style="width:100%;text-align:center;padding:50px;color:#ef4444;">Error loading data</li>';
                }
            },

            initSliderLogic: function() {
                const track = document.getElementById('list_suggest');
                if (!track) return;
                const slides = track.querySelectorAll('.suggest-slide');
                const slideCount = slides.length;
                let currentIndex = 0;
                let autoPlayTimer;

                const goToSlide = (index) => {
                    if (index >= slideCount) currentIndex = 0;
                    else if (index < 0) currentIndex = slideCount - 1;
                    else currentIndex = index;
                    track.style.transform = `translateX(-${currentIndex * 100}%)`;
                };

                const startAutoPlay = () => { autoPlayTimer = setInterval(() => goToSlide(currentIndex + 1), 5000); };
                const resetAutoPlay = () => { clearInterval(autoPlayTimer); startAutoPlay(); };

                document.querySelector('.slider-prev')?.addEventListener('click', () => { goToSlide(currentIndex - 1); resetAutoPlay(); });
                document.querySelector('.slider-next')?.addEventListener('click', () => { goToSlide(currentIndex + 1); resetAutoPlay(); });

                if(slideCount > 1) startAutoPlay();
            }
        };

        // ----------------------------------------------------
        // CHAT CONTROLLER: AI Communication Handler
        // ----------------------------------------------------
        const ChatController = {
            elements: {
                body: document.getElementById('chatBody'),
                input: document.getElementById('chatInput'),
                btnSend: document.getElementById('sendChat')
            },

            init: function() {
                if (!this.elements.input || !this.elements.btnSend) return;

                this.elements.btnSend.addEventListener('click', () => this.sendMessage());

                this.elements.input.addEventListener('keypress', (e) => {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        this.sendMessage();
                    }
                });
            },

            sendMessage: async function() {
                const text = this.elements.input.value.trim();
                if (!text) return;

                this.appendMessage(text, 'user');
                this.elements.input.value = '';

                const typingId = 'typing-' + Date.now();
                this.appendMessage('<i class="fas fa-ellipsis-h fa-fade"></i> Thinking...', 'ai', typingId);

                try {
                    const response = await fetch('http://localhost:5136/api/chatbot/ask', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ message: text })
                    });

                    const data = await response.json();
                    document.getElementById(typingId)?.remove();

                    if (response.ok) {
                        this.appendMessage(data.reply.replace(/\n/g, '<br>'), 'ai');
                    } else {
                        this.appendMessage('Error: ' + (data.message || 'Cannot connect to API.'), 'ai');
                    }
                } catch (error) {
                    console.error("Chat Error:", error);
                    document.getElementById(typingId)?.remove();
                    this.appendMessage('Sorry, the AI system is busy. Please try again later!', 'ai');
                }
            },

            appendMessage: function(text, senderClass, id = '') {
                if (!this.elements.body) return;

                const msgDiv = document.createElement('div');
                msgDiv.className = `message ${senderClass}`;
                if (id) msgDiv.id = id;
                msgDiv.innerHTML = text;

                this.elements.body.appendChild(msgDiv);
                this.elements.body.scrollTop = this.elements.body.scrollHeight;
            }
        };

        // ----------------------------------------------------
        // NOTIFICATION CONTROLLER: Manage Notifications
        // ----------------------------------------------------
        const NotificationController = {
            isLoggedIn: @((User?.Identity?.IsAuthenticated ?? false).ToString().ToLower()),
            dropdownVisible: false,
            lastUnreadCount: 0,
            isInitialized: false,
            pollTimer: null,

            init: function() {
                if (!this.isLoggedIn) return; // Do nothing if not logged in

                const btn = document.getElementById('notificationBtn');
                const dropdown = document.getElementById('notificationDropdown');
                const markAllBtn = document.getElementById('markAllReadBtn');
                const deleteReadBtn = document.getElementById('deleteReadBtn');

                if (!btn || !dropdown) return;

                // 1. Load badge count on page load
                this.loadNotifications(true);
                this.pollTimer = setInterval(() => this.loadNotifications(true), 20000);

                // 2. Handle Bell click
                btn.addEventListener('click', (e) => {
                    e.preventDefault();
                    this.dropdownVisible = !this.dropdownVisible;
                    dropdown.style.display = this.dropdownVisible ? 'block' : 'none';

                    if (this.dropdownVisible) {
                        this.loadNotifications(false); // Render details when open
                    }
                });

                // 3. Hide dropdown when click outside
                document.addEventListener('click', (e) => {
                    if (!btn.contains(e.target) && !dropdown.contains(e.target)) {
                        this.dropdownVisible = false;
                        dropdown.style.display = 'none';
                    }
                });

                // 4. Mark all as read
                markAllBtn?.addEventListener('click', () => this.markAllAsRead());
                deleteReadBtn?.addEventListener('click', () => this.deleteReadNotifications());
            },

            loadNotifications: async function(isBadgeOnly) {
                try {
                    const response = await fetch('/api/notification', {
                        credentials: 'include'
                    });

                    if (!response.ok) {
                        document.getElementById('notificationList').innerHTML = '<li style="padding: 20px; text-align: center; color: #ef4444;">Error loading data</li>';
                        return;
                    }

                    const notifications = await response.json();

                    // Count unread
                    const unreadCount = notifications.filter(n => !n.isRead).length;
                    const badge = document.getElementById('notiBadge');
                    if (badge) {
                        badge.textContent = unreadCount;
                        badge.style.display = unreadCount > 0 ? 'inline-block' : 'none';
                    }

                    if (this.isInitialized && unreadCount > this.lastUnreadCount) {
                        this.playNotificationSound();
                    }
                    this.lastUnreadCount = unreadCount;
                    this.isInitialized = true;

                    if (isBadgeOnly) return;

                    // Render list
                    this.renderList(notifications);

                } catch (error) {
                    console.error("Error loading notification:", error);
                }
            },

            renderList: function(notifications) {
                const listEl = document.getElementById('notificationList');
                if (!listEl) return;

                if (!notifications || notifications.length === 0) {
                    listEl.innerHTML = '<li style="padding: 20px; text-align: center; color: #9ca3af;">No notifications yet</li>';
                    return;
                }

                let html = '';
                notifications.forEach(noti => {
                    const bgClass = noti.isRead ? '' : 'unread';
                    html += `
                        <li>
                            <a href="${noti.targetUrl || '#'}" class="noti-item ${bgClass}" onclick="NotificationController.markAsRead('${noti.id}', this)">
                                <h4 class="noti-title">${noti.title}</h4>
                                <p class="noti-msg">${noti.message}</p>
                                <p class="noti-time"><i class="far fa-clock"></i> ${noti.timeAgo || new Date(noti.createDate).toLocaleDateString()}</p>
                            </a>
                        </li>
                    `;
                });
                listEl.innerHTML = html;
            },

            markAsRead: async function(id, element) {
                if (!element.classList.contains('unread')) return;
                element.classList.remove('unread');
                try {
                    await fetch(`/api/notification/${id}/read`, {
                        method: 'PUT',
                        credentials: 'include'
                    });
                    // Update badge count
                    const badge = document.getElementById('notiBadge');
                    if (badge) {
                        let count = parseInt(badge.textContent) - 1;
                        if (count < 0) count = 0;
                        badge.textContent = count;
                        badge.style.display = count > 0 ? 'inline-block' : 'none';
                    }
                } catch (e) { console.error(e); }
            },

            markAllAsRead: async function() {
                try {
                    await fetch('/api/notification/read-all', {
                        method: 'PUT',
                        credentials: 'include'
                    });
                    this.loadNotifications(false);
                } catch (e) { console.error(e); }
            },

            deleteReadNotifications: async function() {
                try {
                    await fetch('/api/notification/read', {
                        method: 'DELETE',
                        credentials: 'include'
                    });
                    this.loadNotifications(false);
                } catch (e) { console.error(e); }
            },

            playNotificationSound: function() {
                try {
                    const audioContext = new (window.AudioContext || window.webkitAudioContext)();
                    const oscillator = audioContext.createOscillator();
                    const gainNode = audioContext.createGain();

                    oscillator.type = 'sine';
                    oscillator.frequency.setValueAtTime(880, audioContext.currentTime);
                    gainNode.gain.setValueAtTime(0.0001, audioContext.currentTime);
                    gainNode.gain.exponentialRampToValueAtTime(0.12, audioContext.currentTime + 0.01);
                    gainNode.gain.exponentialRampToValueAtTime(0.0001, audioContext.currentTime + 0.18);

                    oscillator.connect(gainNode);
                    gainNode.connect(audioContext.destination);

                    oscillator.start();
                    oscillator.stop(audioContext.currentTime + 0.2);
                } catch (e) {
                    console.error('Cannot play notification sound:', e);
                }
            }
        };

        const IntroController = {
            storageKey: 'wibuhub_intro_304_shown',

            init: function(isHomePage) {
                document.body.classList.remove('preloader-active');
                document.body.classList.add('intro-304-done');
            },

            play: function(options = {}) {
                const shouldForce = options.force === true;
                if (!shouldForce && sessionStorage.getItem(this.storageKey) === '1') {
                    return;
                }

                const overlay = document.getElementById('intro304');
                if (!overlay) {
                    document.body.classList.remove('preloader-active');
                    return;
                }

                sessionStorage.setItem(this.storageKey, '1');
                document.body.classList.remove('intro-304-done');
                document.body.classList.add('preloader-active');

                const done = () => {
                    document.body.classList.add('intro-304-done');
                    document.body.classList.remove('preloader-active');
                };

                setTimeout(done, 5000);
            }
        };

        const ThemeController = {
            storageKey: 'wibuhub_theme_304',

            init: function() {
                const btn = document.getElementById('themeToggleBtn');
                const saved = localStorage.getItem(this.storageKey);
                const isEnabled = saved === null ? true : saved === '1';

                this.applyTheme(isEnabled);

                if (!btn) return;
                btn.addEventListener('click', () => {
                    const active = document.body.classList.contains('theme-304');
                    const nextState = !active;
                    this.applyTheme(nextState);
                });
            },

            applyTheme: function(enabled) {
                const btn = document.getElementById('themeToggleBtn');
                document.body.classList.toggle('theme-304', enabled);
                localStorage.setItem(this.storageKey, enabled ? '1' : '0');
                if (btn) btn.style.opacity = enabled ? '1' : '0.65';
            }
        };

        // ----------------------------------------------------
        // BOOTSTRAP APP
        // ----------------------------------------------------
        document.addEventListener('DOMContentLoaded', () => {
            const isHomePage = @isHomePage.ToString().ToLower();
            IntroController.init();
            ThemeController.init();
            AuthController.init();
            ChatController.init();
            SearchController.init();
            NotificationController.init(); // Initialize notifications

            const isThemeEnabled = (localStorage.getItem(ThemeController.storageKey) ?? '1') === '1';
            const shouldPlayIntro = isHomePage
                && isThemeEnabled
                && sessionStorage.getItem(IntroController.storageKey) !== '1';
            if (shouldPlayIntro) {
                IntroController.play();
            }

            if (document.getElementById('homeSection') !== null) {
                UIController.init();
                DataController.init();
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

@using Microsoft.AspNetCore.Identity
@using WibuHub.ApplicationCore.Entities.Identity
@using WibuHub.Service.Interface
@inject SignInManager<StoryUser> SignInManager
@inject ICategoryService CategoryService

@{
    var returnUrl = Url.Action("Index", "Home", new { area = "" }) ?? "/";
    var externalSchemes = (await SignInManager.GetExternalAuthenticationSchemesAsync()).ToList();
    var categories = await CategoryService.GetAllAsync();
    var categoryColumnCount = categories.Count == 0 ? 1 : 4;
    var categoriesPerColumn = categories.Count > 0
        ? (int)Math.Ceiling(categories.Count / (double)categoryColumnCount)
        : 0;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Truyện Hay - Chi tiết truyện</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true">
</head>
<body>
    @{
        var isHomePage = string.Equals(ViewContext.RouteData.Values["controller"]?.ToString(), "Home", StringComparison.OrdinalIgnoreCase)
        && string.Equals(ViewContext.RouteData.Values["action"]?.ToString(), "Index", StringComparison.OrdinalIgnoreCase);
        var isIdentityArea = string.Equals(ViewContext.RouteData.Values["area"]?.ToString(), "Identity", StringComparison.OrdinalIgnoreCase);
    }
    <div class="app">
        <header class="header">
            <div class="logo-area">
                <button class="mobile-menu-btn" id="mobileMenuBtn"><i class="fas fa-bars"></i></button>
                <a asp-controller="Home" asp-action="Index" asp-area="" class="logo" id="logo">WIBU<span>HUB</span></a>
            </div>
            <div class="search-bar">
                <input type="text" placeholder="Tìm truyện, tác giả..." id="searchInput">
                <button id="searchBtn"><i class="fas fa-search"></i></button>
            </div>
            <div class="user-actions">
                <a href="#" id="notificationBtn"><i class="far fa-bell"></i> <span>Thông báo</span></a>
                <a href="/ShoppingCart/Cart" id="cartBtn"><i class="fas fa-shopping-cart"></i> <span>Giỏ hàng</span></a>
                @if (User?.Identity?.IsAuthenticated ?? false)
                {
                    <span class="user-name"><i class="far fa-user"></i> <span>@User.Identity?.Name</span></span>
                    <form class="logout-form" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                        <button type="submit" class="logout-btn"><i class="fas fa-sign-out-alt"></i> <span>Đăng xuất</span></button>
                    </form>
                }
                else
                {
                    <a href="#" id="loginBtn"><i class="far fa-user"></i> <span>Đăng nhập</span></a>
                    <a href="#" id="registerBtn"><i class="fas fa-user-plus"></i> <span>Đăng ký</span></a>
                }
            </div>
        </header>

        <div id="authModal" class="modal">
            <div class="modal-content">
                <span class="modal-close" id="closeModal">&times;</span>
                <div class="modal-title">Login</div>
                <form id="loginModalForm" action="/api/auth/login" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <div class="form-error" id="loginError"></div>
                    <div class="input-group">
                        <label>Email</label>
                        <input type="email" name="email" autocomplete="username" placeholder="your@gmail.com" required>
                    </div>
                    <div class="input-group">
                        <label>Password</label>
                        <input type="password" name="password" autocomplete="current-password" placeholder="••••••••" required>
                    </div>
                    <div class="login-meta">
                        <label class="remember-me"><input type="checkbox" name="rememberMe"> Remember me?</label>
                        <a asp-area="Identity" asp-page="/Account/ForgotPassword" class="forgot-link">Forgot your password?</a>
                    </div>
                    <button class="btn" type="submit">LOGIN</button>
                    <div class="switch-link">
                        Chưa có tài khoản? <a href="#" id="showRegisterModal">Register Now</a>
                    </div>
                    @if (externalSchemes.Count > 0)
                    {
                        <div class="external-auth">
                            <div class="external-title">Hoặc đăng nhập với</div>
                            <div class="external-buttons">
                                @foreach (var scheme in externalSchemes)
                                {
                                    <button type="submit" name="provider" value="@scheme.Name" formmethod="post" formaction="@Url.Page("/Account/ExternalLogin", new { area = "Identity", returnUrl })" class="btn-auth">
                                        @scheme.DisplayName
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </form>
            </div>
        </div>

        <div id="registerModal" class="modal">
            <div class="modal-content">
                <span class="modal-close" id="closeRegisterModal">&times;</span>
                <div class="modal-title">Register</div>
                <form id="registerModalForm" action="/api/auth/register" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <div class="form-error" id="registerError"></div>
                    <div class="input-group">
                        <label>Email</label>
                        <input type="email" name="email" autocomplete="username" placeholder="your@email.com" required>
                    </div>
                    <div class="input-group">
                        <label>Password</label>
                        <input type="password" name="password" autocomplete="new-password" placeholder="••••••••" required>
                    </div>
                    <div class="input-group">
                        <label>Confirmed Password</label>
                        <input type="password" name="confirmPassword" autocomplete="new-password" placeholder="••••••••" required>
                    </div>
                    <button class="btn" type="submit">REGISTER</button>
                    <div class="switch-link">
                        Have an account? <a href="#" id="showLoginModal">Login</a>
                    </div>
                    @if (externalSchemes.Count > 0)
                    {
                        <div class="external-auth">
                            <div class="external-title">Hoặc đăng ký với</div>
                            <div class="external-buttons">
                                @foreach (var scheme in externalSchemes)
                                {
                                    <button type="submit" name="provider" value="@scheme.Name" formmethod="post" formaction="@Url.Page("/Account/ExternalLogin", new { area = "Identity", returnUrl })" class="btn-auth">
                                        @scheme.DisplayName
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </form>
            </div>
        </div>

        @if (isHomePage)
        {
            <div class="mobile-menu-overlay" id="mobileMenuOverlay"></div>
            <div class="mobile-menu" id="mobileMenu">
                <div class="mobile-menu-header">
                    <span class="mobile-menu-logo">TRUYỆN<span>HAY</span></span>
                    <span class="close-menu" id="closeMenu"><i class="fas fa-times"></i></span>
                </div>
                <a href="#" class="mobile-menu-item active" id="mobileHome"><i class="fas fa-home"></i> Trang chủ</a>
                <a asp-controller="Categories" asp-action="Index" asp-route-id="" class="mobile-menu-item" id="mobileGenre"><i class="fas fa-tags"></i> Thể loại</a>
                <a href="#" class="mobile-menu-item" id="mobileRank"><i class="fas fa-crown"></i> BXH</a>
                <a href="#" class="mobile-menu-item" id="mobileGroups"><i class="fas fa-users"></i> Nhóm dịch</a>
                <a href="#" class="mobile-menu-item" id="mobileProfilePage"><i class="fas fa-user"></i> Cá nhân</a>
            </div>
        }

        <nav class="nav-tabs">
            <a class="nav-item" id="tabHome" asp-controller="Home" asp-action="Index">Trang chủ</a>
            <div class="nav-dropdown">
                <span class="nav-item nav-item-static" id="tabGenre">Thể loại <i class="fas fa-chevron-down"></i></span>
                <div class="genre-dropdown">
                    <div class="genre-column">
                        <a class="genre-link genre-link-all" asp-controller="Categories" asp-action="Index" asp-route-id="">Tất cả</a>
                        @foreach (var category in categories.Take(categoriesPerColumn))
                        {
                            <a class="genre-link" asp-controller="Categories" asp-action="Index" asp-route-id="@category.Id">@category.Name</a>
                        }
                    </div>
                    @for (var columnIndex = 1; columnIndex < categoryColumnCount; columnIndex++)
                    {
                        var columnCategories = categories.Skip(columnIndex * categoriesPerColumn).Take(categoriesPerColumn).ToList();
                        <div class="genre-column">
                            @foreach (var category in columnCategories)
                            {
                                <a class="genre-link" asp-controller="Categories" asp-action="Index" asp-route-id="@category.Id">@category.Name</a>
                            }
                        </div>
                    }
                </div>
            </div>
            <div class="nav-dropdown nav-dropdown-rank">
                <span class="nav-item nav-item-static" id="tabRank">BXH <i class="fas fa-chevron-down"></i></span>
                <div class="rank-dropdown">
                    <a class="rank-link" asp-controller="Rankings" asp-action="Index" asp-route-type="top-day">Top Ngày</a>
                    <a class="rank-link" asp-controller="Rankings" asp-action="Index" asp-route-type="top-week">Top Tuần</a>
                    <a class="rank-link" asp-controller="Rankings" asp-action="Index" asp-route-type="top-month">Top Tháng</a>
                    <a class="rank-link" asp-controller="Rankings" asp-action="Index" asp-route-type="favorites">Yêu Thích</a>
                    <a class="rank-link" asp-controller="Rankings" asp-action="Index" asp-route-type="latest">Mới Cập Nhật</a>
                    <a class="rank-link" asp-controller="Rankings" asp-action="Index" asp-route-type="new">Truyện Mới</a>
                    <a class="rank-link" asp-controller="Rankings" asp-action="Index" asp-route-type="full">Truyện Full</a>
                    <a class="rank-link" asp-controller="Rankings" asp-action="Index" asp-route-type="random">Truyện Ngẫu Nhiên</a>
                </div>
            </div>
            <a class="nav-item" id="tabGroups" asp-controller="Home" asp-action="Index">Nhóm dịch</a>
            <a class="nav-item" id="tabProfilePage" asp-controller="Home" asp-action="Index">Cá nhân</a>
        </nav>

        @if (isHomePage)
        {
            <div class="main-grid">
                <div>
                    <div id="homeSection" class="content-section">
                        <div class="suggest-slider-wrapper" style="min-height: 350px; background-color: #111827; border-radius: 16px; position: relative; margin-bottom: 30px; overflow: hidden; display: flex; align-items: center;">
                            <button class="slider-nav-btn slider-prev" style="position: absolute; left: 0; z-index: 10; height: 80px; width: 40px; background-color: rgba(0,0,0,0.6); color: white; border: none; border-radius: 0 8px 8px 0; cursor: pointer; font-size: 1.2rem;">
                                <i class="fas fa-chevron-left"></i>
                            </button>

                            <ul id="list_suggest" style="display: flex; list-style: none; padding: 0; margin: 0; width: 100%; transition: transform 0.5s ease;">
                                <li style="flex: 0 0 100%; width: 100%; text-align: center; color: #9ca3af; font-size: 1.1rem; padding: 50px 0;">
                                    <i class="fas fa-spinner fa-spin"></i> Đang tải dữ liệu Nổi Bật...
                                </li>
                            </ul>

                            <button class="slider-nav-btn slider-next" style="position: absolute; right: 0; z-index: 10; height: 80px; width: 40px; background-color: rgba(0,0,0,0.6); color: white; border: none; border-radius: 8px 0 0 8px; cursor: pointer; font-size: 1.2rem;">
                                <i class="fas fa-chevron-right"></i>
                            </button>
                        </div>

                        <div class="home-grid">
                            <div>
                                <div class="update-list">
                                    <div class="section-header">
                                        <h2>Truyện Mới Cập Nhật</h2>
                                        <span class="view-all-link" id="viewAllUpdates">Xem tất cả</span>
                                    </div>
                                </div>

                                <div>
                                    <div class="section-header" style="margin-top: 30px;">
                                        <h2>Truyện Đề Cử</h2>
                                        <div class="recommend-tabs">
                                            <span class="recommend-tab active" data-recommend="all">Tất cả</span>
                                            <span class="recommend-tab" data-recommend="popular">Phổ biến</span>
                                            <span class="recommend-tab" data-recommend="latest">Mới nhất</span>
                                        </div>
                                    </div>
                                    <div class="recommend-grid" id="recommendAll">
                                        <div class="recommend-card" data-title="Nguyên Tôn" data-rating="4.5" data-votes="1300">
                                            <div class="recommend-cover"></div>
                                            <div class="recommend-info">
                                                <div class="recommend-title">Nguyên Tôn</div>
                                                <div class="recommend-stats"><span>4 chương</span><span>1.3M</span></div>
                                            </div>
                                        </div>
                                        <div class="recommend-card" data-title="Vạn Cổ Chí Tôn" data-rating="4.2" data-votes="980">
                                            <div class="recommend-cover"></div>
                                            <div class="recommend-info">
                                                <div class="recommend-title">Vạn Cổ Chí Tôn</div>
                                                <div class="recommend-stats"><span>2 chương</span><span>980K</span></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div>
                                <div class="top-list">
                                    <div class="section-header">
                                        <h2>Xem Nhiều Nhất</h2>
                                    </div>
                                    <div style="text-align: center; padding: 20px; color: #9ca3af;">
                                        <i class="fas fa-spinner fa-spin"></i> Đang tải...
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div id="newSection" class="content-section hidden"><h2>Nội dung Mới cập nhật</h2></div>
                    <div id="hotSection" class="content-section hidden"><h2>Nội dung Hot nhất</h2></div>
                    <div id="rankSection" class="content-section hidden"><h2>Nội dung BXH</h2></div>
                    <div id="groupsSection" class="content-section hidden"><h2>Nội dung Nhóm dịch</h2></div>
                    <div id="profilePageSection" class="content-section hidden"><h2>Nội dung Cá nhân</h2></div>

                    <div id="detailSection" class="content-section hidden">
                        <div class="breadcrumb">
                            <a href="#" id="breadcrumbHome">Trang chủ</a> > <a href="#" id="breadcrumbCategory">Thể loại</a> > <span id="breadcrumbTitle">Tên truyện</span>
                        </div>
                        <div class="detail-container">
                            <div class="detail-header">
                                <div class="detail-cover" id="detailCover">Ảnh bìa</div>
                                <div class="detail-info">
                                    <h1 id="detailTitle">Tên truyện</h1>
                                    <div class="detail-meta">
                                        <div class="detail-meta-item"><span>Tác giả</span><strong id="detailAuthor">Đang cập nhật</strong></div>
                                        <div class="detail-meta-item"><span>Tình trạng</span><strong id="detailStatus">Đang tiến hành</strong></div>
                                        <div class="detail-meta-item"><span>Thể loại</span><strong id="detailGenre">Đang cập nhật</strong></div>
                                        <div class="detail-meta-item"><span>Lượt xem</span><strong id="detailViews">0</strong></div>
                                    </div>
                                    <div class="rating">
                                        <div class="stars-interactive">
                                            <i class="star fas fa-star"></i><i class="star fas fa-star"></i><i class="star fas fa-star"></i><i class="star fas fa-star"></i><i class="star fas fa-star"></i>
                                        </div>
                                        <span class="rating-text">5/5 - 0 Lượt đánh giá</span>
                                    </div>
                                    <div class="follow-info">
                                        <button class="follow-btn" id="followBtn">Theo dõi</button>
                                        <span><strong>0</strong> Người đã theo dõi</span>
                                    </div>
                                    <div class="action-buttons">
                                        <button class="action-btn" id="readFirstBtn">Đọc từ đầu</button>
                                        <button class="action-btn secondary" id="readContinueBtn">Đọc tiếp ></button>
                                    </div>
                                </div>
                            </div>
                            <div class="description" id="detailDescription">
                                <strong>NỘI DUNG TRUYỆN</strong><br>
                                Đang cập nhật nội dung...
                            </div>
                        </div>
                    </div>

                    <div style="text-align: center; margin: 30px 0;">
                        <a class="view-more-btn" id="viewMoreBtn">Xem thêm truyện <i class="fas fa-chevron-down"></i></a>
                    </div>
                </div>

                <aside class="sidebar">
                    <div class="sidebar-card">
                        <div class="sidebar-title"><i class="fas fa-crown" style="color: #fbbf24;"></i> Bảng xếp hạng</div>
                        <div class="rank-tabs">
                            <span class="rank-tab active" data-rank="day">Top ngày</span>
                            <span class="rank-tab" data-rank="week">Top tuần</span>
                            <span class="rank-tab" data-rank="month">Top tháng</span>
                        </div>
                        <div class="rank-content active" id="rankDay">
                            <div class="hot-item"><span class="hot-rank">1</span><div class="hot-info"><h4>Bách Luyện Thành Thần</h4><p>Chapter 1295 • 193K</p></div></div>
                            <div class="hot-item"><span class="hot-rank">2</span><div class="hot-info"><h4>Đại Phụng Đa Canh Nhân</h4><p>Chapter 619 • 297K</p></div></div>
                        </div>
                    </div>

                    <div class="history-card">
                        <h3>Lịch sử đọc <span class="view-all-link" style="font-size: 13px;">Xem tất cả</span></h3>
                        <div class="history-item">
                            <div class="history-cover">Ảnh</div>
                            <div class="history-info">
                                <div class="history-title">Vạn Cố Chí Tôn</div>
                                <div class="history-meta">Đọc tiếp Chapter 502 ></div>
                            </div>
                            <span class="delete-btn"><i class="fas fa-times"></i></span>
                        </div>
                    </div>

                    <div class="sidebar-card">
                        <div class="sidebar-title"><i class="fas fa-tags"></i> Thể loại</div>
                        <div class="genre-tags">
                            @foreach (var category in categories)
                            {
                                <a class="genre-tag" asp-controller="Categories" asp-action="Index" asp-route-id="@category.Id">@category.Name</a>
                            }
                        </div>
                    </div>
                </aside>
            </div>

            <div class="chatbox" id="chatbox">
                <div class="chat-header" id="toggleChat">
                    <h3><i class="fas fa-robot" style="color: #f97316;"></i> Trợ lý AI</h3>
                    <i class="fas fa-minus" id="chatIcon"></i>
                </div>
                <div class="chat-body" id="chatBody">
                    <div class="message ai">Xin chào! Tôi là trợ lý đọc truyện. Bạn cần tìm gì?</div>
                </div>
                <div class="chat-footer">
                    <input type="text" id="chatInput" placeholder="Nhập tin nhắn...">
                    <button id="sendChat"><i class="fas fa-paper-plane"></i></button>
                </div>
            </div>
        }
        @RenderBody()
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const isHomePage = document.getElementById('homeSection') !== null;

            // ==========================================
            // 1. XỬ LÝ ĐĂNG NHẬP / ĐĂNG KÝ
            // ==========================================
            const modals = {
                auth: document.getElementById('authModal'),
                register: document.getElementById('registerModal')
            };

            function toggleModal(modalToShow, modalToHide) {
                if (modalToHide) modalToHide.classList.remove('active');
                if (modalToShow) modalToShow.classList.add('active');
            }

            document.getElementById('loginBtn')?.addEventListener('click', (e) => { e.preventDefault(); toggleModal(modals.auth, modals.register); });
            document.getElementById('registerBtn')?.addEventListener('click', (e) => { e.preventDefault(); toggleModal(modals.register, modals.auth); });
            document.getElementById('showRegisterModal')?.addEventListener('click', (e) => { e.preventDefault(); toggleModal(modals.register, modals.auth); });
            document.getElementById('showLoginModal')?.addEventListener('click', (e) => { e.preventDefault(); toggleModal(modals.auth, modals.register); });

            document.querySelectorAll('.modal-close').forEach(btn => {
                btn.addEventListener('click', () => {
                    modals.auth?.classList.remove('active');
                    modals.register?.classList.remove('active');
                });
            });

            window.addEventListener('click', (e) => {
                if (e.target === modals.auth) modals.auth.classList.remove('active');
                if (e.target === modals.register) modals.register.classList.remove('active');
            });

            async function submitAuthForm(form, errorEl, isRegister = false) {
                if (!form) return;
                const formData = new FormData(form);
                const dataObject = Object.fromEntries(formData.entries());

                if (errorEl) { errorEl.classList.remove('active'); errorEl.textContent = ''; }

                try {
                    const response = await fetch(form.action, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': dataObject['__RequestVerificationToken']
                        },
                        body: JSON.stringify(dataObject)
                    });

                    const payload = await response.json().catch(() => ({}));

                    if (response.ok && payload.success) {
                        if (isRegister) {
                            toggleModal(modals.auth, modals.register);
                            const loginError = document.getElementById('loginError');
                            if (loginError) {
                                loginError.textContent = payload.message || 'Đăng ký thành công! Vui lòng đăng nhập.';
                                loginError.classList.add('active');
                                loginError.style.cssText = 'background-color: #d4edda; color: #155724;';
                            }
                            return;
                        }
                        window.location.href = payload.redirectUrl || window.location.href;
                    } else {
                        if (errorEl) { errorEl.textContent = payload.message || 'Thông tin không hợp lệ.'; errorEl.classList.add('active'); }
                    }
                } catch (error) {
                    if (errorEl) { errorEl.textContent = 'Mất kết nối tới máy chủ.'; errorEl.classList.add('active'); }
                }
            }

            document.getElementById('loginModalForm')?.addEventListener('submit', (e) => { e.preventDefault(); submitAuthForm(e.target, document.getElementById('loginError'), false); });
            document.getElementById('registerModalForm')?.addEventListener('submit', (e) => { e.preventDefault(); submitAuthForm(e.target, document.getElementById('registerError'), true); });

            // ==========================================
            // 2. GIAO DIỆN TRANG CHỦ & FETCH DỮ LIỆU
            // ==========================================
            if (isHomePage) {
                // Mobile Menu
                const mobileMenu = document.getElementById('mobileMenu');
                const mobileMenuOverlay = document.getElementById('mobileMenuOverlay');
                const toggleMobileMenu = (force) => {
                    mobileMenu.classList.toggle('open', force);
                    mobileMenuOverlay.classList.toggle('active', force);
                };

                document.getElementById('mobileMenuBtn')?.addEventListener('click', () => toggleMobileMenu(true));
                document.getElementById('closeMenu')?.addEventListener('click', () => toggleMobileMenu(false));
                mobileMenuOverlay?.addEventListener('click', () => toggleMobileMenu(false));

                // Tabs / Sections
                const sections = ['homeSection', 'newSection', 'hotSection', 'rankSection', 'completedSection', 'groupsSection', 'profilePageSection', 'detailSection'].map(id => document.getElementById(id));
                const tabs = ['tabHome', 'tabNew', 'tabHot', 'tabRank', 'tabCompleted', 'tabGroups', 'tabProfilePage'].map(id => document.getElementById(id));

                function showSection(sectionId, tabId) {
                    sections.forEach(s => s?.classList.add('hidden'));
                    tabs.forEach(t => t?.classList.remove('active'));
                    document.getElementById(sectionId)?.classList.remove('hidden');
                    if (tabId) document.getElementById(tabId)?.classList.add('active');
                }

                document.getElementById('tabHome')?.addEventListener('click', (e) => { e.preventDefault(); showSection('homeSection', 'tabHome'); });
                document.getElementById('breadcrumbHome')?.addEventListener('click', (e) => { e.preventDefault(); showSection('homeSection', 'tabHome'); });

                // Chatbox
                const chatbox = document.getElementById('chatbox');
                document.getElementById('toggleChat')?.addEventListener('click', () => {
                    chatbox?.classList.toggle('closed');
                    document.getElementById('chatIcon').className = chatbox?.classList.contains('closed') ? 'fas fa-comment' : 'fas fa-minus';
                });

                // Detail Show (Cho update list và recommend)
                function fillDetailAndShow(card) {
                    document.getElementById('detailTitle').innerText = card.dataset.title || 'Đang cập nhật';
                    document.getElementById('detailAuthor').innerText = card.dataset.author || 'Đang cập nhật';
                    document.getElementById('detailGenre').innerText = card.dataset.genre || 'Đang cập nhật';
                    document.getElementById('detailViews').innerText = card.dataset.views || '0';
                    document.getElementById('breadcrumbTitle').innerText = card.dataset.title || 'Đang cập nhật';

                    const detailCover = document.getElementById('detailCover');
                    if (card.dataset.cover) {
                        detailCover.style.cssText = `background-image: url('${card.dataset.cover}'); background-size: cover;`;
                        detailCover.innerText = '';
                    }
                    showSection('detailSection');
                }

                // Lắng nghe sự kiện click thẻ để mở popup (Trừ .top-item vì nó đã là thẻ a)
                document.addEventListener('click', (event) => {
                    if (event.target.closest('.btn-read')) return; // Bỏ qua nút đọc ngay (chuyển hướng)

                    // Lưu ý: Đã bỏ .top-item ra khỏi đây
                    const card = event.target.closest('.update-item, .recommend-card');
                    if (card) {
                        fillDetailAndShow(card);
                    }
                });

                // Format views
                function formatViews(views) {
                    const v = parseInt(views) || 0;
                    return v >= 1000 ? Math.floor(v / 1000) + 'K' : v.toString();
                }

                // Fetch data mới nhất
                async function loadHomePageData() {
                    const sliderList = document.getElementById('list_suggest');
                    try {
                        const res = await fetch('https://localhost:7267/api/stories/newest');
                        if (!res.ok) throw new Error("Lỗi gọi API: " + res.status);

                        const stories = await res.json();
                        if (!Array.isArray(stories) || stories.length === 0) {
                            if (sliderList) sliderList.innerHTML = '<li style="width:100%;text-align:center;color:#fbbf24;padding:50px;">Chưa có truyện nào!</li>';
                            return;
                        }

                        // Vẽ Slider
                        if (sliderList) {
                            sliderList.innerHTML = '';
                            stories.slice(0, 5).forEach(story => {
                                const id = story.id || story.Id;
                                const title = story.title || story.Title || 'Chưa có tên';
                                const desc = story.description || story.Description || 'Đang cập nhật...';
                                const cover = story.coverImage || story.CoverImage || 'https://via.placeholder.com/200x300';
                                const rating = story.rating || story.Rating || '5.0';
                                const views = formatViews(story.viewCount || story.ViewCount || 0);

                                const li = document.createElement('li');
                                li.className = 'suggest-slide';
                                li.style.cssText = 'flex: 0 0 100%; width: 100%; box-sizing: border-box;';
                                li.innerHTML = `
                                    <div class="featured-box" style="display:flex; align-items:center; justify-content:space-between; padding:40px; gap:30px; width:100%;">
                                        <div class="featured-info" style="flex:1; color:white;">
                                            <p class="tag-hot" style="color:#fbbf24; font-weight:bold; margin-bottom:10px;">NỔI BẬT</p>
                                            <h2 style="font-size:2.5rem; margin:0 0 15px 0;">${title}</h2>
                                            <p class="desc" style="color:#9ca3af; margin-bottom:20px; display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; overflow:hidden;">${desc}</p>
                                            <div class="stats" style="margin-bottom:25px;">
                                                <span style="margin-right:15px;">⭐ ${rating}</span>
                                                <span>👁️ ${views} lượt xem</span>
                                            </div>
                                            <a href="/Stories/Details/${id}" class="btn-read" style="display:inline-block; background-color:#3b82f6; color:white; padding:12px 32px; border-radius:20px; font-weight:bold; text-decoration:none;">Đọc ngay</a>
                                        </div>
                                        <div class="featured-cover" style="width:200px; height:300px; border-radius:12px; overflow:hidden; flex-shrink:0; background:#333;">
                                            <img src="${cover}" alt="${title}" style="width:100%; height:100%; object-fit:cover;">
                                        </div>
                                    </div>
                                `;
                                sliderList.appendChild(li);
                            });
                            setTimeout(initSlider, 100);
                        }
                    } catch (err) {
                        console.error("Lỗi tải Slider:", err);
                    }
                }

                // Fetch data Top Views
                async function loadTopViewsData() {
                    const topList = document.querySelector('.top-list');
                    if (!topList) return;

                    try {
                        const res = await fetch('https://localhost:7267/api/stories/top-views');
                        if (!res.ok) throw new Error("Lỗi API top views: " + res.status);

                        const topStories = await res.json();

                        // Xóa chữ Loading
                        const existingItems = topList.querySelectorAll('.top-item, div[style*="text-align"]');
                        existingItems.forEach(item => item.remove());

                        if (!Array.isArray(topStories) || topStories.length === 0) return;

                        topStories.slice(0, 5).forEach((story, index) => {
                            const id = story.id || story.Id;
                            const title = story.title || story.Title || 'Chưa có tên';
                            const views = story.viewCount || story.ViewCount || 0;

                            // TOP ITEM là thẻ <a> chuyển link
                            const item = document.createElement('a');
                            item.className = 'top-item';
                            item.href = `/Stories/Details/${id}`;
                            item.style.textDecoration = 'none';
                            item.style.color = 'inherit';

                            item.innerHTML = `
                                <span class="top-rank">${index + 1}</span>
                                <div class="top-info">
                                    <div class="top-title">${title}</div>
                                    <div class="top-views">${formatViews(views)}</div>
                                </div>
                            `;
                            topList.appendChild(item);
                        });
                    } catch (err) {
                        console.error("Lỗi tải Xem Nhiều Nhất:", err);
                    }
                }

                // KHỞI CHẠY API CÙNG LÚC
                async function fetchAllData() {
                    await Promise.all([
                        loadHomePageData(),
                        loadTopViewsData()
                    ]);
                }
                fetchAllData();

                // Logic Slider
                let autoPlayTimer;
                function initSlider() {
                    const track = document.getElementById('list_suggest');
                    if (!track) return;

                    const slides = track.querySelectorAll('.suggest-slide');
                    const slideCount = slides.length;
                    let currentIndex = 0;

                    function goToSlide(index) {
                        if (index >= slideCount) currentIndex = 0;
                        else if (index < 0) currentIndex = slideCount - 1;
                        else currentIndex = index;
                        track.style.transform = `translateX(-${currentIndex * 100}%)`;
                    }

                    function startAutoPlay() {
                        autoPlayTimer = setInterval(() => goToSlide(currentIndex + 1), 4000);
                    }

                    function resetAutoPlay() {
                        clearInterval(autoPlayTimer);
                        startAutoPlay();
                    }

                    document.querySelector('.slider-prev')?.addEventListener('click', () => { goToSlide(currentIndex - 1); resetAutoPlay(); });
                    document.querySelector('.slider-next')?.addEventListener('click', () => { goToSlide(currentIndex + 1); resetAutoPlay(); });

                    if(slideCount > 1) startAutoPlay();
                }
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
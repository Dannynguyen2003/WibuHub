                        <div class="hot-item"><span class="hot-rank">1</span><div class="hot-info"><h4>Bách Luyện Thành Thần</h4><p>Chapter 1295 • 193K</p></div></div>
                        <div class="hot-item"><span class="hot-rank">2</span><div class="hot-info"><h4>Đại Phụng Đa Canh Nhân</h4><p>Chapter 619 • 297K</p></div></div>
                        <div class="hot-item"><span class="hot-rank">3</span><div class="hot-info"><h4>Tinh Giáp Hôn Tướng</h4><p>Chapter 349 • 305K</p></div></div>
                        <div class="hot-item"><span class="hot-rank">4</span><div class="hot-info"><h4>Tự Kỷ Luật Ta Đầy Bất Khả...</h4><p>Chapter 200 • 280K</p></div></div>
                        <div class="hot-item"><span class="hot-rank">5</span><div class="hot-info"><h4>Solo Leveling</h4><p>Chapter 200 • 1.2M</p></div></div>
                    </div>
                    <div class="rank-content" id="rankWeek">
                        <div class="hot-item"><span class="hot-rank">1</span><div class="hot-info"><h4>One Piece</h4><p>Chapter 1090 • 980K</p></div></div>
                        <div class="hot-item"><span class="hot-rank">2</span><div class="hot-info"><h4>Dớp Dâng</h4><p>Chapter 567 • 854K</p></div></div>
                        <div class="hot-item"><span class="hot-rank">3</span><div class="hot-info"><h4>Thiên mệnh đế chủ</h4><p>Chapter 420 • 620K</p></div></div>
                    </div>
                    <div class="rank-content" id="rankMonth">
                        <div class="hot-item"><span class="hot-rank">1</span><div class="hot-info"><h4>Solo Leveling</h4><p>Chapter 200 • 1.2M</p></div></div>
                        <div class="hot-item"><span class="hot-rank">2</span><div class="hot-info"><h4>One Piece</h4><p>Chapter 1090 • 980K</p></div></div>
                        <div class="hot-item"><span class="hot-rank">3</span><div class="hot-info"><h4>Dớp Dâng</h4><p>Chapter 567 • 854K</p></div></div>
                    </div>
                </div>

                <!-- Lịch sử đọc -->
                <div class="history-card">
                    <h3>Lịch sử đọc <span class="view-all-link" style="font-size: 13px;">Xem tất cả</span></h3>
                    <div class="history-item">
                        <div class="history-cover">Ảnh</div>
                        <div class="history-info">
                            <div class="history-title">Vạn Cố Chí Tôn</div>
                            <div class="history-meta">Đọc tiếp Chapter 502 ></div>
                        </div>
                        <span class="delete-btn"><i class="fas fa-times"></i></span>
                    </div>
                    <div class="history-item">
                        <div class="history-cover">Ảnh</div>
                        <div class="history-info">
                            <div class="history-title">Bỏ Làm Simp Chúa, Ta Có Trong...</div>
                            <div class="history-meta">Đọc tiếp Chapter 278 ></div>
                        </div>
                        <span class="delete-btn"><i class="fas fa-times"></i></span>
                    </div>
                    <div class="history-item">
                        <div class="history-cover">Ảnh</div>
                        <div class="history-info">
                            <div class="history-title">One Piece</div>
                            <div class="history-meta">Đọc tiếp Chapter 2 ></div>
                        </div>
                        <span class="delete-btn"><i class="fas fa-times"></i></span>
                    </div>
                </div>

                <!-- Thể loại -->
                <div class="sidebar-card">
                    <div class="sidebar-title"><i class="fas fa-tags"></i> Thể loại</div>
                    <div class="genre-tags">
                        <span class="genre-tag">Hành động</span>
                        <span class="genre-tag">Hài hước</span>
                        <span class="genre-tag">Ngôn tình</span>
                        <span class="genre-tag">Đam mỹ</span>
                        <span class="genre-tag">Xuyên không</span>
                        <span class="genre-tag">Kiếm hiệp</span>
                        <span class="genre-tag">Khoa huyễn</span>
                        <span class="genre-tag">Trọng sinh</span>
                    </div>
                </div>
            </aside>
        </div>

        <!-- PHẦN MUA TRUYỆN -->
        <div class="purchase-section">
            <h2><i class="fas fa-gem" style="color: #f97316;"></i> Mua chương / Ủng hộ truyện</h2>
            <div class="purchase-options">
                <div class="purchase-card"><i class="fas fa-coins" style="font-size: 32px; color: #fbbf24;"></i><div class="price">10 Xu</div><p>Mua chương 126</p><button class="btn-buy" id="buyChapter" data-chapter-id="126">Mua ngay</button></div>
                <div class="purchase-card"><i class="fas fa-gem" style="font-size: 32px; color: #2563eb;"></i><div class="price">50 Xu</div><p>Ủng hộ tác giả</p><button class="btn-buy" id="donate">Ủng hộ</button></div>
                <div class="purchase-card"><i class="fas fa-crown" style="font-size: 32px; color: #f97316;"></i><div class="price">Gói VIP</div><p>Đọc không giới hạn</p><button class="btn-buy" id="vip">Đăng ký</button></div>
            </div>
        </div>

        <!-- CHATBOX AI -->
        <div class="chatbox" id="chatbox">
            <div class="chat-header" id="toggleChat"><h3><i class="fas fa-robot" style="color: #f97316;"></i> Trợ lý AI</h3><i class="fas fa-minus" id="chatIcon"></i></div>
            <div class="chat-body" id="chatBody"><div class="message ai">Xin chào! Tôi là trợ lý đọc truyện. Bạn cần tìm gì?</div></div>
            <div class="chat-footer"><input type="text" id="chatInput" placeholder="Nhập tin nhắn..."><button id="sendChat"><i class="fas fa-paper-plane"></i></button></div>
        </div>
        <form id="antiForgeryForm" style="display:none;">
            @Html.AntiForgeryToken()
        </form>
        @RenderBody()
    </div>

    <script>
        // ===== BIẾN GIẢ LẬP ĐĂNG NHẬP =====
        let isLoggedIn = false;

        // ===== MODAL AUTH =====
        const authModal = document.getElementById('authModal');
        const profileModal = document.getElementById('profileModal');
        const loginBtn = document.getElementById('loginBtn');
        const avatarBtn = document.getElementById('avatarBtn');
        const closeModal = document.getElementById('closeModal');
        const closeProfileModal = document.getElementById('closeProfileModal');
        const loginForm = document.getElementById('loginForm');
        const registerForm = document.getElementById('registerForm');
        const confirmEmailMsg = document.getElementById('confirmEmailMessage');
        const showRegister = document.getElementById('showRegister');
        const showLogin = document.getElementById('showLogin');
        const backToLogin = document.getElementById('backToLogin');
        const modalTitle = document.getElementById('modalTitle');

        function openAuthModal() { authModal.classList.add('active'); resetToLogin(); }
        function openProfileModal() { profileModal.classList.add('active'); }
        function closeAllModals() { authModal.classList.remove('active'); profileModal.classList.remove('active'); }

        avatarBtn.addEventListener('click', () => { if (isLoggedIn) openProfileModal(); else openAuthModal(); });
        loginBtn.addEventListener('click', (e) => { e.preventDefault(); if (isLoggedIn) openProfileModal(); else openAuthModal(); });
        closeModal.addEventListener('click', closeAllModals);
        closeProfileModal.addEventListener('click', closeAllModals);
        window.addEventListener('click', (e) => { if (e.target === authModal) closeAllModals(); if (e.target === profileModal) closeAllModals(); });

        function resetToLogin() { loginForm.style.display = 'block'; registerForm.style.display = 'none'; confirmEmailMsg.style.display = 'none'; modalTitle.innerText = 'Đăng nhập'; }
        showRegister.addEventListener('click', () => { loginForm.style.display = 'none'; registerForm.style.display = 'block'; confirmEmailMsg.style.display = 'none'; modalTitle.innerText = 'Đăng ký'; });
        showLogin.addEventListener('click', resetToLogin);
        backToLogin.addEventListener('click', resetToLogin);

        // ===== CAPTCHA =====
        function randomCaptcha() { let chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ0123456789', result = ''; for (let i = 0; i < 5; i++) result += chars[Math.floor(Math.random() * chars.length)]; return result; }
        document.getElementById('refreshCaptcha').addEventListener('click', function() { document.getElementById('captchaText').innerText = randomCaptcha(); });
        document.getElementById('refreshRegCaptcha').addEventListener('click', function() { document.getElementById('regCaptchaText').innerText = randomCaptcha(); });

        // ===== GIẢ LẬP ĐĂNG NHẬP =====
        document.getElementById('doLogin').addEventListener('click', function() {
            const captcha = document.getElementById('captchaText').innerText;
            const input = document.getElementById('captchaInput').value;
            if (input.toUpperCase() !== captcha) { alert('Mã captcha không đúng!'); return; }
            alert('Đăng nhập thành công! (Mô phỏng)');
            isLoggedIn = true;
            authModal.classList.remove('active');
            loginBtn.innerHTML = '<i class="far fa-user"></i> <span>Tài khoản</span>';
        });

        document.getElementById('doRegister').addEventListener('click', function() {
            const captcha = document.getElementById('regCaptchaText').innerText;
            const input = document.getElementById('regCaptchaInput').value;
            if (input.toUpperCase() !== captcha) { alert('Mã captcha không đúng!'); return; }
            const email = document.getElementById('regEmail').value;
            if (!email) { alert('Vui lòng nhập email'); return; }
            loginForm.style.display = 'none'; registerForm.style.display = 'none'; confirmEmailMsg.style.display = 'block';
            modalTitle.innerText = 'Xác nhận email';
            document.querySelector('#confirmEmailMessage strong').innerText = email || 'user@example.com';
        });

        // ===== ĐĂNG XUẤT (modal) =====
        document.getElementById('logoutBtn').addEventListener('click', function() {
            isLoggedIn = false; profileModal.classList.remove('active'); loginBtn.innerHTML = '<i class="far fa-user"></i> <span>Đăng nhập</span>'; alert('Đã đăng xuất');
        });

        // ===== PROFILE TABS (modal) =====
        const tabs = document.querySelectorAll('.profile-tab');
        const panes = document.querySelectorAll('.profile-pane');
        tabs.forEach(tab => {
            tab.addEventListener('click', () => {
                if (!tab.dataset.tab) return;
                tabs.forEach(t => t.classList.remove('active'));
                tab.classList.add('active');
                panes.forEach(pane => pane.classList.remove('active'));
                document.getElementById(`pane-${tab.dataset.tab}`).classList.add('active');
            });
        });

        // ===== MOBILE MENU =====
        const mobileMenuBtn = document.getElementById('mobileMenuBtn');
        const mobileMenu = document.getElementById('mobileMenu');
        const mobileMenuOverlay = document.getElementById('mobileMenuOverlay');
        const closeMenu = document.getElementById('closeMenu');
        function openMobileMenu() { mobileMenu.classList.add('open'); mobileMenuOverlay.classList.add('active'); }
        function closeMobileMenu() { mobileMenu.classList.remove('open'); mobileMenuOverlay.classList.remove('active'); }
        mobileMenuBtn.addEventListener('click', openMobileMenu);
        closeMenu.addEventListener('click', closeMobileMenu);
        mobileMenuOverlay.addEventListener('click', closeMobileMenu);

        // ===== CÁC SECTION =====
        const homeSection = document.getElementById('homeSection');
        const newSection = document.getElementById('newSection');
        const hotSection = document.getElementById('hotSection');
        const genreSection = document.getElementById('genreSection');
        const rankSection = document.getElementById('rankSection');
        const completedSection = document.getElementById('completedSection');
        const groupsSection = document.getElementById('groupsSection');
        const profilePageSection = document.getElementById('profilePageSection');
        const detailSection = document.getElementById('detailSection');

        const tabHome = document.getElementById('tabHome');
        const tabNew = document.getElementById('tabNew');
        const tabHot = document.getElementById('tabHot');
        const tabGenre = document.getElementById('tabGenre');
        const tabRank = document.getElementById('tabRank');
        const tabCompleted = document.getElementById('tabCompleted');
        const tabGroups = document.getElementById('tabGroups');
        const tabProfilePage = document.getElementById('tabProfilePage');

        function hideAllSections() {
            homeSection.classList.add('hidden');
            newSection.classList.add('hidden');
            hotSection.classList.add('hidden');
            genreSection.classList.add('hidden');
            rankSection.classList.add('hidden');
            completedSection.classList.add('hidden');
            groupsSection.classList.add('hidden');
            profilePageSection.classList.add('hidden');
            detailSection.classList.add('hidden');
        }

        function removeActiveTabs() {
            tabHome.classList.remove('active');
            tabNew.classList.remove('active');
            tabHot.classList.remove('active');
            tabGenre.classList.remove('active');
            tabRank.classList.remove('active');
            tabCompleted.classList.remove('active');
            tabGroups.classList.remove('active');
            tabProfilePage.classList.remove('active');
        }

        function showHome() { hideAllSections(); homeSection.classList.remove('hidden'); removeActiveTabs(); tabHome.classList.add('active'); }
        function showNew() { hideAllSections(); newSection.classList.remove('hidden'); removeActiveTabs(); tabNew.classList.add('active'); }
        function showHot() { hideAllSections(); hotSection.classList.remove('hidden'); removeActiveTabs(); tabHot.classList.add('active'); }
        function showGenre() { hideAllSections(); genreSection.classList.remove('hidden'); removeActiveTabs(); tabGenre.classList.add('active'); }
        function showRank() { hideAllSections(); rankSection.classList.remove('hidden'); removeActiveTabs(); tabRank.classList.add('active'); }
        function showCompleted() { hideAllSections(); completedSection.classList.remove('hidden'); removeActiveTabs(); tabCompleted.classList.add('active'); }
        function showGroups() { hideAllSections(); groupsSection.classList.remove('hidden'); removeActiveTabs(); tabGroups.classList.add('active'); }
        function showProfilePage() { hideAllSections(); profilePageSection.classList.remove('hidden'); removeActiveTabs(); tabProfilePage.classList.add('active'); }
        function showDetail() { hideAllSections(); detailSection.classList.remove('hidden'); removeActiveTabs(); }

        // Mặc định hiện trang chủ
        showHome();

        tabHome.addEventListener('click', (e) => { e.preventDefault(); showHome(); });
        tabNew.addEventListener('click', (e) => { e.preventDefault(); showNew(); });
        tabHot.addEventListener('click', (e) => { e.preventDefault(); showHot(); });
        tabGenre.addEventListener('click', (e) => { e.preventDefault(); showGenre(); });
        tabRank.addEventListener('click', (e) => { e.preventDefault(); showRank(); });
        tabCompleted.addEventListener('click', (e) => { e.preventDefault(); showCompleted(); });
        tabGroups.addEventListener('click', (e) => { e.preventDefault(); showGroups(); });
        tabProfilePage.addEventListener('click', (e) => { e.preventDefault(); showProfilePage(); });

        // Mobile menu items
        document.getElementById('mobileHome').addEventListener('click', (e) => { e.preventDefault(); showHome(); closeMobileMenu(); });
        document.getElementById('mobileNew').addEventListener('click', (e) => { e.preventDefault(); showNew(); closeMobileMenu(); });
        document.getElementById('mobileHot').addEventListener('click', (e) => { e.preventDefault(); showHot(); closeMobileMenu(); });
        document.getElementById('mobileGenre').addEventListener('click', (e) => { e.preventDefault(); showGenre(); closeMobileMenu(); });
        document.getElementById('mobileRank').addEventListener('click', (e) => { e.preventDefault(); showRank(); closeMobileMenu(); });
        document.getElementById('mobileCompleted').addEventListener('click', (e) => { e.preventDefault(); showCompleted(); closeMobileMenu(); });
        document.getElementById('mobileGroups').addEventListener('click', (e) => { e.preventDefault(); showGroups(); closeMobileMenu(); });
        document.getElementById('mobileProfilePage').addEventListener('click', (e) => { e.preventDefault(); if (isLoggedIn) showProfilePage(); else openAuthModal(); closeMobileMenu(); });

        // ===== SIDEBAR RANK TABS =====
        const rankTabs = document.querySelectorAll('.rank-tab');
        const rankContents = document.querySelectorAll('.rank-content');
        rankTabs.forEach(tab => {
            tab.addEventListener('click', () => {
                rankTabs.forEach(t => t.classList.remove('active'));
                tab.classList.add('active');
                rankContents.forEach(content => content.classList.remove('active'));
                document.getElementById('rank' + tab.dataset.rank.charAt(0).toUpperCase() + tab.dataset.rank.slice(1)).classList.add('active');
            });
        });

        // ===== CHATBOX =====
        const chatbox = document.getElementById('chatbox');
        const toggleChat = document.getElementById('toggleChat');
        const chatBody = document.getElementById('chatBody');
        const chatInput = document.getElementById('chatInput');
        const sendBtn = document.getElementById('sendChat');
        toggleChat.addEventListener('click', () => { chatbox.classList.toggle('closed'); document.getElementById('chatIcon').className = chatbox.classList.contains('closed') ? 'fas fa-plus' : 'fas fa-minus'; });
        function addMessage(text, sender) { const msgDiv = document.createElement('div'); msgDiv.classList.add('message', sender); msgDiv.innerText = text; chatBody.appendChild(msgDiv); chatBody.scrollTop = chatBody.scrollHeight; }
        function sendMessage() { const text = chatInput.value.trim(); if (!text) return; addMessage(text, 'user'); chatInput.value = ''; setTimeout(() => { let reply = 'Tôi là AI, tôi có thể gợi ý truyện hot hoặc tìm kiếm. Bạn muốn gì?'; if (text.toLowerCase().includes('truyện hot') || text.toLowerCase().includes('đề xuất')) reply = 'Gợi ý cho bạn: "Đại chiến thần", "Solo Leveling", "One Piece" đang rất hot!'; else if (text.includes('cảm ơn')) reply = 'Không có gì! Đọc truyện vui vẻ nhé.'; addMessage(reply, 'ai'); }, 600); }
        sendBtn.addEventListener('click', sendMessage);
        chatInput.addEventListener('keypress', (e) => { if (e.key === 'Enter') sendMessage(); });

        // ===== CÁC BUTTON TƯƠNG TÁC =====
        document.getElementById('searchBtn').addEventListener('click', function() { alert('Bạn đang tìm: "' + document.getElementById('searchInput').value + '" (Mô phỏng tìm kiếm)'); });
        document.getElementById('logo').addEventListener('click', function(e) { e.preventDefault(); showHome(); });
        document.getElementById('notificationBtn').addEventListener('click', function(e) { e.preventDefault(); alert('Bạn có 3 thông báo mới (mô phỏng)'); });
        document.getElementById('readFeaturedBtn').addEventListener('click', function() { alert('Đọc truyện "Shadow Warrior" (mô phỏng)'); });
        document.getElementById('viewAllUpdates').addEventListener('click', function() { alert('Xem tất cả truyện mới cập nhật'); });
        document.getElementById('viewMoreBtn').addEventListener('click', function() { alert('Tải thêm truyện (mô phỏng)'); });
        document.getElementById('buyChapter').addEventListener('click', async () => {
            const buyButton = document.getElementById('buyChapter');
            const chapterId = parseInt(buyButton?.dataset.chapterId || '', 10);
            const antiForgeryToken = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]')?.value;
            if (!Number.isInteger(chapterId) || chapterId <= 0) {
                alert('Không tìm thấy chương để thêm vào giỏ hàng.');
                return;
            }
            if (!antiForgeryToken) {
                alert('Không thể xác thực yêu cầu. Vui lòng tải lại trang.');
                return;
            }

            try {
                const response = await fetch('/api/cart/add', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': antiForgeryToken
                    },
                    body: JSON.stringify({ chapterId: chapterId, quantity: 1 })
                });

                if (!response.ok) {
                    throw new Error('Không thể thêm vào giỏ hàng.');
                }

                const result = await response.json();
                alert(`${result.message} Tổng sản phẩm: ${result.totalItems}`);
            } catch (error) {
                alert(error?.message || 'Đã xảy ra lỗi khi thêm vào giỏ hàng.');
            }
        });
        document.getElementById('donate').addEventListener('click', () => alert('Cảm ơn bạn đã ủng hộ! (Mô phỏng)'));
        document.getElementById('vip').addEventListener('click', () => alert('Đăng ký gói VIP thành công! (Mô phỏng)'));

        // ===== CLICK CARD TRUYỆN -> HIỂN THỊ CHI TIẾT =====
        function fillDetailAndShow(card) {
            // Lấy thông tin từ data attributes
            const title = card.dataset.title || 'Đồ Đệ Của Ta Đều Là Đại Phản Phái';
            const author = card.dataset.author || 'TruyenQQ, Mộng Tiên Giới';
            const genre = card.dataset.genre || 'Adventure - Chuyển Sinh - Cổ Đại - Manhua - Truyện Màu - Xuyên Không';
            const views = card.dataset.views || '427,480';
            // Cập nhật chi tiết
            document.getElementById('detailTitle').innerText = title;
            document.getElementById('detailAuthor').innerText = author;
            document.getElementById('detailGenre').innerText = genre;
            document.getElementById('detailViews').innerText = views;
            document.getElementById('breadcrumbTitle').innerText = title;
            // Hiển thị section chi tiết
            showDetail();
        }

        // Gán sự kiện cho các card trong mục "Truyện Mới Cập Nhật"
        document.querySelectorAll('.update-item').forEach(item => {
            item.addEventListener('click', function() {
                fillDetailAndShow(this);
            });
        });

        // Gán sự kiện cho các card trong "Xem Nhiều Nhất"
        document.querySelectorAll('.top-item').forEach(item => {
            item.addEventListener('click', function() {
                fillDetailAndShow(this);
            });
        });

        // Gán sự kiện cho các card trong "Truyện Đề Cử"
        document.querySelectorAll('.recommend-card').forEach(card => {
            card.addEventListener('click', function() {
                fillDetailAndShow(this);
            });
        });

        // Các nút xóa trong lịch sử
        document.querySelectorAll('.delete-btn').forEach(btn => {
            btn.addEventListener('click', (e) => { e.stopPropagation(); alert('Đã xóa lịch sử'); });
        });

        // Recommend tabs
        const recommendTabs = document.querySelectorAll('.recommend-tab');
        recommendTabs.forEach(tab => {
            tab.addEventListener('click', () => {
                recommendTabs.forEach(t => t.classList.remove('active'));
                tab.classList.add('active');
                alert('Chuyển tab ' + tab.innerText);
            });
        });

        // Nút chi tiết trong trang detail
        document.getElementById('followBtn').addEventListener('click', () => alert('Đã theo dõi truyện (mô phỏng)'));
        document.getElementById('readFirstBtn').addEventListener('click', () => alert('Đọc từ đầu'));
        document.getElementById('readLatestBtn').addEventListener('click', () => alert('Đọc mới nhất'));
        document.getElementById('readContinueBtn').addEventListener('click', () => alert('Đọc tiếp'));
        document.getElementById('breadcrumbHome').addEventListener('click', (e) => { e.preventDefault(); showHome(); });
        document.getElementById('breadcrumbCategory').addEventListener('click', (e) => { e.preventDefault(); showGenre(); });
    </script>
</body>
</html>

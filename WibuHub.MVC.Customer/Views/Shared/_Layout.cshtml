        const showRegisterModal = document.getElementById('showRegisterModal');
        const showLoginModal = document.getElementById('showLoginModal');

        if (loginBtn && authModal) loginBtn.addEventListener('click', (e) => { e.preventDefault(); if (registerModal) registerModal.classList.remove('active'); authModal.classList.add('active'); });
        if (registerBtn && registerModal) registerBtn.addEventListener('click', (e) => { e.preventDefault(); if (authModal) authModal.classList.remove('active'); registerModal.classList.add('active'); });
        if (closeModal && authModal) closeModal.addEventListener('click', () => authModal.classList.remove('active'));
        if (closeRegisterModal && registerModal) closeRegisterModal.addEventListener('click', () => registerModal.classList.remove('active'));
        if (showRegisterModal && registerModal && authModal) showRegisterModal.addEventListener('click', (e) => { e.preventDefault(); authModal.classList.remove('active'); registerModal.classList.add('active'); });
        if (showLoginModal && registerModal && authModal) showLoginModal.addEventListener('click', (e) => { e.preventDefault(); registerModal.classList.remove('active'); authModal.classList.add('active'); });
        window.addEventListener('click', (e) => { if (authModal && e.target === authModal) authModal.classList.remove('active'); if (registerModal && e.target === registerModal) registerModal.classList.remove('active'); });

        const loginForm = document.getElementById('loginModalForm');
        const registerForm = document.getElementById('registerModalForm');
        const loginError = document.getElementById('loginError');
        const registerError = document.getElementById('registerError');

        async function submitAuthForm(form, errorEl, isRegister = false) {
            if (!form) return;
            const formData = new FormData(form);
            const dataObject = {};
            let antiForgeryToken = '';

            formData.forEach((value, key) => {
                if (key === '__RequestVerificationToken') antiForgeryToken = value;
                else dataObject[key] = value;
            });

            if (errorEl) { errorEl.classList.remove('active'); errorEl.textContent = ''; }

            try {
                const response = await fetch(form.action, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': antiForgeryToken },
                    body: JSON.stringify(dataObject)
                });

                let payload = {};
                try { payload = await response.json(); } catch(e){}

                if (response.ok && payload.success) {
                    if (isRegister) {
                        if (registerModal) registerModal.classList.remove('active');
                        if (authModal) {
                            authModal.classList.add('active');
                            if (loginError) {
                                loginError.textContent = payload.message || 'Đăng ký thành công! Vui lòng đăng nhập.';
                                loginError.classList.add('active');
                                loginError.style.backgroundColor = '#d4edda';
                                loginError.style.color = '#155724';
                            }
                        }
                        return;
                    }
                    if (payload.redirectUrl) window.location.href = payload.redirectUrl;
                    else window.location.reload();
                    return;
                }

                if (errorEl) { errorEl.textContent = payload?.message || 'Thông tin không hợp lệ.'; errorEl.classList.add('active'); }
            } catch (error) {
                if (errorEl) { errorEl.textContent = 'Mất kết nối tới máy chủ.'; errorEl.classList.add('active'); }
            }
        }

        if (loginForm) loginForm.addEventListener('submit', (e) => { e.preventDefault(); submitAuthForm(loginForm, loginError, false); });
        if (registerForm) registerForm.addEventListener('submit', (e) => { e.preventDefault(); submitAuthForm(registerForm, registerError, true); });


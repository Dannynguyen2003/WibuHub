@using Microsoft.AspNetCore.Identity
@using WibuHub.ApplicationCore.Entities.Identity
@using WibuHub.Service.Interface
@inject SignInManager<StoryUser> SignInManager
@inject UserManager<StoryUser> UserManager
@inject ICategoryService CategoryService

@{
    var returnUrl = Url.Action("Index", "Home", new { area = "" }) ?? "/";
    var externalSchemes = (await SignInManager.GetExternalAuthenticationSchemesAsync()).ToList();
    var categories = await CategoryService.GetAllAsync();
    var categoryColumnCount = categories.Count == 0 ? 1 : 4;
    var categoriesPerColumn = categories.Count > 0
      ? (int)Math.Ceiling(categories.Count / (double)categoryColumnCount)
      : 0;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Good Stories - WibuHub</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true">

    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="preloader-active intro-304-done">
    @{
        var isHomePage = string.Equals(ViewContext.RouteData.Values["controller"]?.ToString(), "Home", StringComparison.OrdinalIgnoreCase)
        && string.Equals(ViewContext.RouteData.Values["action"]?.ToString(), "Index", StringComparison.OrdinalIgnoreCase);
        var isIdentityArea = string.Equals(ViewContext.RouteData.Values["area"]?.ToString(), "Identity", StringComparison.OrdinalIgnoreCase);
    }
    @if (isHomePage)
    {
        <div id="intro304" class="intro-304-overlay" aria-hidden="true">
            <div class="intro-304-content">
                <span class="intro-304-star">🇻🇳</span>
                <div class="intro-304-title">Chao mung Dai le 30/4</div>
                <div class="intro-304-subtitle">Thong nhat dat nuoc - Truyen cam hung den moi trang truyen</div>
            </div>
        </div>
    }

    <div class="app" style="width:100%;max-width:none;margin:0;padding:10px 0 0;">
        <header class="header" style="width:calc(100% - 24px);max-width:none;margin:0 12px 10px;">
            <div class="logo-area">
                <button class="mobile-menu-btn" id="mobileMenuBtn"><i class="fas fa-bars"></i></button>
                <a asp-controller="Home" asp-action="Index" asp-area="" class="logo" id="logo">WIBU<span>HUB</span></a>
            </div>

            <div class="search-wrapper">

                <div class="search-bar">
                    <input type="text" placeholder="Search stories" id="searchInput" autocomplete="off">
                    <button id="searchBtn"><i class="fas fa-search"></i></button>
                </div>

                <div id="searchSuggestions" style="display: none;"></div>

            </div>

            <div class="user-actions">
                <button type="button" id="themeToggleBtn" aria-label="Toggle 30-4 theme" title="Bat/tat theme 30/4"><i class="fas fa-palette"></i></button>

                @if (User?.Identity?.IsAuthenticated ?? false)
                {
                    <div class="notification-wrapper" style="position: relative; display: inline-block;">
                        <a href="#" id="notificationBtn">
                            <i class="far fa-bell"></i>
                            <span class="d-none d-md-inline">Notifications</span>
                            <span id="notiBadge" style="position: absolute; top: -5px; right: -5px; background: #ef4444; color: white; border-radius: 50%; padding: 2px 6px; font-size: 0.7rem; font-weight: bold; display: none;">0</span>
                        </a>

                        <div id="notificationDropdown" class="dropdown-menu notification-dropdown" style="display: none; position: absolute; top: 100%; right: 0; width: 320px; max-height: 400px; overflow-y: auto; background: white; border: 1px solid #e5e7eb; border-radius: 8px; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); z-index: 1000; padding: 0;">
                            <div style="padding: 10px 15px; border-bottom: 1px solid #e5e7eb; display: flex; justify-content: space-between; align-items: center;">
                                <strong style="color: #1f2937;">New Notifications</strong>
                                <div style="display: flex; gap: 10px; align-items: center;">
                                    <button id="deleteReadBtn" style="background: none; border: none; color: #ef4444; font-size: 0.85rem; cursor: pointer;">Delete read</button>
                                    <button id="markAllReadBtn" style="background: none; border: none; color: #3b82f6; font-size: 0.85rem; cursor: pointer;">Mark all as read</button>
                                </div>
                            </div>
                            <ul id="notificationList" style="list-style: none; padding: 0; margin: 0;">
                                <li style="padding: 20px; text-align: center; color: #9ca3af;">Loading...</li>
                            </ul>
                        </div>
                    </div>
                }

                <a href="/ShoppingCart/Cart" id="cartBtn"><i class="fas fa-shopping-cart"></i> <span class="d-none d-md-inline">Cart</span></a>

                @if (User?.Identity?.IsAuthenticated ?? false)
                {
                    var currentUser = await UserManager.GetUserAsync(User);
                    var avatarUrl = currentUser?.Avatar;
                    if (string.IsNullOrEmpty(avatarUrl))
                    {
                        avatarUrl = "https://ui-avatars.com/api/?name=" + (currentUser?.UserName ?? "User") + "&background=E2E8F0&color=475569";
                    }

                    // Add VIP check logic
                    bool isVip = currentUser?.IsVip ?? false;

                    <div class="user-account">
                        <div class="avatar-wrapper @(isVip ? "is-vip" : "")" style="position: relative;">
                            <img src="@avatarUrl" alt="Avatar" class="avatar-icon" style="@(isVip ? "border-radius: 50%; width: 40px; height: 40px; object-fit: cover;" : "")">
                            @if (isVip)
                            {
                                <span class="vip-crown-badge" title="VIP Account"><i class="fas fa-crown"></i></span>
                            }
                        </div>

                        <ul class="dropdown-menu">
                            <li class="user-info-header" style="padding: 10px 15px; border-bottom: 1px solid #eee; margin-bottom: 5px;">
                                <strong>@currentUser?.UserName</strong>
                                <div style="font-size: 0.85rem; color: #666;">Coins: <span style="color: #f59e0b; font-weight: bold;">@currentUser?.Points <i class="fas fa-coins"></i></span></div>
                            </li>
                            <li>
                                <a href="/vip/upgrade" class="btn-upgrade-vip @(isVip ? "vip-active" : "")">
                                    <i class="fas fa-gem"></i> @(isVip ? "Renew VIP" : "Upgrade VIP")
                                </a>
                            </li>
                            @if (isVip && currentUser?.VipExpireDate.HasValue == true)
                            {
                                <li style="padding: 0 15px 10px; font-size: 0.8rem; color: #10b981; text-align: center;">
                                    VIP Expiry: @currentUser.VipExpireDate.Value.ToLocalTime().ToString("dd/MM/yyyy")
                                </li>
                            }
                            <li class="divider"></li>

                            <li><a asp-controller="CustomerProfile" asp-action="Followed"><i class="fas fa-bookmark"></i> Following List</a></li>
                            <li><a asp-controller="CustomerProfile" asp-action="History"><i class="fas fa-history"></i> Reading History</a></li>
                            <li><a asp-controller="ShoppingCart" asp-action="Orders"><i class="fas fa-receipt"></i> Purchased Orders</a></li>
                            <li><a asp-controller="ShoppingCart" asp-action="PurchasedStories"><i class="fas fa-book-open"></i> Purchased Stories</a></li>
                            <li><a asp-controller="CustomerProfile" asp-action="Index"><i class="fas fa-cog"></i> Account Settings</a></li>
                            <li class="divider"></li>
                            <li>
                                <form class="logout-form" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" style="margin: 0;">
                                    <button type="submit" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Logout</button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <a href="#" id="loginBtn"><i class="far fa-user"></i> <span class="d-none d-md-inline">Login</span></a>
                    <a href="#" id="registerBtn"><i class="fas fa-user-plus"></i> <span class="d-none d-md-inline">Register</span></a>
                }
            </div>
        </header>

        <div id="authModal" class="modal">
            <div class="modal-content">
                <span class="modal-close" id="closeModal">&times;</span>
                <div class="modal-title">Login</div>
                <form id="loginModalForm" action="/api/auth/login" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <div class="form-error" id="loginError"></div>
                    <div class="input-group">
                        <label>Email</label>
                        <input type="email" name="email" autocomplete="username" placeholder="your@gmail.com" required>
                    </div>
                    <div class="input-group">
                        <label>Password</label>
                        <div style="position: relative; display: flex; align-items: center;">
                            <input id="loginModalPassword" type="password" name="password" autocomplete="current-password" placeholder="••••••••" data-password-field="customer-login-password" style="padding-right: 40px;" required>
                            <button type="button" data-password-toggle="customer-login-password" style="position: absolute; right: 10px; background: transparent; border: none; cursor: pointer; color: #a0aec0; padding: 0; display: flex; align-items: center; justify-content: center;" aria-label="Toggle password visibility">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                            </button>
                        </div>
                    </div>
                    <div class="login-meta">
                        <label class="remember-me"><input type="checkbox" name="rememberMe"> Remember me?</label>
                        <a href="#" id="showForgotModal" class="forgot-link">Forgot password?</a>
                    </div>
                    <button class="btn" type="submit">LOGIN</button>
                    <div class="switch-link">
                        Don't have an account? <a href="#" id="showRegisterModal">Register now</a>
                    </div>
                    @if (externalSchemes.Count > 0)
                    {
                        <div class="external-auth">
                            <div class="external-title">Or login with</div>
                            <div class="external-buttons">
                                @foreach (var scheme in externalSchemes)
                                {
                                    <button type="submit" name="provider" value="@scheme.Name" formmethod="post" formaction="@Url.Page("/Account/ExternalLogin", new { area = "Identity", returnUrl })" class="btn-auth">
                                        @scheme.DisplayName
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </form>
            </div>
        </div>

        <div id="registerModal" class="modal">
            <div class="modal-content">
                <span class="modal-close" id="closeRegisterModal">&times;</span>
                <div class="modal-title">Register</div>
                <form id="registerModalForm" action="/api/auth/register" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <div class="form-error" id="registerError"></div>
                    <div class="input-group">
                        <label>Email</label>
                        <input type="email" name="email" autocomplete="username" placeholder="your@email.com" required>
                    </div>
                    <div class="input-group">
                        <label>Password</label>
                        <div style="position: relative; display: flex; align-items: center;">
                            <input id="registerModalPassword" type="password" name="password" autocomplete="new-password" placeholder="••••••••" data-password-field="customer-register-password" style="padding-right: 40px;" required>
                            <button type="button" data-password-toggle="customer-register-password" style="position: absolute; right: 10px; background: transparent; border: none; cursor: pointer; color: #a0aec0; padding: 0; display: flex; align-items: center; justify-content: center;" aria-label="Toggle password visibility">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                            </button>
                        </div>
                    </div>
                    <div class="input-group">
                        <label>Confirm Password</label>
                        <div style="position: relative; display: flex; align-items: center;">
                            <input id="registerModalConfirmPassword" type="password" name="confirmPassword" autocomplete="new-password" placeholder="••••••••" data-password-field="customer-register-confirm-password" style="padding-right: 40px;" required>
                            <button type="button" data-password-toggle="customer-register-confirm-password" style="position: absolute; right: 10px; background: transparent; border: none; cursor: pointer; color: #a0aec0; padding: 0; display: flex; align-items: center; justify-content: center;" aria-label="Toggle password visibility">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                            </button>
                        </div>
                    </div>
                    <button class="btn" type="submit">REGISTER</button>
                    <div class="switch-link">
                        Already have an account? <a href="#" id="showLoginModal">Login</a>
                    </div>
                    @if (externalSchemes.Count > 0)
                    {
                        <div class="external-auth">
                            <div class="external-title">Or register with</div>
                            <div class="external-buttons">
                                @foreach (var scheme in externalSchemes)
                                {
                                    <button type="submit" name="provider" value="@scheme.Name" formmethod="post" formaction="@Url.Page("/Account/ExternalLogin", new { area = "Identity", returnUrl })" class="btn-auth">
                                        @scheme.DisplayName
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </form>
            </div>
        </div>

        <div id="forgotModal" class="modal">
            <div class="modal-content">
                <span class="modal-close" id="closeForgotPasswordModal">&times;</span>
                <div class="modal-title">Forgot Password</div>
                <form id="forgotModalForm" action="/api/auth/forgot-password" method="post">
                    @Html.AntiForgeryToken()
                    <div class="form-error" id="forgotError"></div>
                    <div class="input-group">
                        <label>Email</label>
                        <input type="email" name="email" autocomplete="username" placeholder="your@email.com" required>
                    </div>
                    <button class="btn" type="submit">SEND RESET LINK</button>
                    <div class="switch-link">
                        Remembered your password? <a href="#" id="showLoginFromForgot">Login</a>
                    </div>
                </form>
            </div>
        </div>

        @if (isHomePage)
        {
            <div class="mobile-menu-overlay" id="mobileMenuOverlay"></div>
            <div class="mobile-menu" id="mobileMenu">
                <div class="mobile-menu-header">
                    <span class="mobile-menu-logo">GOOD<span>STORIES</span></span>
                    <span class="close-menu" id="closeMenu"><i class="fas fa-times"></i></span>
                </div>
                <a asp-controller="Home" asp-action="Index" asp-area="" class="mobile-menu-item active" id="mobileHome"><i class="fas fa-home"></i> Home</a>
                <a asp-controller="Categories" asp-action="Index" asp-route-id="" class="mobile-menu-item" id="mobileGenre"><i class="fas fa-tags"></i> Categories</a>
                <a href="#" class="mobile-menu-item" id="mobileRank"><i class="fas fa-crown"></i> Rankings</a>
                <a href="https://docs.google.com/forms/d/e/1FAIpQLSc3gIauY8q3Ta_McAnlhNVwAw8YLV_paFi7BQdL8Tr9LTYdow/viewform?usp=dialog" target="_blank" rel="noopener noreferrer" class="mobile-menu-item" id="mobileGroups"><i class="fas fa-users"></i> Translation Requests</a>
            </div>
        }

        <nav class="nav-tabs" style="width:calc(100% - 24px);max-width:none;margin:0 12px 18px;">
            <a class="nav-item active" id="tabHome" asp-controller="Home" asp-action="Index" asp-area="">Home</a>
            <div class="nav-dropdown">
                <span class="nav-item nav-item-static" id="tabGenre">Categories <i class="fas fa-chevron-down"></i></span>
                <div class="genre-dropdown">
                    <div class="genre-column">
                        <a class="genre-link genre-link-all" asp-controller="Categories" asp-action="Index" asp-route-id="">All</a>
                        @foreach (var category in categories.Take(categoriesPerColumn))
                        {
                            <a class="genre-link" asp-controller="Categories" asp-action="Index" asp-route-id="@category.Id">@category.Name</a>
                        }
                    </div>
                    @for (var columnIndex = 1; columnIndex < categoryColumnCount; columnIndex++)
                    {
                        var columnCategories = categories.Skip(columnIndex * categoriesPerColumn).Take(categoriesPerColumn).ToList();
                        <div class="genre-column">
                            @foreach (var category in columnCategories)
                            {
                                <a class="genre-link" asp-controller="Categories" asp-action="Index" asp-route-id="@category.Id">@category.Name</a>
                            }
                        </div>
                    }
                </div>
            </div>
            <div class="nav-dropdown nav-dropdown-rank">
                <span class="nav-item nav-item-static" id="tabRank">Rankings <i class="fas fa-chevron-down"></i></span>
                <div class="rank-dropdown">
                    <a class="rank-link" asp-controller="Rankings" asp-action="Index" asp-route-type="top-day">Top Day</a>
                    <a class="rank-link" asp-controller="Rankings" asp-action="Index" asp-route-type="top-week">Top Week</a>
                    <a class="rank-link" asp-controller="Rankings" asp-action="Index" asp-route-type="top-month">Top Month</a>
                    <a class="rank-link" asp-controller="Rankings" asp-action="Index" asp-route-type="favorites">Favorites</a>
                    <a class="rank-link" asp-controller="Rankings" asp-action="Index" asp-route-type="latest">Recently Updated</a>
                    <a class="rank-link" asp-controller="Rankings" asp-action="Index" asp-route-type="new">New Stories</a>
                    <a class="rank-link" asp-controller="Rankings" asp-action="Index" asp-route-type="full">Completed</a>
                    <a class="rank-link" asp-controller="Rankings" asp-action="Index" asp-route-type="random">Random</a>
                </div>
            </div>
            <a class="nav-item" id="tabGroups" href="https://docs.google.com/forms/d/e/1FAIpQLSc3gIauY8q3Ta_McAnlhNVwAw8YLV_paFi7BQdL8Tr9LTYdow/viewform?usp=dialog" target="_blank" rel="noopener noreferrer">Translation Requests</a>
        </nav>

        @if (isHomePage)
        {
            <div class="main-grid">
                <div>
                    <div id="homeSection" class="content-section">
                        <div class="suggest-slider-wrapper">
                            <button class="slider-nav-btn slider-prev"><i class="fas fa-chevron-left"></i></button>

                            <ul id="list_suggest">
                                <li style="flex: 0 0 100%; width: 100%; text-align: center; color: #9ca3af; font-size: 1.1rem; padding: 50px 0;">
                                    <i class="fas fa-spinner fa-spin"></i> Loading Featured data...
                                </li>
                            </ul>

                            <button class="slider-nav-btn slider-next"><i class="fas fa-chevron-right"></i></button>
                        </div>

                        <div class="home-grid">
                            <div>
                                <div>
                                    <div class="section-header" style="margin-top: 30px;">
                                        <h2>Recently Updated</h2>
                                        <div class="recommend-tabs">
                                            <span class="recommend-tab active" data-recommend="all">All</span>
                                            <span class="recommend-tab" data-recommend="popular">Popular</span>
                                            <span class="recommend-tab" data-recommend="latest">Latest</span>
                                        </div>
                                    </div>
                                    <div class="recommend-grid" id="recommendAll"></div>

                                    <div style="text-align: center; margin: 30px 0;">
                                        <a class="view-more-btn" id="viewMoreBtn" style="cursor: pointer;">Load More Stories <i class="fas fa-chevron-down"></i></a>
                                    </div>
                                </div>
                            </div>

                            <div>
                                <div class="top-list">
                                    <div class="section-header">
                                        <h2>Most Viewed</h2>
                                    </div>
                                    <div class="top-list-loading" style="text-align: center; padding: 20px; color: #9ca3af;">
                                        <i class="fas fa-spinner fa-spin"></i> Loading...
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div id="newSection" class="content-section hidden"><h2>Recently Updated</h2></div>
                    <div id="hotSection" class="content-section hidden"><h2>Hottest Content</h2></div>
                    <div id="rankSection" class="content-section hidden"><h2>Rankings Content</h2></div>
                    <div id="groupsSection" class="content-section hidden"><h2>Translation Groups</h2></div>
                    <div id="detailSection" class="content-section hidden"></div>
                </div>

                <aside class="sidebar">
                    <div class="sidebar-card">
                        <div class="sidebar-title"><i class="fas fa-tags"></i> Categories</div>
                        <div class="genre-tags">
                            @foreach (var category in categories)
                            {
                                <a class="genre-tag" asp-controller="Categories" asp-action="Index" asp-route-id="@category.Id">@category.Name</a>
                            }
                        </div>
                    </div>
                </aside>
            </div>

            <div class="chatbox" id="chatbox">
                <div class="chat-header" id="toggleChat">
                    <h3><i class="fas fa-robot" style="color: #f97316;"></i> AI Assistant</h3>
                    <i class="fas fa-minus" id="chatIcon"></i>
                </div>
                <div class="chat-body" id="chatBody">
                    <div class="message ai">Hello! I am the WibuHub AI Assistant. What story do you want to find today?</div>
                </div>
                <div class="chat-footer">
                    <input type="text" id="chatInput" placeholder="Type a message...">
                    <button id="sendChat"><i class="fas fa-paper-plane"></i></button>
                </div>
            </div>
        }
        @RenderBody()
    </div>

    <script>
        // ----------------------------------------------------
        // UTILITIES: Shared utility functions
        // ----------------------------------------------------
        const Utils = {
            formatViews: (views) => {
                const v = parseInt(views, 10) || 0;
                return v >= 1000 ? (v / 1000).toFixed(1) + 'K' : v.toString();
            },

            buildStoryCardHTML: (story) => {
                const id = story.id || story.Id;
                const title = story.title || story.Title || 'Updating';
                const cover = story.coverImage || story.CoverImage || 'https://via.placeholder.com/200x300';
                const timeTag = story.timeAgo || story.TimeAgo || 'Just updated';
                const views = parseInt(story.viewCount || story.ViewCount || 0, 10);
                const isHot = story.isHot || story.IsHot || (views > 1000);

                let chapterText = 'Updating';
                const totalChap = story.totalChapters ?? story.TotalChapters ?? 0;
                if (totalChap > 0) chapterText = 'Chapter ' + totalChap;

                return `
                    <div class="recommend-card" style="cursor: default;" data-title="${title}" data-cover="${cover}" data-views="${Utils.formatViews(views)}">
                        <div class="tq-card-cover" style="position: relative; overflow: hidden; border-radius: 12px;">
                            <a href="/Stories/Details/${id}">
                                <img src="${cover}" alt="${title}" loading="lazy" style="width: 100%; aspect-ratio: 2/3; object-fit: cover; display: block;">
                            </a>
                            <div class="tq-badges">
                                <span class="tq-time">${timeTag}</span>
                                ${isHot ? '<span class="tq-hot">Hot</span>' : ''}
                            </div>
                            <div class="tq-bookmark"><i class="fas fa-bookmark"></i></div>
                        </div>
                        <div class="tq-card-info" style="text-align: center; padding: 10px 5px;">
                            <h3 class="tq-title" style="margin: 0; font-size: 1rem; line-height: 1.4; height: 2.8em; overflow: hidden;">
                                <a href="/Stories/Details/${id}" style="text-decoration: none; color: #1f2937; font-weight: 600;">${title}</a>
                            </h3>
                            <div class="last_chapter" style="margin-top: 4px;">
                                <a href="/Stories/Details/${id}" title="${chapterText}" style="text-decoration: none; color: #6b7280; font-size: 0.85rem;">
                                    ${chapterText}
                                </a>
                            </div>
                        </div>
                    </div>
                `;
            },

            fetchAPI: async (url) => {
                const res = await fetch(url);
                if (!res.ok) throw new Error(`API Error: ${res.status}`);
                return await res.json();
            }
        };

        // ----------------------------------------------------
        // SEARCH CONTROLLER: Handle Search & Live Search
        // ----------------------------------------------------
        const SearchController = {
            init: function() {
                const searchInput = document.getElementById('searchInput');
                const searchBtn = document.getElementById('searchBtn');
                const suggestBox = document.getElementById('searchSuggestions');
                let debounceTimer = null;

                if (!searchInput || !searchBtn || !suggestBox) return;

                // Handle key press
                searchInput.addEventListener('input', (e) => {
                    clearTimeout(debounceTimer);
                    const keyword = e.target.value.trim();

                    if (keyword.length === 0) {
                        suggestBox.style.display = 'none';
                        return;
                    }

                    // Temporary set background to black and show Searching text
                    suggestBox.className = 'search_result';
                    suggestBox.innerHTML = '<div style="padding: 15px; text-align: center; color: #9ca3af;"><i class="fas fa-spinner fa-spin"></i> Searching...</div>';
                    suggestBox.style.display = 'block';

                    debounceTimer = setTimeout(async () => {
                        try {
                            const response = await fetch(`http://localhost:5136/api/stories/search-suggest?q=${encodeURIComponent(keyword)}`);
                            const data = await response.json();

                            this.renderSuggestions(data, keyword);
                        } catch (error) {
                            console.error("Error loading suggestions:", error);
                            suggestBox.innerHTML = '<div style="padding: 15px; text-align: center; color: #ef4444;">Connection error</div>';
                        }
                    }, 300);
                });

                // Hide suggestion box when click outside
                document.addEventListener('click', (e) => {
                    if (!searchInput.contains(e.target) && !suggestBox.contains(e.target)) {
                        suggestBox.style.display = 'none';
                    }
                });

                // Show suggestion box again when focus
                searchInput.addEventListener('focus', () => {
                    if (searchInput.value.trim().length > 0 && suggestBox.innerHTML !== '') {
                        suggestBox.style.display = 'block';
                    }
                });

                const submitSearch = async () => {
                    const keyword = searchInput.value.trim();
                    if (!keyword) {
                        searchInput.focus();
                        return;
                    }

                    try {
                        const response = await fetch(`http://localhost:5136/api/stories/search-suggest?q=${encodeURIComponent(keyword)}`);
                        const data = await response.json();

                        this.renderSuggestions(data, keyword);

                        suggestBox.style.display = 'block';
                    } catch (error) {
                        console.error("Search error:", error);
                        suggestBox.className = 'search_result';
                        suggestBox.innerHTML = '<div style="padding: 15px; text-align: center; color: #ef4444;">Connection error</div>';
                        suggestBox.style.display = 'block';
                    }
                };

                searchBtn.addEventListener('click', (e) => {
                    e.preventDefault();
                    submitSearch();
                });

                searchInput.addEventListener('keypress', (e) => {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        submitSearch();
                    }
                });
            },

            // Render HTML to UL > LI > A structure
            renderSuggestions: function(data, keyword) {
                const suggestBox = document.getElementById('searchSuggestions');
                suggestBox.className = 'search_result';
                suggestBox.innerHTML = '';

                if (!data || data.length === 0) {
                    suggestBox.innerHTML = '<div style="padding: 15px; text-align: center; color: #9ca3af;">No stories found</div>';
                    return;
                }

                const escapeRegExp = (string) => string.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
                const regex = new RegExp(`(${escapeRegExp(keyword)})`, 'gi');

                let html = '<ul>';

                data.forEach(item => {
                    const cover = item.coverImage || 'https://via.placeholder.com/50x70';
                    const highlightedTitle = item.title.replace(regex, '<strong style="color: #f97316;">$1</strong>');

                    const categoryText = Array.isArray(item.categories) && item.categories.length > 0
                        ? item.categories.join(', ')
                        : 'No categories';

                    let chapterText = 'No chapters yet';
                    if (item.latestChapterLabel && item.latestChapterLabel.trim() !== '') {
                        chapterText = item.latestChapterLabel;
                    } else if (item.latestChapter !== null && item.latestChapter !== undefined) {
                        chapterText = `Chapter ${item.latestChapter}`;
                    }

                    html += `
                        <li>
                            <a href="/Stories/Details/${item.id}">
                                <div class="search_avatar">
                                    <img src="${cover}" alt="${item.title}">
                                </div>
                                <div class="search_info">
                                    <p class="name">${highlightedTitle}</p>
                                    <p class="name_other">${categoryText}</p>
                                    <p>${chapterText}</p>
                                </div>
                                <div style="clear: both;"></div>
                            </a>
                        </li>
                    `;
                });

                html += '</ul>';
                suggestBox.innerHTML = html;
            }
        };

        // ----------------------------------------------------
        // AUTH CONTROLLER: Handle Login / Register
        // ----------------------------------------------------
        const AuthController = {
            modals: {
                auth: document.getElementById('authModal'),
                register: document.getElementById('registerModal'),
                forgot: document.getElementById('forgotModal')
            },
            init: function() {
                const toggles = [
                    { btn: 'loginBtn', show: this.modals.auth, hide: this.modals.register },
                    { btn: 'registerBtn', show: this.modals.register, hide: this.modals.auth },
                    { btn: 'showRegisterModal', show: this.modals.register, hide: this.modals.auth },
                    { btn: 'showLoginModal', show: this.modals.auth, hide: this.modals.register },
                    { btn: 'showForgotModal', show: this.modals.forgot, hide: this.modals.auth },
                    { btn: 'showLoginFromForgot', show: this.modals.auth, hide: this.modals.forgot }
                ];

                toggles.forEach(t => {
                    const el = document.getElementById(t.btn);
                    if (el) el.addEventListener('click', (e) => {
                        e.preventDefault();
                        this.modals.auth?.classList.remove('active');
                        this.modals.register?.classList.remove('active');
                        this.modals.forgot?.classList.remove('active');
                        if (t.show) t.show.classList.add('active');
                    });
                });

                document.querySelectorAll('.modal-close').forEach(btn => {
                    btn.addEventListener('click', () => {
                        this.modals.auth?.classList.remove('active');
                        this.modals.register?.classList.remove('active');
                        this.modals.forgot?.classList.remove('active');
                    });
                });

                window.addEventListener('click', (e) => {
                    if (e.target === this.modals.auth) this.modals.auth.classList.remove('active');
                    if (e.target === this.modals.register) this.modals.register.classList.remove('active');
                    if (e.target === this.modals.forgot) this.modals.forgot.classList.remove('active');
                });

                document.getElementById('loginModalForm')?.addEventListener('submit', (e) => this.submitForm(e, false));
                document.getElementById('registerModalForm')?.addEventListener('submit', (e) => this.submitForm(e, true));
                document.getElementById('forgotModalForm')?.addEventListener('submit', (e) => this.submitForgotForm(e));
                this.initPasswordToggles();
            },
            initPasswordToggles: function() {
                document.querySelectorAll('[data-password-toggle]').forEach(button => {
                    button.addEventListener('click', () => {
                        const fieldName = button.getAttribute('data-password-toggle');
                        const input = fieldName ? document.querySelector('[data-password-field="' + fieldName + '"]') : null;
                        if (!input) return;

                        const isPassword = input.type === 'password';
                        input.type = isPassword ? 'text' : 'password';

                        if (isPassword) {
                            button.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>';
                        } else {
                            button.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>';
                        }
                    });
                });
            },
            submitForm: async function(e, isRegister) {
                e.preventDefault();
                const form = e.target;
                const errorEl = document.getElementById(isRegister ? 'registerError' : 'loginError');
                if (errorEl) { errorEl.classList.remove('active'); errorEl.textContent = ''; errorEl.style.cssText = ''; }

                const formData = new FormData(form);
                const dataObject = Object.fromEntries(formData.entries());
                if (!isRegister) {
                    dataObject.rememberMe = form.querySelector('input[name="rememberMe"]').checked;
                }

                try {
                    const response = await fetch(form.action, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': dataObject['__RequestVerificationToken']
                        },
                        body: JSON.stringify(dataObject)
                    });
                    const payload = await response.json().catch(() => ({}));

                    if (response.ok && payload.success) {
                        if (isRegister) {
                            this.modals.register.classList.remove('active');
                            this.modals.auth.classList.add('active');
                            const loginErr = document.getElementById('loginError');
                            if (loginErr) {
                                loginErr.textContent = payload.message || 'Registration successful! Please login.';
                                loginErr.classList.add('active');
                                loginErr.style.cssText = 'background-color: #d4edda; color: #155724;';
                            }
                        } else {
                            window.location.href = payload.redirectUrl || window.location.href;
                        }
                    } else {
                        if (errorEl) { errorEl.textContent = payload.message || 'Invalid information.'; errorEl.classList.add('active'); }
                    }
                } catch (error) {
                    if (errorEl) { errorEl.textContent = 'Disconnected from server.'; errorEl.classList.add('active'); }
                }
            },
            submitForgotForm: async function(e) {
                e.preventDefault();
                const form = e.target;
                const errorEl = document.getElementById('forgotError');
                if (errorEl) { errorEl.classList.remove('active'); errorEl.textContent = ''; errorEl.style.cssText = ''; }

                const formData = new FormData(form);
                const dataObject = Object.fromEntries(formData.entries());

                try {
                    const response = await fetch(form.action, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': dataObject['__RequestVerificationToken']
                        },
                        body: JSON.stringify(dataObject)
                    });
                    const payload = await response.json().catch(() => ({}));

                    if (response.ok && payload.success) {
                        if (errorEl) {
                            errorEl.textContent = payload.message || 'If the email exists, a reset link has been sent.';
                            errorEl.classList.add('active');
                            errorEl.style.cssText = 'background-color: #d4edda; color: #155724;';
                        }
                        form.reset();
                    } else {
                        if (errorEl) { errorEl.textContent = payload.message || 'Invalid information.'; errorEl.classList.add('active'); }
                    }
                } catch (error) {
                    if (errorEl) { errorEl.textContent = 'Disconnected from server.'; errorEl.classList.add('active'); }
                }
            }
        };


    <script>
        const isHomePage = document.getElementById('homeSection') !== null;
        const isAuthenticated = @((User?.Identity?.IsAuthenticated ?? false).ToString().ToLower());
        const loginUrl = '@Url.Page("/Account/Login", new { area = "Identity" })';
        const authModal = document.getElementById('authModal');
        const loginBtn = document.getElementById('loginBtn');
        const closeModal = document.getElementById('closeModal');
        const registerModal = document.getElementById('registerModal');
        const registerBtn = document.getElementById('registerBtn');
        const closeRegisterModal = document.getElementById('closeRegisterModal');
        const showRegisterModal = document.getElementById('showRegisterModal');
        const showLoginModal = document.getElementById('showLoginModal');

        if (loginBtn && authModal) {
            loginBtn.addEventListener('click', (e) => {
                e.preventDefault();
                if (registerModal) {
                    registerModal.classList.remove('active');
                }
                authModal.classList.add('active');
            });
        }

        if (registerBtn && registerModal) {
            registerBtn.addEventListener('click', (e) => {
                e.preventDefault();
                if (authModal) {
                    authModal.classList.remove('active');
                }
                registerModal.classList.add('active');
            });
        }

        if (closeModal && authModal) {
            closeModal.addEventListener('click', () => authModal.classList.remove('active'));
        }

        if (closeRegisterModal && registerModal) {
            closeRegisterModal.addEventListener('click', () => registerModal.classList.remove('active'));
        }

        if (showRegisterModal && registerModal && authModal) {
            showRegisterModal.addEventListener('click', (e) => {
                e.preventDefault();
                authModal.classList.remove('active');
                registerModal.classList.add('active');
            });
        }

        if (showLoginModal && registerModal && authModal) {
            showLoginModal.addEventListener('click', (e) => {
                e.preventDefault();
                registerModal.classList.remove('active');
                authModal.classList.add('active');
            });
        }

        const urlParams = new URLSearchParams(window.location.search);
        const openLoginParam = urlParams.get('openLogin');
        const shouldOpenLoginFromQuery = openLoginParam === '1' || openLoginParam === 'true';

        if (shouldOpenLoginFromQuery && authModal) {
            if (registerModal) {
                registerModal.classList.remove('active');
            }
            authModal.classList.add('active');
        }

        document.addEventListener('click', (e) => {
            const trigger = e.target.closest('[data-open-login="true"]');
            if (!trigger || !authModal) {
                return;
            }
            e.preventDefault();
            if (registerModal) {
                registerModal.classList.remove('active');
            }
            authModal.classList.add('active');
        });

        const loginForm = document.getElementById('loginModalForm');
        const registerForm = document.getElementById('registerModalForm');
        const loginError = document.getElementById('loginError');
        const registerError = document.getElementById('registerError');

        async function submitAuthForm(form, errorEl) {
            if (!form) {
                return;
            }

            const formData = new FormData(form);
            const token = formData.get('__RequestVerificationToken');

            if (errorEl) {
                errorEl.classList.remove('active');
                errorEl.textContent = '';
            }

            const response = await fetch(form.action, {
                method: 'POST',
                headers: token ? { 'RequestVerificationToken': token } : {},
                body: formData
            });

            const payload = await response.json();
            if (payload?.success) {
                if (payload.redirectUrl) {
                    window.location.href = payload.redirectUrl;
                } else {
                    window.location.reload();
                }
                return;
            }

            if (errorEl) {
                errorEl.textContent = payload?.message || 'Không thể xử lý yêu cầu.';
                errorEl.classList.add('active');
            }
        }

        if (loginForm) {
            loginForm.addEventListener('submit', (e) => {
                e.preventDefault();
                submitAuthForm(loginForm, loginError);
            });
        }

        if (registerForm) {
            registerForm.addEventListener('submit', (e) => {
                e.preventDefault();
                submitAuthForm(registerForm, registerError);
            });
        }

        const followForms = document.querySelectorAll('.story-follow-form');
        followForms.forEach((form) => {
            form.addEventListener('submit', (e) => {
                if (isAuthenticated) {
                    return;
                }
                e.preventDefault();
                if (registerModal) {
                    registerModal.classList.remove('active');
                }
                if (authModal) {
                    authModal.classList.add('active');
                }
            });
        });

        window.addEventListener('click', (e) => {
            if (authModal && e.target === authModal) {
                authModal.classList.remove('active');
            }
            if (registerModal && e.target === registerModal) {
                registerModal.classList.remove('active');
            }
        });

        if (isHomePage) {
            // ===== MOBILE MENU =====
            const mobileMenuBtn = document.getElementById('mobileMenuBtn');
            const mobileMenu = document.getElementById('mobileMenu');
            const mobileMenuOverlay = document.getElementById('mobileMenuOverlay');
            const closeMenu = document.getElementById('closeMenu');
            function openMobileMenu() { mobileMenu.classList.add('open'); mobileMenuOverlay.classList.add('active'); }
            function closeMobileMenu() { mobileMenu.classList.remove('open'); mobileMenuOverlay.classList.remove('active'); }
            mobileMenuBtn.addEventListener('click', openMobileMenu);
            closeMenu.addEventListener('click', closeMobileMenu);
            mobileMenuOverlay.addEventListener('click', closeMobileMenu);

            // ===== CÁC SECTION =====
            const homeSection = document.getElementById('homeSection');
            const newSection = document.getElementById('newSection');
            const hotSection = document.getElementById('hotSection');
            const rankSection = document.getElementById('rankSection');
            const completedSection = document.getElementById('completedSection');
            const groupsSection = document.getElementById('groupsSection');
            const profilePageSection = document.getElementById('profilePageSection');
            const detailSection = document.getElementById('detailSection');
            const readerSection = document.getElementById('readerSection');

            const sections = [
                homeSection,
                newSection,
                hotSection,
                rankSection,
                completedSection,
                groupsSection,
                profilePageSection,
                detailSection,
                readerSection
            ];

            const tabHome = document.getElementById('tabHome');
            const tabNew = document.getElementById('tabNew');
            const tabHot = document.getElementById('tabHot');
            const tabGenre = document.getElementById('tabGenre');
            const tabRank = document.getElementById('tabRank');
            const tabCompleted = document.getElementById('tabCompleted');
            const tabGroups = document.getElementById('tabGroups');
            const tabProfilePage = document.getElementById('tabProfilePage');

            function hideAllSections() {
                sections.forEach(section => section?.classList.add('hidden'));
            }

            function removeActiveTabs() {
                tabHome.classList.remove('active');
                tabNew.classList.remove('active');
                tabHot.classList.remove('active');
                tabGenre.classList.remove('active');
                tabRank.classList.remove('active');
                tabCompleted.classList.remove('active');
                tabGroups.classList.remove('active');
                tabProfilePage.classList.remove('active');
            }

            function showHome() { hideAllSections(); homeSection.classList.remove('hidden'); removeActiveTabs(); tabHome.classList.add('active'); }
            function showNew() { hideAllSections(); newSection.classList.remove('hidden'); removeActiveTabs(); tabNew.classList.add('active'); }
            function showHot() { hideAllSections(); hotSection.classList.remove('hidden'); removeActiveTabs(); tabHot.classList.add('active'); }
            function showRank() { hideAllSections(); rankSection.classList.remove('hidden'); removeActiveTabs(); tabRank.classList.add('active'); }
            function showCompleted() { hideAllSections(); completedSection.classList.remove('hidden'); removeActiveTabs(); tabCompleted.classList.add('active'); }
            function showGroups() { hideAllSections(); groupsSection.classList.remove('hidden'); removeActiveTabs(); tabGroups.classList.add('active'); }
            function showProfilePage() {
                if (!isAuthenticated) {
                    window.location.href = loginUrl;
                    return;
                }
                hideAllSections();
                profilePageSection.classList.remove('hidden');
                removeActiveTabs();
                tabProfilePage.classList.add('active');
            }
            function showDetail() { hideAllSections(); detailSection.classList.remove('hidden'); removeActiveTabs(); }
            function showReader() { hideAllSections(); readerSection.classList.remove('hidden'); removeActiveTabs(); }

            // Mặc định hiện trang chủ
            showHome();

            tabHome.addEventListener('click', (e) => { e.preventDefault(); showHome(); });
            tabNew.addEventListener('click', (e) => { e.preventDefault(); showNew(); });
            tabHot.addEventListener('click', (e) => { e.preventDefault(); showHot(); });
            tabCompleted.addEventListener('click', (e) => { e.preventDefault(); showCompleted(); });
            tabGroups.addEventListener('click', (e) => { e.preventDefault(); showGroups(); });
            tabProfilePage.addEventListener('click', (e) => { e.preventDefault(); showProfilePage(); });

            // Mobile menu items
            document.getElementById('mobileHome').addEventListener('click', (e) => { e.preventDefault(); showHome(); closeMobileMenu(); });
            document.getElementById('mobileNew').addEventListener('click', (e) => { e.preventDefault(); showNew(); closeMobileMenu(); });
            document.getElementById('mobileHot').addEventListener('click', (e) => { e.preventDefault(); showHot(); closeMobileMenu(); });
            document.getElementById('mobileGenre').addEventListener('click', () => { closeMobileMenu(); });
            document.getElementById('mobileRank').addEventListener('click', (e) => { e.preventDefault(); showRank(); closeMobileMenu(); });
            document.getElementById('mobileCompleted').addEventListener('click', (e) => { e.preventDefault(); showCompleted(); closeMobileMenu(); });
            document.getElementById('mobileGroups').addEventListener('click', (e) => { e.preventDefault(); showGroups(); closeMobileMenu(); });
            document.getElementById('mobileProfilePage').addEventListener('click', (e) => { e.preventDefault(); showProfilePage(); closeMobileMenu(); });

            // ===== SIDEBAR RANK TABS =====
            const rankTabs = document.querySelectorAll('.rank-tab');
            const rankContents = document.querySelectorAll('.rank-content');
            rankTabs.forEach(tab => {
                tab.addEventListener('click', () => {
                    rankTabs.forEach(t => t.classList.remove('active'));
                    tab.classList.add('active');
                    rankContents.forEach(content => content.classList.remove('active'));
                    document.getElementById('rank' + tab.dataset.rank.charAt(0).toUpperCase() + tab.dataset.rank.slice(1)).classList.add('active');
                });
            });

            // ===== CHATBOX TOGGLE (thu nhỏ thành bong bóng) =====
            const chatbox = document.getElementById('chatbox');
            const toggleChat = document.getElementById('toggleChat');
            const chatIcon = document.getElementById('chatIcon');
            const chatBody = document.getElementById('chatBody');
            const chatInput = document.getElementById('chatInput');
            const sendBtn = document.getElementById('sendChat');

            toggleChat.addEventListener('click', () => {
                chatbox.classList.toggle('closed');
                if (chatbox.classList.contains('closed')) {
                    chatIcon.className = 'fas fa-comment';
                } else {
                    chatIcon.className = 'fas fa-minus';
                }
            });

            function addMessage(text, sender) {
                const msgDiv = document.createElement('div');
                msgDiv.classList.add('message', sender);
                msgDiv.innerText = text;
                chatBody.appendChild(msgDiv);
                chatBody.scrollTop = chatBody.scrollHeight;
            }
            function sendMessage() {
                const text = chatInput.value.trim();
                if (!text) return;
                addMessage(text, 'user');
                chatInput.value = '';
                setTimeout(() => {
                    let reply = 'Tôi là AI, tôi có thể gợi ý truyện hot hoặc tìm kiếm. Bạn muốn gì?';
                    if (text.toLowerCase().includes('truyện hot') || text.toLowerCase().includes('đề xuất')) {
                        reply = 'Gợi ý cho bạn: "Đại chiến thần", "Solo Leveling", "One Piece" đang rất hot!';
                    } else if (text.includes('cảm ơn')) {
                        reply = 'Không có gì! Đọc truyện vui vẻ nhé.';
                    }
                    addMessage(reply, 'ai');
                }, 600);
            }
            sendBtn.addEventListener('click', sendMessage);
            chatInput.addEventListener('keypress', (e) => {
                if (e.key === 'Enter') sendMessage();
            });

            // ===== CÁC BUTTON TƯƠNG TÁC =====
            document.getElementById('searchBtn').addEventListener('click', function() { alert('Bạn đang tìm: "' + document.getElementById('searchInput').value + '" (Mô phỏng tìm kiếm)'); });
            document.getElementById('logo').addEventListener('click', function(e) { e.preventDefault(); showHome(); });
            document.getElementById('notificationBtn').addEventListener('click', function(e) { e.preventDefault(); alert('Bạn có 3 thông báo mới (mô phỏng)'); });
            document.getElementById('readFeaturedBtn').addEventListener('click', function() { fillDetailAndShow(this); });
            document.getElementById('viewAllUpdates').addEventListener('click', function() { alert('Xem tất cả truyện mới cập nhật'); });
            document.getElementById('viewMoreBtn').addEventListener('click', function() { alert('Tải thêm truyện (mô phỏng)'); });

            // ===== XỬ LÝ RATING (SAO) =====
            const stars = document.querySelectorAll('.star');
            const ratingText = document.querySelector('.rating-text');
            let currentRating = 5;
            let totalVotes = 605;

            function updateRatingDisplay(rating) {
                stars.forEach((star, index) => {
                    if (index < rating) {
                        star.classList.add('selected');
                    } else {
                        star.classList.remove('selected');
                    }
                });
                ratingText.innerText = `${rating}/5 - ${totalVotes} Lượt đánh giá`;
            }
            updateRatingDisplay(currentRating);

            stars.forEach(star => {
                star.addEventListener('click', function() {
                    const value = parseInt(this.dataset.value);
                    currentRating = value;
                    totalVotes++;
                    updateRatingDisplay(value);
                    alert(`Bạn đã đánh giá ${value} sao! Cảm ơn bạn.`);
                });
            });

            function fillDetailAndShow(card) {
                const title = card.dataset.title || 'Đồ Đệ Của Ta Đều Là Đại Phản Phái';
                const author = card.dataset.author || 'TruyenQQ, Mộng Tiên Giới';
                const genre = card.dataset.genre || 'Adventure - Chuyển Sinh - Cổ Đại - Manhua - Truyện Màu - Xuyên Không';
                const views = card.dataset.views || '427,480';
                const rating = parseFloat(card.dataset.rating) || 5.0;
                const votes = parseInt(card.dataset.votes) || 605;
                const description = card.dataset.description || '';
                const cover = card.dataset.cover || '';
                const status = card.dataset.status || 'Đang tiến hành';

                document.getElementById('detailTitle').innerText = title;
                document.getElementById('detailAuthor').innerText = author;
                document.getElementById('detailGenre').innerText = genre;
                document.getElementById('detailViews').innerText = views;
                document.getElementById('detailStatus').innerText = status;
                document.getElementById('breadcrumbTitle').innerText = title;

                const detailDescription = document.getElementById('detailDescription');
                detailDescription.innerHTML = description
                    ? `<strong>NỘI DUNG TRUYỆN ${title.toUpperCase()}</strong><br>${description}`
                    : '<strong>NỘI DUNG TRUYỆN ĐỒ ĐỆ CỦA TA ĐỀU LÀ ĐẠI PHẢN PHÁI</strong><br>Chào mừng bạn đến với NetTruyen – không gian đọc truyện tranh online hoàn hảo dành cho tất cả các fan truyện tranh!';

                const detailCover = document.getElementById('detailCover');
                if (cover) {
                    detailCover.style.backgroundImage = `url('${cover}')`;
                    detailCover.style.backgroundSize = 'cover';
                    detailCover.style.backgroundPosition = 'center';
                    detailCover.innerText = '';
                } else {
                    detailCover.style.backgroundImage = '';
                    detailCover.innerText = 'Ảnh bìa';
                }

                currentRating = Math.round(rating);
                totalVotes = votes;
                updateRatingDisplay(currentRating);

                showDetail();
            }

            document.addEventListener('click', (event) => {
                const card = event.target.closest('.update-item, .top-item, .recommend-card');
                if (card) {
                    fillDetailAndShow(card);
                }
            });

            async function loadStories() {
                try {
                    const response = await fetch('/api/stories');
                    if (!response.ok) {
                        throw new Error('Không tải được danh sách truyện');
                    }
                    const stories = await response.json();
                    if (!Array.isArray(stories) || stories.length === 0) {
                        return;
                    }

                    renderFeaturedStory(stories[0]);
                    renderUpdateStories(stories);
                    renderTopStories(stories);
                    renderRecommendStories(stories);
                } catch (error) {
                    console.error(error);
                }
            }

            function buildStoryData(story) {
                const title = story.title || story.Title || 'Chưa có tiêu đề';
                return {
                    id: story.id || story.Id,
                    title,
                    description: story.description || story.Description || '',
                    author: story.authorName || story.AuthorName || 'Đang cập nhật',
                    genre: story.categoryName || story.CategoryName || 'Đang cập nhật',
                    status: story.status || story.Status || 'Đang tiến hành',
                    cover: story.coverImage || story.CoverImage || '',
                    views: story.views || story.Views || '0',
                    rating: story.rating || story.Rating || '5',
                    votes: story.votes || story.Votes || '0'
                };
            }

            function setStoryDataset(element, storyData) {
                element.dataset.id = storyData.id || '';
                element.dataset.title = storyData.title;
                element.dataset.author = storyData.author;
                element.dataset.genre = storyData.genre;
                element.dataset.views = storyData.views;
                element.dataset.rating = storyData.rating;
                element.dataset.votes = storyData.votes;
                element.dataset.description = storyData.description;
                element.dataset.cover = storyData.cover;
                element.dataset.status = storyData.status;
            }

            function renderFeaturedStory(story) {
                const storyData = buildStoryData(story);
                document.querySelector('.featured-large-content h2').innerText = storyData.title;
                document.querySelector('.featured-large-content p').innerText = storyData.description || 'Đang cập nhật nội dung.';
                const stats = document.querySelectorAll('.featured-stats span');
                if (stats.length >= 2) {
                    stats[1].innerHTML = `<i class="fas fa-eye"></i> ${storyData.views} lượt xem`;
                }

                const featuredCover = document.querySelector('.featured-large-cover');
                if (storyData.cover) {
                    featuredCover.style.backgroundImage = `url('${storyData.cover}')`;
                    featuredCover.style.backgroundSize = 'cover';
                    featuredCover.style.backgroundPosition = 'center';
                    featuredCover.innerText = '';
                } else {
                    featuredCover.style.backgroundImage = '';
                    featuredCover.innerText = 'Ảnh bìa';
                }

                const featuredButton = document.getElementById('readFeaturedBtn');
                setStoryDataset(featuredButton, storyData);
            }

            function renderUpdateStories(stories) {
                const list = document.querySelector('.update-list');
                list.querySelectorAll('.update-item').forEach(item => item.remove());
                stories.slice(0, 5).forEach(story => {
                    const storyData = buildStoryData(story);
                    const item = document.createElement('div');
                    item.className = 'update-item';
                    setStoryDataset(item, storyData);
                    item.innerHTML = `
                        <div class="update-cover" style="${storyData.cover ? `background-image:url('${storyData.cover}')` : ''}"></div>
                        <div class="update-info">
                            <div class="update-title">${storyData.title}</div>
                            <div class="update-chapter">Cập nhật gần đây</div>
                            <div class="update-meta">
                                <span><i class="fas fa-star" style="color: #fbbf24;"></i> ${storyData.rating}</span>
                                <span><i class="fas fa-eye"></i> ${storyData.views}</span>
                            </div>
                        </div>
                    `;
                    list.appendChild(item);
                });
            }

            function renderTopStories(stories) {
                const list = document.querySelector('.top-list');
                list.querySelectorAll('.top-item').forEach(item => item.remove());
                stories.slice(0, 5).forEach((story, index) => {
                    const storyData = buildStoryData(story);
                    const item = document.createElement('div');
                    item.className = 'top-item';
                    setStoryDataset(item, storyData);
                    item.innerHTML = `
                        <span class="top-rank">${index + 1}</span>
                        <div class="top-info">
                            <div class="top-title">${storyData.title}</div>
                            <div class="top-views">${storyData.views}</div>
                        </div>
                    `;
                    list.appendChild(item);
                });
            }

            function renderRecommendStories(stories) {
                const grid = document.getElementById('recommendAll');
                grid.querySelectorAll('.recommend-card').forEach(card => card.remove());
                stories.slice(0, 4).forEach(story => {
                    const storyData = buildStoryData(story);
                    const card = document.createElement('div');
                    card.className = 'recommend-card';
                    setStoryDataset(card, storyData);
                    card.innerHTML = `
                        <div class="recommend-cover" style="${storyData.cover ? `background-image:url('${storyData.cover}')` : ''}"></div>
                        <div class="recommend-info">
                            <div class="recommend-title">${storyData.title}</div>
                            <div class="recommend-stats">
                                <span>${storyData.status}</span>
                                <span>${storyData.views}</span>
                            </div>
                        </div>
                    `;
                    grid.appendChild(card);
                });
            }

            document.querySelectorAll('.delete-btn').forEach(btn => {
                btn.addEventListener('click', (e) => { e.stopPropagation(); alert('Đã xóa lịch sử'); });
            });

            const recommendTabs = document.querySelectorAll('.recommend-tab');
            recommendTabs.forEach(tab => {
                tab.addEventListener('click', () => {
                    recommendTabs.forEach(t => t.classList.remove('active'));
                    tab.classList.add('active');
                    alert('Chuyển tab ' + tab.innerText);
                });
            });

            document.getElementById('followBtn').addEventListener('click', () => alert('Đã theo dõi truyện (mô phỏng)'));
            document.getElementById('readFirstBtn').addEventListener('click', () => { alert('Đọc từ đầu'); showReader(); });
            document.getElementById('readLatestBtn').addEventListener('click', () => { alert('Đọc mới nhất'); showReader(); });
            document.getElementById('readContinueBtn').addEventListener('click', () => { alert('Đọc tiếp'); showReader(); });
            document.getElementById('breadcrumbHome').addEventListener('click', (e) => { e.preventDefault(); showHome(); });

            loadStories();

            document.getElementById('readerBreadcrumbHome').addEventListener('click', (e) => { e.preventDefault(); showHome(); });
            document.getElementById('readerBreadcrumbDetail').addEventListener('click', (e) => { e.preventDefault(); showDetail(); });

            document.getElementById('server1').addEventListener('click', function() {
                document.getElementById('server1').classList.add('active');
                document.getElementById('server2').classList.remove('active');
                alert('Chuyển sang Server 1');
            });
            document.getElementById('server2').addEventListener('click', function() {
                document.getElementById('server2').classList.add('active');
                document.getElementById('server1').classList.remove('active');
                alert('Chuyển sang Server 2');
            });
            document.getElementById('reportError').addEventListener('click', () => alert('Báo lỗi thành công (mô phỏng)'));

            document.getElementById('prevChapter').addEventListener('click', () => alert('Chuyển đến chapter trước'));
            document.getElementById('nextChapter').addEventListener('click', () => alert('Chuyển đến chapter sau'));
            document.getElementById('chapterSelect').addEventListener('change', (e) => alert('Chuyển đến ' + e.target.value));

            window.addEventListener('keydown', (e) => {
                if (e.key === 'ArrowLeft') {
                    alert('← Chuyển chapter trước (mô phỏng)');
                } else if (e.key === 'ArrowRight') {
                    alert('→ Chuyển chapter sau (mô phỏng)');
                }
            });
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
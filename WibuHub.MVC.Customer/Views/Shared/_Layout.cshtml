                        <div class="history-cover">Ảnh</div>
                        <div class="history-info">
                            <div class="history-title">Bỏ Làm Simp Chúa, Ta Có Trong...</div>
                            <div class="history-meta">Đọc tiếp Chapter 278 ></div>

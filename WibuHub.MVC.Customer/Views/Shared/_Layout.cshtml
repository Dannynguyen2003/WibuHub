                console.log("🔥 5. Bắt đầu đổ dữ liệu ra HTML...");
                if (sliderList) {
                    sliderList.innerHTML = ''; // Xóa dòng chữ đang tải

                    // Lấy tối đa 5 truyện đưa lên nổi bật
                    stories.slice(0, 5).forEach(story => {
                        // Cực kỳ chú ý: Map đúng tên biến JSON (đề phòng C# viết hoa chữ cái đầu)
                        const id = story.id || story.Id;
                        const title = story.title || story.Title || 'Chưa có tên';
                        const desc = story.description || story.Description || 'Truyện đang cập nhật nội dung...';
                        const cover = story.coverImage || story.CoverImage || 'https://via.placeholder.com/200x300';
                        const rating = story.rating || story.Rating || '5.0';
                        const views = story.views || story.Views || '0';

                        const li = document.createElement('li');
                        li.className = 'suggest-slide';
                        // Ép cứng CSS để không bị mất hình
                        li.style.flex = "0 0 100%";
                        li.style.width = "100%";
                        li.style.boxSizing = "border-box";

                        li.innerHTML = `
                            <div class="featured-box" style="display: flex; align-items: center; justify-content: space-between; padding: 40px; gap: 30px; width: 100%;">
                                <div class="featured-info" style="flex: 1; color: white;">
                                    <p class="tag-hot" style="color: #fbbf24; font-weight: bold; margin-bottom: 10px;">NỔI BẬT</p>
                                    <h2 style="font-size: 2.5rem; margin: 0 0 15px 0;">${title}</h2>
                                    <p class="desc" style="color: #9ca3af; margin-bottom: 20px; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">${desc}</p>
                                    <div class="stats" style="margin-bottom: 25px;">
                                        <span style="margin-right: 15px;">⭐ ${rating}</span>
                                        <span>👁️ ${views} lượt xem</span>
                                    </div>
                                    <button class="btn-read" data-id="${id}" data-title="${title}" style="background-color: #3b82f6; color: white; border: none; padding: 12px 32px; border-radius: 20px; font-weight: bold; cursor: pointer;">Đọc ngay</button>
                                </div>
                                <div class="featured-cover" style="width: 200px; height: 300px; border-radius: 12px; overflow: hidden; flex-shrink: 0; background: #333;">
                                    <img src="${cover}" alt="${title}" style="width: 100%; height: 100%; object-fit: cover;">
                                </div>
                            </div>
                        `;
                        sliderList.appendChild(li);
                    });

                    console.log("🔥 6. Vẽ xong! Khởi động Slider.");
                    setTimeout(initSlider, 100); // Khởi động hiệu ứng trượt
                }

            } catch (err) {
                console.error("🔥 LỖI CHẾT NGƯỜI:", err);
                if (sliderList) {
                    sliderList.innerHTML = `<li style="width: 100%; text-align: center; color: #ef4444; padding: 50px;">Lỗi không thể tải truyện: ${err.message}</li>`;
                }
            }
        }

            // Chạy dữ liệu
            loadHomePageData();
        }

        // ==========================================
        // 3. LOGIC SLIDER
        // ==========================================
        let autoPlayTimer;
        function initSlider() {
            const track = document.getElementById('list_suggest');
            if (!track) return;

            const slides = track.querySelectorAll('.suggest-slide');
            const slideCount = slides.length;
            let currentIndex = 0;
            const intervalTime = 4000;

            const prevBtn = document.querySelector('.slider-prev');
            const nextBtn = document.querySelector('.slider-next');

            if (autoPlayTimer) clearInterval(autoPlayTimer);

            function goToSlide(index) {
                if (index >= slideCount) currentIndex = 0;
                else if (index < 0) currentIndex = slideCount - 1;
                else currentIndex = index;
                track.style.transform = `translateX(-${currentIndex * 100}%)`;
            }

            function startAutoPlay() {
                autoPlayTimer = setInterval(() => { goToSlide(currentIndex + 1); }, intervalTime);
            }

            function resetAutoPlay() {
                clearInterval(autoPlayTimer);
                startAutoPlay();
            }

            if (prevBtn) prevBtn.onclick = () => { goToSlide(currentIndex - 1); resetAutoPlay(); };
            if (nextBtn) nextBtn.onclick = () => { goToSlide(currentIndex + 1); resetAutoPlay(); };

            if(slideCount > 1) startAutoPlay();
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
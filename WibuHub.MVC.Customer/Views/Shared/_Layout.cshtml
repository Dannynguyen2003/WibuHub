@using Microsoft.AspNetCore.Identity
@using WibuHub.ApplicationCore.Entities.Identity
@using WibuHub.Service.Interface
@inject SignInManager<StoryUser> SignInManager
@inject UserManager<StoryUser> UserManager
@inject ICategoryService CategoryService

@{
    var returnUrl = Url.Action("Index", "Home", new { area = "" }) ?? "/";
    var externalSchemes = (await SignInManager.GetExternalAuthenticationSchemesAsync()).ToList();
    var categories = await CategoryService.GetAllAsync();
    var categoryColumnCount = categories.Count == 0 ? 1 : 4;
    var categoriesPerColumn = categories.Count > 0
      ? (int)Math.Ceiling(categories.Count / (double)categoryColumnCount)
      : 0;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Truyện Hay - WibuHub</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true">

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @{
        var isHomePage = string.Equals(ViewContext.RouteData.Values["controller"]?.ToString(), "Home", StringComparison.OrdinalIgnoreCase)
        && string.Equals(ViewContext.RouteData.Values["action"]?.ToString(), "Index", StringComparison.OrdinalIgnoreCase);
        var isIdentityArea = string.Equals(ViewContext.RouteData.Values["area"]?.ToString(), "Identity", StringComparison.OrdinalIgnoreCase);
    }
    <div class="app">
        <header class="header">
            <div class="logo-area">
                <button class="mobile-menu-btn" id="mobileMenuBtn"><i class="fas fa-bars"></i></button>
                <a asp-controller="Home" asp-action="Index" asp-area="" class="logo" id="logo">WIBU<span>HUB</span></a>
            </div>

            <div class="search-wrapper" style="position: relative; z-index: 9999;">

                <div class="search-bar">
                    <input type="text" placeholder="Tìm truyện, tác giả..." id="searchInput" autocomplete="off">
                    <button id="searchBtn"><i class="fas fa-search"></i></button>
                </div>

                <div id="searchSuggestions" style="display: none;"></div>

            </div>

            <div class="user-actions">
                <a href="#" id="notificationBtn"><i class="far fa-bell"></i> <span class="d-none d-md-inline">Thông báo</span></a>
                <a href="/ShoppingCart/Cart" id="cartBtn"><i class="fas fa-shopping-cart"></i> <span class="d-none d-md-inline">Giỏ hàng</span></a>

                @if (User?.Identity?.IsAuthenticated ?? false)
                {
                    var currentUser = await UserManager.GetUserAsync(User);
                    var avatarUrl = currentUser?.Avatar;
                    if (string.IsNullOrEmpty(avatarUrl))
                    {
                        avatarUrl = "https://ui-avatars.com/api/?name=" + (currentUser?.UserName ?? "User") + "&background=E2E8F0&color=475569";
                    }

                    // Thêm logic check VIP
                    bool isVip = currentUser?.IsVip ?? false;

                    <div class="user-account">
                        <div class="avatar-wrapper @(isVip ? "is-vip" : "")" style="position: relative;">
                            <img src="@avatarUrl" alt="Avatar" class="avatar-icon" style="@(isVip ? "border-radius: 50%; width: 40px; height: 40px; object-fit: cover;" : "")">
                            @if (isVip)
                            {
                                <span class="vip-crown-badge" title="Tài khoản VIP"><i class="fas fa-crown"></i></span>
                            }
                        </div>

                        <ul class="dropdown-menu">
                            <li class="user-info-header" style="padding: 10px 15px; border-bottom: 1px solid #eee; margin-bottom: 5px;">
                                <strong>@currentUser?.UserName</strong>
                                <div style="font-size: 0.85rem; color: #666;">Xu: <span style="color: #f59e0b; font-weight: bold;">@currentUser?.Points <i class="fas fa-coins"></i></span></div>
                            </li>
                            <li>
                                <a href="/vip/upgrade" class="btn-upgrade-vip @(isVip ? "vip-active" : "")">
                                    <i class="fas fa-gem"></i> @(isVip ? "Gia hạn VIP" : "Nâng cấp VIP")
                                </a>
                            </li>
                            @if (isVip && currentUser?.VipExpireDate.HasValue == true)
                            {
                                <li style="padding: 0 15px 10px; font-size: 0.8rem; color: #10b981; text-align: center;">
                                    Hạn VIP: @currentUser.VipExpireDate.Value.ToLocalTime().ToString("dd/MM/yyyy")
                                </li>
                            }
                            <li class="divider"></li>

                            <li><a asp-controller="CustomerProfile" asp-action="Followed"><i class="fas fa-bookmark"></i> Danh sách theo dõi</a></li>
                            <li><a asp-controller="CustomerProfile" asp-action="History"><i class="fas fa-history"></i> Lịch sử đọc truyện</a></li>
                            <li><a asp-controller="CustomerProfile" asp-action="Index"><i class="fas fa-cog"></i> Cài đặt thông tin</a></li>
                            <li class="divider"></li>
                            <li>
                                <form class="logout-form" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" style="margin: 0;">
                                    <button type="submit" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Đăng xuất</button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <a href="#" id="loginBtn"><i class="far fa-user"></i> <span class="d-none d-md-inline">Đăng nhập</span></a>
                    <a href="#" id="registerBtn"><i class="fas fa-user-plus"></i> <span class="d-none d-md-inline">Đăng ký</span></a>
                }
            </div>
        </header>

        <div id="authModal" class="modal">
            <div class="modal-content">
                <span class="modal-close" id="closeModal">&times;</span>
                <div class="modal-title">Đăng nhập</div>
                <form id="loginModalForm" action="/api/auth/login" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <div class="form-error" id="loginError"></div>
                    <div class="input-group">
                        <label>Email</label>
                        <input type="email" name="email" autocomplete="username" placeholder="your@gmail.com" required>
                    </div>
                    <div class="input-group">
                        <label>Mật khẩu</label>
                        <input type="password" name="password" autocomplete="current-password" placeholder="••••••••" required>
                    </div>
                    <div class="login-meta">
                        <label class="remember-me"><input type="checkbox" name="rememberMe"> Ghi nhớ?</label>
                        <a asp-area="Identity" asp-page="/Account/ForgotPassword" class="forgot-link">Quên mật khẩu?</a>
                    </div>
                    <button class="btn" type="submit">ĐĂNG NHẬP</button>
                    <div class="switch-link">
                        Chưa có tài khoản? <a href="#" id="showRegisterModal">Đăng ký ngay</a>
                    </div>
                    @if (externalSchemes.Count > 0)
                    {
                        <div class="external-auth">
                            <div class="external-title">Hoặc đăng nhập với</div>
                            <div class="external-buttons">
                                @foreach (var scheme in externalSchemes)
                                {
                                    <button type="submit" name="provider" value="@scheme.Name" formmethod="post" formaction="@Url.Page("/Account/ExternalLogin", new { area = "Identity", returnUrl })" class="btn-auth">
                                        @scheme.DisplayName
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </form>
            </div>
        </div>

        <div id="registerModal" class="modal">
            <div class="modal-content">
                <span class="modal-close" id="closeRegisterModal">&times;</span>
                <div class="modal-title">Đăng ký</div>
                <form id="registerModalForm" action="/api/auth/register" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <div class="form-error" id="registerError"></div>
                    <div class="input-group">
                        <label>Email</label>
                        <input type="email" name="email" autocomplete="username" placeholder="your@email.com" required>
                    </div>
                    <div class="input-group">
                        <label>Mật khẩu</label>
                        <input type="password" name="password" autocomplete="new-password" placeholder="••••••••" required>
                    </div>
                    <div class="input-group">
                        <label>Xác nhận mật khẩu</label>
                        <input type="password" name="confirmPassword" autocomplete="new-password" placeholder="••••••••" required>
                    </div>
                    <button class="btn" type="submit">ĐĂNG KÝ</button>
                    <div class="switch-link">
                        Đã có tài khoản? <a href="#" id="showLoginModal">Đăng nhập</a>
                    </div>
                    @if (externalSchemes.Count > 0)
                    {
                        <div class="external-auth">
                            <div class="external-title">Hoặc đăng ký với</div>
                            <div class="external-buttons">
                                @foreach (var scheme in externalSchemes)
                                {
                                    <button type="submit" name="provider" value="@scheme.Name" formmethod="post" formaction="@Url.Page("/Account/ExternalLogin", new { area = "Identity", returnUrl })" class="btn-auth">
                                        @scheme.DisplayName
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </form>
            </div>
        </div>

        @if (isHomePage)
        {
            <div class="mobile-menu-overlay" id="mobileMenuOverlay"></div>
            <div class="mobile-menu" id="mobileMenu">
                <div class="mobile-menu-header">
                    <span class="mobile-menu-logo">TRUYỆN<span>HAY</span></span>
                    <span class="close-menu" id="closeMenu"><i class="fas fa-times"></i></span>
                </div>
                <a asp-controller="Home" asp-action="Index" asp-area="" class="mobile-menu-item active" id="mobileHome"><i class="fas fa-home"></i> Trang chủ</a>
                <a asp-controller="Categories" asp-action="Index" asp-route-id="" class="mobile-menu-item" id="mobileGenre"><i class="fas fa-tags"></i> Thể loại</a>
                <a href="#" class="mobile-menu-item" id="mobileRank"><i class="fas fa-crown"></i> BXH</a>
                <a href="#" class="mobile-menu-item" id="mobileGroups"><i class="fas fa-users"></i> Nhóm dịch</a>
            </div>
        }

        <nav class="nav-tabs">
            <a class="nav-item active" id="tabHome" asp-controller="Home" asp-action="Index" asp-area="">Trang chủ</a>
            <div class="nav-dropdown">
                <span class="nav-item nav-item-static" id="tabGenre">Thể loại <i class="fas fa-chevron-down"></i></span>
                <div class="genre-dropdown">
                    <div class="genre-column">
                        <a class="genre-link genre-link-all" asp-controller="Categories" asp-action="Index" asp-route-id="">Tất cả</a>
                        @foreach (var category in categories.Take(categoriesPerColumn))
                        {
                            <a class="genre-link" asp-controller="Categories" asp-action="Index" asp-route-id="@category.Id">@category.Name</a>
                        }
                    </div>
                    @for (var columnIndex = 1; columnIndex < categoryColumnCount; columnIndex++)
                    {
                        var columnCategories = categories.Skip(columnIndex * categoriesPerColumn).Take(categoriesPerColumn).ToList();
                        <div class="genre-column">
                            @foreach (var category in columnCategories)
                            {
                                <a class="genre-link" asp-controller="Categories" asp-action="Index" asp-route-id="@category.Id">@category.Name</a>
                            }
                        </div>
                    }
                </div>
            </div>
            <div class="nav-dropdown nav-dropdown-rank">
                <span class="nav-item nav-item-static" id="tabRank">BXH <i class="fas fa-chevron-down"></i></span>
                <div class="rank-dropdown">
                    <a class="rank-link" asp-controller="Rankings" asp-action="Index" asp-route-type="top-day">Top Ngày</a>
                    <a class="rank-link" asp-controller="Rankings" asp-action="Index" asp-route-type="top-week">Top Tuần</a>
                    <a class="rank-link" asp-controller="Rankings" asp-action="Index" asp-route-type="top-month">Top Tháng</a>
                    <a class="rank-link" asp-controller="Rankings" asp-action="Index" asp-route-type="favorites">Yêu Thích</a>
                    <a class="rank-link" asp-controller="Rankings" asp-action="Index" asp-route-type="latest">Mới Cập Nhật</a>
                    <a class="rank-link" asp-controller="Rankings" asp-action="Index" asp-route-type="new">Truyện Mới</a>
                    <a class="rank-link" asp-controller="Rankings" asp-action="Index" asp-route-type="full">Truyện Full</a>
                    <a class="rank-link" asp-controller="Rankings" asp-action="Index" asp-route-type="random">Truyện Ngẫu Nhiên</a>
                </div>
            </div>
            <a class="nav-item" id="tabGroups" href="#">Nhóm dịch</a>
        </nav>

        @if (isHomePage)
        {
            <div class="main-grid">
                <div>
                    <div id="homeSection" class="content-section">
                        <div class="suggest-slider-wrapper">
                            <button class="slider-nav-btn slider-prev"><i class="fas fa-chevron-left"></i></button>

                            <ul id="list_suggest">
                                <li style="flex: 0 0 100%; width: 100%; text-align: center; color: #9ca3af; font-size: 1.1rem; padding: 50px 0;">
                                    <i class="fas fa-spinner fa-spin"></i> Đang tải dữ liệu Nổi Bật...
                                </li>
                            </ul>

                            <button class="slider-nav-btn slider-next"><i class="fas fa-chevron-right"></i></button>
                        </div>

                        <div class="home-grid">
                            <div>
                                <div>
                                    <div class="section-header" style="margin-top: 30px;">
                                        <h2>Truyện Mới Cập Nhật</h2>
                                        <div class="recommend-tabs">
                                            <span class="recommend-tab active" data-recommend="all">Tất cả</span>
                                            <span class="recommend-tab" data-recommend="popular">Phổ biến</span>
                                            <span class="recommend-tab" data-recommend="latest">Mới nhất</span>
                                        </div>
                                    </div>
                                    <div class="recommend-grid" id="recommendAll"></div>

                                    <div style="text-align: center; margin: 30px 0;">
                                        <a class="view-more-btn" id="viewMoreBtn" style="cursor: pointer;">Xem thêm truyện <i class="fas fa-chevron-down"></i></a>
                                    </div>
                                </div>
                            </div>

                            <div>
                                <div class="top-list">
                                    <div class="section-header">
                                        <h2>Xem Nhiều Nhất</h2>
                                    </div>
                                    <div class="top-list-loading" style="text-align: center; padding: 20px; color: #9ca3af;">
                                        <i class="fas fa-spinner fa-spin"></i> Đang tải...
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div id="newSection" class="content-section hidden"><h2>Nội dung Mới cập nhật</h2></div>
                    <div id="hotSection" class="content-section hidden"><h2>Nội dung Hot nhất</h2></div>
                    <div id="rankSection" class="content-section hidden"><h2>Nội dung BXH</h2></div>
                    <div id="groupsSection" class="content-section hidden"><h2>Nội dung Nhóm dịch</h2></div>
                    <div id="detailSection" class="content-section hidden"></div>
                </div>

                <aside class="sidebar">
                    <div class="sidebar-card">
                        <div class="sidebar-title"><i class="fas fa-tags"></i> Thể loại</div>
                        <div class="genre-tags">
                            @foreach (var category in categories)
                            {
                                <a class="genre-tag" asp-controller="Categories" asp-action="Index" asp-route-id="@category.Id">@category.Name</a>
                            }
                        </div>
                    </div>
                </aside>
            </div>

            <div class="chatbox" id="chatbox">
                <div class="chat-header" id="toggleChat">
                    <h3><i class="fas fa-robot" style="color: #f97316;"></i> Trợ lý AI</h3>
                    <i class="fas fa-minus" id="chatIcon"></i>
                </div>
                <div class="chat-body" id="chatBody">
                    <div class="message ai">Xin chào! Tôi là trợ lý AI của WibuHub. Bạn muốn tìm truyện gì hôm nay?</div>
                </div>
                <div class="chat-footer">
                    <input type="text" id="chatInput" placeholder="Nhập tin nhắn...">
                    <button id="sendChat"><i class="fas fa-paper-plane"></i></button>
                </div>
            </div>
        }
        @RenderBody()
    </div>

    <script>
        // ----------------------------------------------------
        // UTILITIES: Hàm tiện ích dùng chung
        // ----------------------------------------------------
        const Utils = {
            formatViews: (views) => {
                const v = parseInt(views, 10) || 0;
                return v >= 1000 ? (v / 1000).toFixed(1) + 'K' : v.toString();
            },

            buildStoryCardHTML: (story) => {
                const id = story.id || story.Id;
                const title = story.title || story.Title || 'Đang cập nhật';
                const cover = story.coverImage || story.CoverImage || 'https://via.placeholder.com/200x300';
                const timeTag = story.timeAgo || story.TimeAgo || 'Mới cập nhật';
                const views = parseInt(story.viewCount || story.ViewCount || 0, 10);
                const isHot = story.isHot || story.IsHot || (views > 1000);

                let chapterText = 'Đang cập nhật';
                const totalChap = story.totalChapters ?? story.TotalChapters ?? 0;
                if (totalChap > 0) chapterText = 'Chapter ' + totalChap;

                return `
                    <div class="recommend-card" style="cursor: default;" data-title="${title}" data-cover="${cover}" data-views="${Utils.formatViews(views)}">
                        <div class="tq-card-cover" style="position: relative; overflow: hidden; border-radius: 12px;">
                            <a href="/Stories/Details/${id}">
                                <img src="${cover}" alt="${title}" loading="lazy" style="width: 100%; aspect-ratio: 2/3; object-fit: cover; display: block;">
                            </a>
                            <div class="tq-badges">
                                <span class="tq-time">${timeTag}</span>
                                ${isHot ? '<span class="tq-hot">Hot</span>' : ''}
                            </div>
                            <div class="tq-bookmark"><i class="fas fa-bookmark"></i></div>
                        </div>
                        <div class="tq-card-info" style="text-align: center; padding: 10px 5px;">
                            <h3 class="tq-title" style="margin: 0; font-size: 1rem; line-height: 1.4; height: 2.8em; overflow: hidden;">
                                <a href="/Stories/Details/${id}" style="text-decoration: none; color: #1f2937; font-weight: 600;">${title}</a>
                            </h3>
                            <div class="last_chapter" style="margin-top: 4px;">
                                <a href="/Stories/Details/${id}" title="${chapterText}" style="text-decoration: none; color: #6b7280; font-size: 0.85rem;">
                                    ${chapterText}
                                </a>
                            </div>
                        </div>
                    </div>
                `;
            },

            fetchAPI: async (url) => {
                const res = await fetch(url);
                if (!res.ok) throw new Error(`Lỗi gọi API: ${res.status}`);
                return await res.json();
            }
        };

        // ----------------------------------------------------
        // SEARCH CONTROLLER: Xử lý tìm kiếm & Live Search
        // ----------------------------------------------------
        const SearchController = {
            init: function() {
                const searchInput = document.getElementById('searchInput');
                const searchBtn = document.getElementById('searchBtn');
                const suggestBox = document.getElementById('searchSuggestions');
                let debounceTimer = null;

                if (!searchInput || !searchBtn || !suggestBox) return;

                // Xử lý sự kiện gõ phím
                searchInput.addEventListener('input', (e) => {
                    clearTimeout(debounceTimer);
                    const keyword = e.target.value.trim();

                    if (keyword.length === 0) {
                        suggestBox.style.display = 'none';
                        return;
                    }

                    // Tạm thời set background thành nền đen và hiện chữ Đang tìm kiếm
                    suggestBox.className = 'search_result';
                    suggestBox.innerHTML = '<div style="padding: 15px; text-align: center; color: #9ca3af;"><i class="fas fa-spinner fa-spin"></i> Đang tìm kiếm...</div>';
                    suggestBox.style.display = 'block';

                    debounceTimer = setTimeout(async () => {
                        try {
                            const response = await fetch(`http://localhost:5126/api/stories/search-suggest?q=${encodeURIComponent(keyword)}`);
                            const data = await response.json();

                            this.renderSuggestions(data, keyword);
                        } catch (error) {
                            console.error("Lỗi khi tải gợi ý:", error);
                            suggestBox.innerHTML = '<div style="padding: 15px; text-align: center; color: #ef4444;">Lỗi kết nối</div>';
                        }
                    }, 300);
                });

                // Ẩn hộp gợi ý khi click ra chỗ khác
                document.addEventListener('click', (e) => {
                    if (!searchInput.contains(e.target) && !suggestBox.contains(e.target)) {
                        suggestBox.style.display = 'none';
                    }
                });

                // Hiện lại hộp gợi ý khi focus lại
                searchInput.addEventListener('focus', () => {
                    if (searchInput.value.trim().length > 0 && suggestBox.innerHTML !== '') {
                        suggestBox.style.display = 'block';
                    }
                });

                // CHẶN CHUYỂN TRANG
                searchBtn.addEventListener('click', (e) => {
                    e.preventDefault();
                    searchInput.focus();
                });
                searchInput.addEventListener('keypress', (e) => {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                    }
                });
            },

            // Hàm render HTML xuất ra cấu trúc UL > LI > A
            renderSuggestions: function(data, keyword) {
                const suggestBox = document.getElementById('searchSuggestions');
                suggestBox.className = 'search_result';
                suggestBox.innerHTML = '';

                if (!data || data.length === 0) {
                    suggestBox.innerHTML = '<div style="padding: 15px; text-align: center; color: #9ca3af;">Không tìm thấy truyện nào</div>';
                    return;
                }

                const escapeRegExp = (string) => string.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
                const regex = new RegExp(`(${escapeRegExp(keyword)})`, 'gi');

                let html = '<ul>';

                data.forEach(item => {
                    const cover = item.coverImage || 'https://via.placeholder.com/50x70';
                    const highlightedTitle = item.title.replace(regex, '<strong style="color: #f97316;">$1</strong>');

                    const authorText = item.author || 'Đang cập nhật';
                    const chapterText = item.chapter > 0 ? `Chương ${item.chapter}` : 'Đang cập nhật';

                    html += `
                        <li>
                            <a href="/Stories/Details/${item.id}">
                                <div class="search_avatar">
                                    <img src="${cover}" alt="${item.title}">
                                </div>
                                <div class="search_info">
                                    <p class="name">${highlightedTitle}</p>
                                    <p class="name_other">${authorText}</p>
                                    <p>${chapterText}</p>
                                </div>
                                <div style="clear: both;"></div>
                            </a>
                        </li>
                    `;
                });

                html += '</ul>';
                suggestBox.innerHTML = html;
            }
        };

        // ----------------------------------------------------
        // AUTH CONTROLLER: Xử lý Đăng nhập / Đăng ký
        // ----------------------------------------------------
        const AuthController = {
            modals: {
                auth: document.getElementById('authModal'),
                register: document.getElementById('registerModal')
            },
            init: function() {
                const toggles = [
                    { btn: 'loginBtn', show: this.modals.auth, hide: this.modals.register },
                    { btn: 'registerBtn', show: this.modals.register, hide: this.modals.auth },
                    { btn: 'showRegisterModal', show: this.modals.register, hide: this.modals.auth },
                    { btn: 'showLoginModal', show: this.modals.auth, hide: this.modals.register }
                ];

                toggles.forEach(t => {
                    const el = document.getElementById(t.btn);
                    if (el) el.addEventListener('click', (e) => {
                        e.preventDefault();
                        if (t.hide) t.hide.classList.remove('active');
                        if (t.show) t.show.classList.add('active');
                    });
                });

                document.querySelectorAll('.modal-close').forEach(btn => {
                    btn.addEventListener('click', () => {
                        this.modals.auth?.classList.remove('active');
                        this.modals.register?.classList.remove('active');
                    });
                });

                window.addEventListener('click', (e) => {
                    if (e.target === this.modals.auth) this.modals.auth.classList.remove('active');
                    if (e.target === this.modals.register) this.modals.register.classList.remove('active');
                });

                document.getElementById('loginModalForm')?.addEventListener('submit', (e) => this.submitForm(e, false));
                document.getElementById('registerModalForm')?.addEventListener('submit', (e) => this.submitForm(e, true));
            },
            submitForm: async function(e, isRegister) {
                e.preventDefault();
                const form = e.target;
                const errorEl = document.getElementById(isRegister ? 'registerError' : 'loginError');
                if (errorEl) { errorEl.classList.remove('active'); errorEl.textContent = ''; }

                const formData = new FormData(form);
                const dataObject = Object.fromEntries(formData.entries());
                if (!isRegister) {
                    dataObject.rememberMe = form.querySelector('input[name="rememberMe"]').checked;
                }

                try {
                    const response = await fetch(form.action, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': dataObject['__RequestVerificationToken']
                        },
                        body: JSON.stringify(dataObject)
                    });
                    const payload = await response.json().catch(() => ({}));

                    if (response.ok && payload.success) {
                        if (isRegister) {
                            this.modals.register.classList.remove('active');
                            this.modals.auth.classList.add('active');
                            const loginErr = document.getElementById('loginError');
                            if (loginErr) {
                                loginErr.textContent = payload.message || 'Đăng ký thành công! Vui lòng đăng nhập.';
                                loginErr.classList.add('active');
                                loginErr.style.cssText = 'background-color: #d4edda; color: #155724;';
                            }
                        } else {
                            window.location.href = payload.redirectUrl || window.location.href;
                        }
                    } else {
                        if (errorEl) { errorEl.textContent = payload.message || 'Thông tin không hợp lệ.'; errorEl.classList.add('active'); }
                    }
                } catch (error) {
                    if (errorEl) { errorEl.textContent = 'Mất kết nối tới máy chủ.'; errorEl.classList.add('active'); }
                }
            }
        };

        // ----------------------------------------------------
        // UI CONTROLLER: Điều hướng & Giao diện (Tabs, Menu)
        // ----------------------------------------------------
        const UIController = {
            sections: ['homeSection', 'newSection', 'hotSection', 'rankSection', 'groupsSection', 'profilePageSection', 'detailSection'],
            tabs: ['tabHome', 'tabGenre', 'tabRank', 'tabGroups', 'tabProfilePage'],

            init: function() {
                // Mobile Menu
                const menu = document.getElementById('mobileMenu');
                const overlay = document.getElementById('mobileMenuOverlay');
                const toggleMenu = (force) => {
                    menu?.classList.toggle('open', force);
                    overlay?.classList.toggle('active', force);
                };
                document.getElementById('mobileMenuBtn')?.addEventListener('click', () => toggleMenu(true));
                document.getElementById('closeMenu')?.addEventListener('click', () => toggleMenu(false));
                overlay?.addEventListener('click', () => toggleMenu(false));

                // Nav Tabs
                document.getElementById('tabHome')?.addEventListener('click', (e) => { e.preventDefault(); this.showSection('homeSection', 'tabHome'); });
                document.getElementById('tabGroups')?.addEventListener('click', (e) => { e.preventDefault(); this.showSection('groupsSection', 'tabGroups'); });
                document.getElementById('tabProfilePage')?.addEventListener('click', (e) => { e.preventDefault(); this.showSection('profilePageSection', 'tabProfilePage'); });

                // Chatbox UI Toggle
                const chatbox = document.getElementById('chatbox');
                document.getElementById('toggleChat')?.addEventListener('click', () => {
                    chatbox?.classList.toggle('closed');
                    document.getElementById('chatIcon').className = chatbox?.classList.contains('closed') ? 'fas fa-comment' : 'fas fa-minus';
                });
            },

            showSection: function(sectionId, tabId) {
                this.sections.forEach(id => document.getElementById(id)?.classList.add('hidden'));
                this.tabs.forEach(id => document.getElementById(id)?.classList.remove('active'));

                document.getElementById(sectionId)?.classList.remove('hidden');
                if (tabId) document.getElementById(tabId)?.classList.add('active');
            }
        };

        // ----------------------------------------------------
        // DATA CONTROLLER: Quản lý API & Render List
        // ----------------------------------------------------
        const DataController = {
            state: {
                originalStories: [],
                activeStoriesList: [],
                currentIndex: 0,
                INITIAL_ITEMS: 30,
                LOAD_MORE_ITEMS: 20,
                MAX_ITEMS: 50
            },

            init: function() {
                this.bindFilters();
                this.bindLoadMore();

                Promise.all([
                    this.loadSlider(),
                    this.loadTopViews(),
                    this.loadGrid()
                ]);
            },

            bindFilters: function() {
                const tabs = document.querySelectorAll('.recommend-tab');
                tabs.forEach(tab => {
                    tab.addEventListener('click', () => {
                        tabs.forEach(t => t.classList.remove('active'));
                        tab.classList.add('active');

                        const filterType = tab.dataset.recommend;

                        if (filterType === 'all') {
                            this.state.activeStoriesList = [...this.state.originalStories];
                        } else if (filterType === 'popular') {
                            this.state.activeStoriesList = [...this.state.originalStories].sort((a, b) => (b.viewCount ?? b.ViewCount ?? 0) - (a.viewCount ?? a.ViewCount ?? 0));
                        } else if (filterType === 'latest') {
                            this.state.activeStoriesList = [...this.state.originalStories].sort((a, b) => new Date(b.createdAt ?? b.CreatedAt ?? 0) - new Date(a.createdAt ?? a.CreatedAt ?? 0));
                        }

                        document.getElementById('recommendAll').innerHTML = '';
                        this.state.currentIndex = 0;
                        this.renderGrid();
                    });
                });
            },

            bindLoadMore: function() {
                document.getElementById('viewMoreBtn')?.addEventListener('click', (e) => {
                    e.preventDefault();
                    if (this.state.currentIndex >= this.state.MAX_ITEMS) {
                        window.location.href = '/Categories';
                        return;
                    }
                    this.renderGrid();
                });
            },

            loadGrid: async function() {
                const grid = document.getElementById('recommendAll');
                if (!grid) return;

                try {
                    const data = await Utils.fetchAPI('http://localhost:5126/api/stories/liststory');
                    this.state.originalStories = Array.isArray(data) ? data : [];
                    this.state.activeStoriesList = [...this.state.originalStories];
                    grid.innerHTML = '';

                    if (this.state.activeStoriesList.length === 0) {
                        grid.innerHTML = '<div style="grid-column: 1/-1; text-align: center; color: #fbbf24; padding: 20px;">Chưa có truyện nào!</div>';
                        document.getElementById('viewMoreBtn').style.display = 'none';
                        return;
                    }
                    this.renderGrid();
                } catch (error) {
                    grid.innerHTML = '<div style="grid-column: 1/-1; text-align: center; color: #ef4444; padding: 20px;">Đã xảy ra lỗi khi tải dữ liệu!</div>';
                }
            },

            renderGrid: function() {
                const grid = document.getElementById('recommendAll');
                const btn = document.getElementById('viewMoreBtn');
                if (!grid) return;

                let itemsToTake = this.state.currentIndex === 0 ? this.state.INITIAL_ITEMS : this.state.LOAD_MORE_ITEMS;
                const slice = this.state.activeStoriesList.slice(this.state.currentIndex, this.state.currentIndex + itemsToTake);

                slice.forEach(story => {
                    grid.innerHTML += Utils.buildStoryCardHTML(story);
                });

                this.state.currentIndex += slice.length;

                if (btn) {
                    if (this.state.currentIndex >= this.state.activeStoriesList.length) {
                        btn.style.display = 'none';
                    } else if (this.state.currentIndex >= this.state.MAX_ITEMS) {
                        btn.style.display = 'inline-block';
                        btn.innerHTML = 'Xem tất cả truyện <i class="fas fa-arrow-right"></i>';
                    } else {
                        btn.style.display = 'inline-block';
                        btn.innerHTML = 'Xem thêm truyện <i class="fas fa-chevron-down"></i>';
                    }
                }
            },

            loadTopViews: async function() {
                const container = document.querySelector('.top-list-loading');
                const topList = document.querySelector('.top-list');
                if (!topList) return;

                try {
                    const data = await Utils.fetchAPI('http://localhost:5126/api/stories/top-views');
                    if (container) container.remove();

                    if (Array.isArray(data)) {
                        data.slice(0, 10).forEach((story, index) => {
                            const id = story.id || story.Id;
                            const title = story.title || story.Title || 'Chưa có tên';
                            const views = story.viewCount || story.ViewCount || 0;

                            topList.insertAdjacentHTML('beforeend', `
                                <a class="top-item" href="/Stories/Details/${id}" style="text-decoration: none; color: inherit; display: flex; align-items: center; padding: 10px 0; border-bottom: 1px dashed #e5e7eb;">
                                    <span class="top-rank" style="font-size: 1.5rem; font-weight: bold; width: 30px; color: ${index < 3 ? '#ef4444' : '#9ca3af'};">${index + 1}</span>
                                    <div class="top-info" style="flex: 1; padding-left: 10px;">
                                        <div class="top-title" style="font-weight: 500;">${title}</div>
                                        <div class="top-views" style="font-size: 0.85rem; color: #6b7280;">${Utils.formatViews(views)} lượt xem</div>
                                    </div>
                                </a>
                            `);
                        });
                    }
                } catch (err) {
                    if (container) container.innerHTML = '<span style="color: #ef4444;">Lỗi tải dữ liệu</span>';
                }
            },

            loadSlider: async function() {
                const list = document.getElementById('list_suggest');
                if (!list) return;
                try {
                    const data = await Utils.fetchAPI('http://localhost:5126/api/stories/newest');
                    if (!Array.isArray(data) || data.length === 0) {
                        list.innerHTML = '<li style="width:100%;text-align:center;padding:50px;">Chưa có truyện nào!</li>';
                        return;
                    }

                    list.innerHTML = '';
                    data.slice(0, 5).forEach(story => {
                        const id = story.id || story.Id;
                        const title = story.title || story.Title || 'Chưa có tên';
                        const desc = story.description || story.Description || 'Đang cập nhật...';
                        const cover = story.coverImage || story.CoverImage || 'https://via.placeholder.com/200x300';
                        const rating = story.rating || story.Rating || '5.0';
                        const views = Utils.formatViews(story.viewCount || story.ViewCount || 0);

                        list.insertAdjacentHTML('beforeend', `
                            <li class="suggest-slide" style="flex: 0 0 100%; width: 100%; box-sizing: border-box;">
                                <div class="featured-box" style="display:flex; align-items:center; justify-content:space-between; padding:40px; gap:30px; width:100%;">
                                    <div class="featured-info" style="flex:1; color:white;">
                                        <p class="tag-hot" style="color:#fbbf24; font-weight:bold; margin-bottom:10px;">NỔI BẬT</p>
                                        <h2 style="font-size:2.5rem; margin:0 0 15px 0; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">${title}</h2>
                                        <p class="desc" style="color:#9ca3af; margin-bottom:20px; display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; overflow:hidden;">${desc}</p>
                                        <div class="stats" style="margin-bottom:25px;">
                                            <span style="margin-right:15px; color:#fbbf24;"><i class="fas fa-star"></i> ${rating}</span>
                                            <span style="color:#9ca3af;"><i class="fas fa-eye"></i> ${views} lượt xem</span>
                                        </div>
                                        <a href="/Stories/Details/${id}" class="btn-read" style="display:inline-block; background-color:#3b82f6; color:white; padding:12px 32px; border-radius:20px; font-weight:bold; text-decoration:none;">Đọc ngay</a>
                                    </div>
                                    <div class="featured-cover" style="width:200px; height:300px; border-radius:12px; overflow:hidden; flex-shrink:0; background:#333; box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.5);">
                                        <img src="${cover}" alt="${title}" style="width:100%; height:100%; object-fit:cover;">
                                    </div>
                                </div>
                            </li>
                        `);
                    });

                    this.initSliderLogic();
                } catch (err) {
                    list.innerHTML = '<li style="width:100%;text-align:center;padding:50px;color:#ef4444;">Lỗi tải dữ liệu</li>';
                }
            },

            initSliderLogic: function() {
                const track = document.getElementById('list_suggest');
                if (!track) return;
                const slides = track.querySelectorAll('.suggest-slide');
                const slideCount = slides.length;
                let currentIndex = 0;
                let autoPlayTimer;

                const goToSlide = (index) => {
                    if (index >= slideCount) currentIndex = 0;
                    else if (index < 0) currentIndex = slideCount - 1;
                    else currentIndex = index;
                    track.style.transform = `translateX(-${currentIndex * 100}%)`;
                };

                const startAutoPlay = () => { autoPlayTimer = setInterval(() => goToSlide(currentIndex + 1), 5000); };
                const resetAutoPlay = () => { clearInterval(autoPlayTimer); startAutoPlay(); };

                document.querySelector('.slider-prev')?.addEventListener('click', () => { goToSlide(currentIndex - 1); resetAutoPlay(); });
                document.querySelector('.slider-next')?.addEventListener('click', () => { goToSlide(currentIndex + 1); resetAutoPlay(); });

                if(slideCount > 1) startAutoPlay();
            }
        };

        // ----------------------------------------------------
        // CHAT CONTROLLER: Xử lý giao tiếp AI
        // ----------------------------------------------------
        const ChatController = {
            elements: {
                body: document.getElementById('chatBody'),
                input: document.getElementById('chatInput'),
                btnSend: document.getElementById('sendChat')
            },

            init: function() {
                if (!this.elements.input || !this.elements.btnSend) return;

                this.elements.btnSend.addEventListener('click', () => this.sendMessage());

                this.elements.input.addEventListener('keypress', (e) => {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        this.sendMessage();
                    }
                });
            },

            sendMessage: async function() {
                const text = this.elements.input.value.trim();
                if (!text) return;

                this.appendMessage(text, 'user');
                this.elements.input.value = '';

                const typingId = 'typing-' + Date.now();
                this.appendMessage('<i class="fas fa-ellipsis-h fa-fade"></i> Đang suy nghĩ...', 'ai', typingId);

                try {
                    const response = await fetch('http://localhost:5126/api/chatbot/ask', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ message: text })
                    });

                    const data = await response.json();
                    document.getElementById(typingId)?.remove();

                    if (response.ok) {
                        this.appendMessage(data.reply.replace(/\n/g, '<br>'), 'ai');
                    } else {
                        this.appendMessage('Lỗi: ' + (data.message || 'Không thể kết nối API.'), 'ai');
                    }
                } catch (error) {
                    console.error("Chat Error:", error);
                    document.getElementById(typingId)?.remove();
                    this.appendMessage('Xin lỗi, hệ thống AI đang bận. Bạn thử lại sau nhé!', 'ai');
                }
            },

            appendMessage: function(text, senderClass, id = '') {
                if (!this.elements.body) return;

                const msgDiv = document.createElement('div');
                msgDiv.className = `message ${senderClass}`;
                if (id) msgDiv.id = id;
                msgDiv.innerHTML = text;

                this.elements.body.appendChild(msgDiv);
                this.elements.body.scrollTop = this.elements.body.scrollHeight;
            }
        };

        // ----------------------------------------------------
        // BOOTSTRAP APP
        // ----------------------------------------------------
        document.addEventListener('DOMContentLoaded', () => {
            AuthController.init();
            ChatController.init();
            SearchController.init();

            if (document.getElementById('homeSection') !== null) {
                UIController.init();
                DataController.init();
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
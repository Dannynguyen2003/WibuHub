import { Link, Outlet, useLocation } from 'react-router';
import { BookOpen, Home, Search, Bookmark, Library, TrendingUp, User, Menu, Bell, Coins, LogOut } from 'lucide-react';
import { AIChatbox } from './ai-chatbox';
import { useUser } from '@/app/context/user-context';
import { useState } from 'react';
import { CoinPurchaseModal } from './coin-purchase-modal';
import { AuthModal } from './auth-modal';

export function Layout() {
  const location = useLocation();
  const isReaderPage = location.pathname.includes('/reader');
  const { coins, user, logout } = useUser();
  const [isCoinModalOpen, setIsCoinModalOpen] = useState(false);
  const [isAuthModalOpen, setIsAuthModalOpen] = useState(false);
  const [authMode, setAuthMode] = useState<'login' | 'register'>('login');
  const [showUserMenu, setShowUserMenu] = useState(false);

  if (isReaderPage) {
    return <Outlet />;
  }

  const handleLogin = () => {
    setAuthMode('login');
    setIsAuthModalOpen(true);
  };

  const handleRegister = () => {
    setAuthMode('register');
    setIsAuthModalOpen(true);
  };

  const handleLogout = async () => {
    await logout();
    setShowUserMenu(false);
  };

  return (
    <div className="min-h-screen bg-gray-100 text-gray-900">
      {/* Top Banner */}
      <div className="bg-gradient-to-r from-green-500 to-blue-500 py-2 text-center text-xs text-white">
        <span>📚 Cập nhật truyện mới mỗi ngày - Đọc truyện miễn phí</span>
      </div>

      {/* Header */}
      <header className="border-b border-gray-200 bg-white shadow-sm">
        <div className="mx-auto max-w-[1200px] px-4">
          {/* Top Header */}
          <div className="flex h-16 items-center justify-between">
            <Link to="/" className="flex items-center gap-2">
              <BookOpen className="size-7 text-green-600" />
              <div>
                <div className="text-xl font-bold text-green-600">NetTruyen</div>
                <div className="text-[10px] text-gray-500">Đọc truyện online</div>
              </div>
            </Link>

            {/* Search Bar */}
            <div className="hidden flex-1 max-w-md mx-8 md:block">
              <div className="relative">
                <input
                  type="text"
                  placeholder="Tìm truyện..."
                  className="w-full rounded-full border border-gray-300 bg-gray-50 px-4 py-2 pr-10 text-sm outline-none focus:border-green-500 focus:ring-2 focus:ring-green-200"
                />
                <button className="absolute right-2 top-1/2 -translate-y-1/2 text-gray-400">
                  <Search className="size-5" />
                </button>
              </div>
            </div>

            <div className="flex items-center gap-3">
              {/* Coin Balance */}
              <button
                onClick={() => setIsCoinModalOpen(true)}
                className="flex items-center gap-2 rounded-full bg-gradient-to-r from-yellow-400 to-orange-500 px-4 py-2 text-sm font-semibold text-white shadow-md transition-transform hover:scale-105"
              >
                <Coins className="size-4" />
                <span>{coins.toLocaleString()}</span>
              </button>

              <button className="rounded-full p-2 hover:bg-gray-100">
                <Bell className="size-5 text-gray-600" />
              </button>
              
              {user ? (
                <div className="relative">
                  <button
                    onClick={() => setShowUserMenu(!showUserMenu)}
                    className="flex items-center gap-2 rounded-full bg-green-600 px-4 py-2 text-sm text-white hover:bg-green-700"
                  >
                    <User className="size-4" />
                    <span className="hidden sm:inline">{user.name}</span>
                  </button>
                  
                  {showUserMenu && (
                    <div className="absolute right-0 top-12 w-48 rounded-lg border border-gray-200 bg-white shadow-lg">
                      <div className="p-3 border-b border-gray-100">
                        <div className="font-semibold text-gray-900">{user.name}</div>
                        <div className="text-xs text-gray-500">{user.email}</div>
                      </div>
                      <div className="py-1">
                        <button
                          onClick={handleLogout}
                          className="flex w-full items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-gray-100"
                        >
                          <LogOut className="size-4" />
                          Đăng xuất
                        </button>
                      </div>
                    </div>
                  )}
                </div>
              ) : (
                <div className="flex items-center gap-2">
                  <button
                    onClick={handleLogin}
                    className="rounded-full bg-green-600 px-4 py-2 text-sm text-white hover:bg-green-700"
                  >
                    Đăng nhập
                  </button>
                  <button
                    onClick={handleRegister}
                    className="hidden sm:block rounded-full border border-green-600 px-4 py-2 text-sm text-green-600 hover:bg-green-50"
                  >
                    Đăng ký
                  </button>
                </div>
              )}
            </div>
          </div>

          {/* Navigation */}
          <nav className="flex h-12 items-center gap-6 border-t border-gray-100 text-sm">
            <Link
              to="/"
              className="flex items-center gap-1.5 font-medium text-green-600 hover:text-green-700"
            >
              <Home className="size-4" />
              Trang chủ
            </Link>
            <a href="#" className="text-gray-600 hover:text-green-600">
              Thể loại
            </a>
            <a href="#" className="text-gray-600 hover:text-green-600">
              Xếp hạng
            </a>
            <a href="#" className="text-gray-600 hover:text-green-600">
              Mới cập nhật
            </a>
            <a href="#" className="text-gray-600 hover:text-green-600">
              Hoàn thành
            </a>
          </nav>
        </div>
      </header>

      {/* Main Content */}
      <main className="bg-gray-100">
        <Outlet />
      </main>

      {/* Footer */}
      <footer className="border-t border-gray-200 bg-white py-8 mt-12">
        <div className="mx-auto max-w-[1200px] px-4">
          <div className="grid grid-cols-2 gap-8 md:grid-cols-4">
            <div>
              <h3 className="mb-3 font-semibold text-green-600">NetTruyen</h3>
              <ul className="space-y-2 text-sm text-gray-600">
                <li><a href="#" className="hover:text-green-600">Giới thiệu</a></li>
                <li><a href="#" className="hover:text-green-600">Liên hệ</a></li>
                <li><a href="#" className="hover:text-green-600">Điều khoản</a></li>
              </ul>
            </div>
            <div>
              <h3 className="mb-3 font-semibold text-green-600">Thể loại</h3>
              <ul className="space-y-2 text-sm text-gray-600">
                <li><a href="#" className="hover:text-green-600">Action</a></li>
                <li><a href="#" className="hover:text-green-600">Romance</a></li>
                <li><a href="#" className="hover:text-green-600">Fantasy</a></li>
              </ul>
            </div>
            <div>
              <h3 className="mb-3 font-semibold text-green-600">Hỗ trợ</h3>
              <ul className="space-y-2 text-sm text-gray-600">
                <li><a href="#" className="hover:text-green-600">Hướng dẫn</a></li>
                <li><a href="#" className="hover:text-green-600">FAQ</a></li>
              </ul>
            </div>
            <div>
              <h3 className="mb-3 font-semibold text-green-600">Theo dõi</h3>
              <ul className="space-y-2 text-sm text-gray-600">
                <li><a href="#" className="hover:text-green-600">Facebook</a></li>
                <li><a href="#" className="hover:text-green-600">Discord</a></li>
              </ul>
            </div>
          </div>
          <div className="mt-8 border-t border-gray-200 pt-8 text-center text-xs text-gray-500">
            <p>&copy; 2026 NetTruyen. All rights reserved.</p>
            <p className="mt-1">Mọi thông tin và hình ảnh trên website đều được sưu tầm trên Internet.</p>
          </div>
        </div>
      </footer>

      {/* AI Chatbox */}
      <AIChatbox />

      {/* Coin Purchase Modal */}
      <CoinPurchaseModal isOpen={isCoinModalOpen} onClose={() => setIsCoinModalOpen(false)} />

      {/* Auth Modal */}
      <AuthModal
        isOpen={isAuthModalOpen}
        onClose={() => setIsAuthModalOpen(false)}
        initialMode={authMode}
      />
    </div>
  );
}
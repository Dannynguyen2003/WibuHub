@model WibuHub.MVC.Customer.ViewModels.ChangePasswordVM

@{
    ViewData["Title"] = "Change Password";
}

<link rel="stylesheet" href="~/css/CustomerProfile.css" asp-append-version="true">

<div class="profile-page-wrapper">
    <div class="profile-container">

        <div class="profile-sidebar">
            <a href="/CustomerProfile" class="profile-menu-item">
                <i class="far fa-user-circle"></i> Manage Account
            </a>
            <a href="/CustomerProfile/ChangePassword" class="profile-menu-item active">
                <i class="fas fa-lock"></i> Change Password
            </a>
        </div>

        <div class="profile-content">

            <form asp-action="ChangePassword" method="post" class="profile-form">

                @if (ViewData["StatusMessage"] != null)
                {
                    <div class="alert-success-custom">
                        <i class="fas fa-check-circle"></i> @ViewData["StatusMessage"]
                    </div>
                }

                <h3 class="form-group-title"><i class="fas fa-shield-alt" style="color: #2563eb;"></i> Change account password</h3>

                <div class="form-group">
                    <label asp-for="OldPassword">Current Password</label>
                    <div style="position: relative;">
                        <input asp-for="OldPassword" type="password" class="form-control" placeholder="Enter old password..." data-password-field="old-password" style="padding-right: 40px;" />
                        <button type="button" data-password-toggle="old-password" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); background: transparent; border: none; cursor: pointer; color: #a0aec0; padding: 0; display: flex; align-items: center; justify-content: center;" aria-label="Toggle password visibility">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                        </button>
                    </div>
                    <div class="validation-error"><span asp-validation-for="OldPassword"></span></div>
                </div>

                <div class="form-group">
                    <label asp-for="NewPassword">New Password</label>
                    <div style="position: relative;">
                        <input asp-for="NewPassword" type="password" class="form-control" placeholder="Enter new password..." data-password-field="new-password" style="padding-right: 40px;" />
                        <button type="button" data-password-toggle="new-password" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); background: transparent; border: none; cursor: pointer; color: #a0aec0; padding: 0; display: flex; align-items: center; justify-content: center;" aria-label="Toggle password visibility">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                        </button>
                    </div>
                    <div class="validation-error"><span asp-validation-for="NewPassword"></span></div>
                </div>

                <div class="form-group">
                    <label asp-for="ConfirmPassword">Confirm New Password</label>
                    <div style="position: relative;">
                        <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Re-enter new password..." data-password-field="confirm-password" style="padding-right: 40px;" />
                        <button type="button" data-password-toggle="confirm-password" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); background: transparent; border: none; cursor: pointer; color: #a0aec0; padding: 0; display: flex; align-items: center; justify-content: center;" aria-label="Toggle password visibility">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                        </button>
                    </div>
                    <div class="validation-error"><span asp-validation-for="ConfirmPassword"></span></div>
                </div>

                <div class="btn-save-wrapper">
                    <button type="submit" class="btn-save"><i class="fas fa-key"></i> Update Password</button>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelectorAll('[data-password-toggle]').forEach(function (button) {
            button.addEventListener('click', function () {
                const fieldName = button.getAttribute('data-password-toggle');
                const passwordInput = document.querySelector('[data-password-field="' + fieldName + '"]');

                if (!passwordInput) {
                    return;
                }

                const isPassword = passwordInput.type === 'password';
                passwordInput.type = isPassword ? 'text' : 'password';

                if (isPassword) {
                    button.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>';
                } else {
                    button.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>';
                }
            });
        });
    </script>
}
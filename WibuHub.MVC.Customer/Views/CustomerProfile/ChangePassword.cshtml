@model WibuHub.MVC.Customer.ViewModels.ChangePasswordVM

@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<link rel="stylesheet" href="~/css/CustomerProfile.css" asp-append-version="true">

<div class="profile-page-wrapper">
    <div class="profile-container">

        <div class="profile-sidebar">
            <a href="/CustomerProfile" class="profile-menu-item">
                <i class="far fa-user-circle"></i> Quản lý tài khoản
            </a>
            <a href="/CustomerProfile/ChangePassword" class="profile-menu-item active">
                <i class="fas fa-lock"></i> Đổi mật khẩu
            </a>
        </div>

        <div class="profile-content">

            <form asp-action="ChangePassword" method="post" class="profile-form">

                @if (ViewData["StatusMessage"] != null)
                {
                    <div class="alert-success-custom">
                        <i class="fas fa-check-circle"></i> @ViewData["StatusMessage"]
                    </div>
                }

                <h3 class="form-group-title"><i class="fas fa-shield-alt" style="color: #2563eb;"></i> Thay đổi mật khẩu bảo mật</h3>

                <div class="form-group">
                    <label asp-for="OldPassword">Mật khẩu hiện tại</label>
                    <input asp-for="OldPassword" type="password" class="form-control" placeholder="Nhập mật khẩu cũ..." />
                    <div class="validation-error"><span asp-validation-for="OldPassword"></span></div>
                </div>

                <div class="form-group">
                    <label asp-for="NewPassword">Mật khẩu mới</label>
                    <input asp-for="NewPassword" type="password" class="form-control" placeholder="Nhập mật khẩu mới..." />
                    <div class="validation-error"><span asp-validation-for="NewPassword"></span></div>
                </div>

                <div class="form-group">
                    <label asp-for="ConfirmPassword">Xác nhận mật khẩu mới</label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Nhập lại mật khẩu mới..." />
                    <div class="validation-error"><span asp-validation-for="ConfirmPassword"></span></div>
                </div>

                <div class="btn-save-wrapper">
                    <button type="submit" class="btn-save"><i class="fas fa-key"></i> Cập nhật mật khẩu</button>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
@model List<WibuHub.MVC.Customer.ViewModels.FollowItemVM>

@{
    ViewData["Title"] = "Followed Stories";
}

<link rel="stylesheet" href="~/css/CustomerProfile.css" asp-append-version="true">

<div class="profile-page-wrapper">
    <div class="profile-container">
        @* <div class="profile-sidebar">
            <a href="/CustomerProfile" class="profile-menu-item"><i class="far fa-user-circle"></i> Manage Account</a>
            <a href="/CustomerProfile/Followed" class="profile-menu-item active"><i class="fas fa-bookmark"></i> Followed Stories</a>
            <a href="/CustomerProfile/History" class="profile-menu-item"><i class="fas fa-history"></i> Reading History</a>
            <a href="/CustomerProfile/ChangePassword" class="profile-menu-item"><i class="fas fa-lock"></i> Change Password</a>
        </div> *@

        <div class="profile-content">
            <div class="pane-header">
                <i class="fas fa-flag" style="color: #38bdf8;"></i> Followed Stories
            </div>

            @if (Model != null && Model.Any())
            {
                <div class="truyen-grid">
                    @foreach (var item in Model)
                    {
                        <div class="truyen-card">
                            <div class="truyen-cover">
                                <form asp-action="Unfollow" method="post" style="margin:0;">
                                    <input type="hidden" name="storyId" value="@item.StoryId" />
                                    <button type="submit" class="btn-remove-card" title="Unfollow"><i class="fas fa-times"></i></button>
                                </form>

                                <div class="tag-time">Updated</div>

                                <a href="/Stories/Details/@item.StoryId">
                                    <img src="@item.CoverImage" alt="@item.StoryTitle">
                                </a>
                            </div>

                            <a href="/Stories/Details/@item.StoryId" class="truyen-title">@item.StoryTitle</a>

                            @if (item.TotalChapters > 0)
                            {
                                <a href="@Url.Action("Read", "Stories", new { storyId = item.StoryId, chapter = item.TotalChapters })"
                                   class="truyen-chapter">
                                    Continue Reading Chapter @item.TotalChapters
                                </a>
                            }
                            else
                            {
                                <span class="truyen-chapter" style="color: #ef4444; cursor: not-allowed;">
                                    No Chapters
                                </span>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <div style="text-align:center; padding: 40px; color:#94a3b8;">
                    <i class="far fa-folder-open" style="font-size: 40px; margin-bottom: 10px;"></i>
                    <p>You haven't followed any stories yet.</p>
                </div>
            }
        </div>
    </div>
</div>
@model WibuHub.MVC.Customer.ViewModels.CustomerProfileVM

@{
    ViewData["Title"] = "Quản lý tài khoản";

    var avatarUrl = string.IsNullOrWhiteSpace(Model?.Avatar)
        ? "https://ui-avatars.com/api/?name=Anonymous&background=E2E8F0&color=475569"
        : Model.Avatar;

    var displayName = string.IsNullOrWhiteSpace(Model?.FullName)
        ? Model?.UserName
        : Model.FullName;
}

<link rel="stylesheet" href="~/css/CustomerProfile.css" asp-append-version="true">

<div class="profile-page-wrapper">
    <div class="profile-container">

        <div class="profile-sidebar">
            <a href="/CustomerProfile" class="profile-menu-item active">
                <i class="far fa-user-circle"></i> Quản lý tài khoản
            </a>
            <a href="/CustomerProfile/ChangePassword" class="profile-menu-item">
                <i class="fas fa-lock"></i> Đổi mật khẩu
            </a>
        </div>

        <div class="profile-content">

            <form asp-action="Index" method="post" enctype="multipart/form-data" class="profile-form">

                @if (ViewData["StatusMessage"] != null)
                {
                    <div class="alert-success-custom">
                        <i class="fas fa-check-circle"></i> @ViewData["StatusMessage"]
                    </div>
                }

                <div class="avatar-section">
                    <img id="avatarPreview" src="@avatarUrl" alt="@displayName" class="avatar-preview">
                    <br />

                    <label for="AvatarFile" class="btn-choose-image"><i class="fas fa-camera"></i> Chọn hình mới</label>
                    <input asp-for="AvatarFile" type="file" id="AvatarFile" accept="image/*" onchange="previewAvatar(event)" style="display:none;" />

                    <input asp-for="Avatar" type="hidden" />
                    <div class="validation-error"><span asp-validation-for="AvatarFile"></span></div>

                    <p class="warning-text"><i class="fas fa-exclamation-triangle"></i> Dùng hình 18+ sẽ bị khóa tài khoản vĩnh viễn.</p>
                </div>

                <div class="level-showcase">
                    <span class="level-label">Cấp @Model.Level</span>
                    <div class="level-progress-container">
                        <span class="level-percent">@Model.ExpPercentage% (@Model.RankTier)</span>
                        <div class="level-bar">
                            <div style="width: @Model.ExpPercentage%;"></div>
                        </div>
                    </div>
                    <span class="level-label">Cấp @(Model.Level + 1)</span>
                </div>

                <h3 class="form-group-title">Thông tin tài khoản</h3>

                <div class="form-group">
                    <label>Điểm tích lũy:</label>
                    <input type="text" class="form-control" value="@Model.Points Xu" readonly disabled>
                </div>

                <div class="form-group">
                    <label>Email liên kết:</label>
                    <input type="email" class="form-control" value="@Model?.Email" readonly disabled>
                </div>

                <h3 class="form-group-title">Thông tin cá nhân</h3>

                <div class="form-group">
                    <label asp-for="FullName">Họ và Tên</label>
                    <input asp-for="FullName" class="form-control" placeholder="Nhập họ và tên..." />
                    <div class="validation-error"><span asp-validation-for="FullName"></span></div>
                </div>

                <div class="form-group">
                    <label asp-for="PhoneNumber">Số điện thoại</label>
                    <input asp-for="PhoneNumber" class="form-control" placeholder="Nhập số điện thoại..." />
                    <div class="validation-error"><span asp-validation-for="PhoneNumber"></span></div>
                </div>

                <div class="btn-save-wrapper">
                    <button type="submit" class="btn-save"><i class="fas fa-save"></i> Lưu Thay Đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function previewAvatar(event) {
            var input = event.target;
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('avatarPreview').src = e.target.result;
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot your password?";
}

<div class="modal active">
    <div class="modal-content">
        <span class="modal-close" id="closeForgotModal" aria-label="Close forgot password form">&times;</span>
        <div class="modal-title">Forgot Password</div>
        <p style="text-align: center; color: #64748b; margin-bottom: 20px;">Nhập email để nhận liên kết đặt lại mật khẩu.</p>
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="form-error" role="alert"></div>
            <div class="input-group">
                <label asp-for="Input.Email">Email</label>
                <input asp-for="Input.Email" type="email" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <button type="submit" class="btn">Gửi liên kết đặt lại</button>
            <div class="switch-link">
                <a asp-page="./Login">Quay lại đăng nhập</a>
            </div>
        </form>
    </div>
</div>

@section Styles {
    <style>
        .form-error.validation-summary-errors {
            display: block;
        }
    </style>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const modal = document.querySelector('.modal.active');
            const closeBtn = document.getElementById('closeForgotModal');
            const loginUrl = '@Url.Page("./Login")';

            if (closeBtn) {
                closeBtn.addEventListener('click', function () {
                    window.location.href = loginUrl;
                });
            }

            if (modal) {
                modal.addEventListener('click', function (event) {
                    if (event.target === modal) {
                        window.location.href = loginUrl;
                    }
                });
            }
        })();
    </script>
}

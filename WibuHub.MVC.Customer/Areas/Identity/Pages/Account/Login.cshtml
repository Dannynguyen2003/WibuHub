@page
@model LoginModel

@{
    ViewData["Title"] = "Login";
}

<div class="modal" style="display: flex; position: static; background: transparent; padding: 40px 0;">
    <div class="modal-content">
        <div class="modal-title">Login</div>
        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            <div class="input-group">
                <label asp-for="Input.Email">Email</label>
                <input asp-for="Input.Email" type="email" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <div class="input-group">
                <label asp-for="Input.Password">Password</label>
                <div style="position: relative; display: flex; align-items: center;">
                    <input asp-for="Input.Password" type="password" autocomplete="current-password" aria-required="true" placeholder="••••••••" data-password-field="login-password" style="padding-right: 40px; width: 100%; box-sizing: border-box;" />
                    <button type="button" data-password-toggle="login-password" style="position: absolute; right: 10px; background: transparent; border: none; cursor: pointer; color: #a0aec0; padding: 0; display: flex; align-items: center; justify-content: center;" aria-label="Toggle password visibility">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                    </button>
                </div>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>
            <div class="input-group" style="display: flex; align-items: center; gap: 10px;">
                <input asp-for="Input.RememberMe" style="width: auto;" />
                <label asp-for="Input.RememberMe" style="margin: 0;">@Html.DisplayNameFor(m => m.Input.RememberMe)</label>
            </div>
            <button id="login-submit" type="submit" class="btn">Login</button>
            <div class="switch-link">
                <a id="forgot-password" asp-page="./ForgotPassword">Forgot password?</a>
            </div>
            <div class="switch-link">
                Don't have an account? <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Register now</a>
            </div>
            <div class="switch-link">
                <a id="resend-confirmation" asp-page="./ResendEmailConfirmation">Resend confirmation email</a>
            </div>
        </form>

        @if ((Model.ExternalLogins?.Count ?? 0) > 0)
        {
            <div style="margin-top: 20px;">
                <p style="text-align: center; color: #64748b; margin-bottom: 12px;">Or connect with</p>
                <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" style="display: flex; gap: 10px; flex-wrap: wrap;">
                    @foreach (var provider in Model.ExternalLogins!)
                    {
                        <button type="submit" class="btn" style="width: auto;" name="provider" value="@provider.Name" title="Log in using your @provider.DisplayName account">
                            @provider.DisplayName
                        </button>
                    }
                </form>
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelectorAll('[data-password-toggle]').forEach(function (button) {
            button.addEventListener('click', function () {
                const fieldName = button.getAttribute('data-password-toggle');
                const passwordInput = document.querySelector('[data-password-field="' + fieldName + '"]');

                if (!passwordInput) {
                    return;
                }

                const isPassword = passwordInput.type === 'password';
                passwordInput.type = isPassword ? 'text' : 'password';
                
                if (isPassword) {
                    button.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>';
                } else {
                    button.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>';
                }
            });
        });
    </script>
}
